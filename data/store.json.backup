          "mode": "raw",
          "cardTitle": "Dharmesh Enterprise",
          "category": "Case Study",
          "summary": "Developed a responsive management experience that simplified inventory and billing workflows.",
          "thumbnailImage": "/assets/images/work-card-mockup/de-mockup.png",
          "thumbnailAlt": "Dharmesh Enterprise project mockup",
          "metaTitle": "Dharmesh Enterprise | Webx Design Studio",
          "metaDescription": "Developed a responsive management experience that simplified inventory and billing workflows.",
          "rawHtml": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n\n<title>Dharmesh Enterprise | Webx Design Studio</title>\n<meta name=\"description\" content=\"Developed a responsive management experience that simplified inventory and billing workflows.\" />\n<meta name=\"robots\" content=\"index, follow\" />\n<meta name=\"author\" content=\"Webx Design Studio\" />\n<meta name=\"theme-color\" content=\"#ff6b00\" />\n\n<link rel=\"canonical\" href=\"https://webxds.com/pages/details/de-pdp.html\" />\n\n<meta property=\"og:type\" content=\"article\" />\n<meta property=\"og:title\" content=\"Dharmesh Enterprise | Webx Design Studio\" />\n<meta property=\"og:description\" content=\"Developed a responsive management experience that simplified inventory and billing workflows.\" />\n<meta property=\"og:url\" content=\"https://webxds.com/pages/details/de-pdp.html\" />\n<meta property=\"og:image\" content=\"https://webxds.com/assets/images/others/work.png\" />\n<meta property=\"og:site_name\" content=\"Webx Design Studio\" />\n<meta property=\"og:locale\" content=\"en_IN\" />\n\n<meta name=\"twitter:card\" content=\"summary_large_image\" />\n<meta name=\"twitter:title\" content=\"Dharmesh Enterprise | Webx Design Studio\" />\n<meta name=\"twitter:description\" content=\"Developed a responsive management experience that simplified inventory and billing workflows.\" />\n<meta name=\"twitter:image\" content=\"https://webxds.com/assets/images/others/work.png\" />\n\n<link rel=\"icon\" href=\"/assets/images/icons/favicon.png\" type=\"image/png\" sizes=\"32x32\" />\n<link rel=\"apple-touch-icon\" href=\"/assets/images/icons/favicon-180.png\" sizes=\"180x180\" />\n<link rel=\"manifest\" href=\"/manifest.json\" />\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\" />\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin />\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap\" rel=\"stylesheet\" />\n<link rel=\"stylesheet\" href=\"/css/style.css\" />\n<link rel=\"preload\" href=\"/assets/images/others/work.png\" as=\"image\" />\n\n<script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n  \"@type\": \"CreativeWork\",\n  \"name\": \"Dharmesh Enterprise | Webx Design Studio\",\n  \"description\": \"Developed a responsive management experience that simplified inventory and billing workflows.\",\n  \"url\": \"https://webxds.com/pages/details/de-pdp.html\",\n  \"image\": \"https://webxds.com/assets/images/others/work.png\",\n  \"author\": {\n    \"@type\": \"Organization\",\n    \"name\": \"Webx Design Studio\",\n    \"url\": \"https://webxds.com\"\n  }\n}\n</script>\n\n<script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n  \"@type\": \"BreadcrumbList\",\n  \"itemListElement\": [\n    { \"@type\": \"ListItem\", \"position\": 1, \"name\": \"Home\", \"item\": \"https://webxds.com/\" },\n    { \"@type\": \"ListItem\", \"position\": 2, \"name\": \"Work\", \"item\": \"https://webxds.com/pages/main/work.html\" },\n    { \"@type\": \"ListItem\", \"position\": 3, \"name\": \"Dharmesh Enterprise\", \"item\": \"https://webxds.com/pages/details/de-pdp.html\" }\n  ]\n}\n</script>\n\n\n<script type=\"text/javascript\">\n    (function(c,l,a,r,i,t,y){\n        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};\n        t=l.createElement(r);t.async=1;t.src=\"https://www.clarity.ms/tag/\"+i;\n        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);\n    })(window, document, \"clarity\", \"script\", \"w2scyt23ol\");\n</script>\n</head>\n<body>\n\n<noscript>\n  <div style=\"padding: 20px; background: #111; color: #fff; text-align: center; font-family: sans-serif;\">\n    This website requires JavaScript to function correctly. Please enable JavaScript in your browser settings.\n  </div>\n</noscript>\n\n<header>\n  <section class=\"pdp-hero-section\" aria-label=\"Dharmesh Enterprise case study hero\">\n    <div class=\"hero-bg-morphico\" aria-hidden=\"true\">\n      <img src=\"/assets/images/others/work.png\" alt=\"\" class=\"hero-bg-image-morphico\" width=\"1440\" height=\"800\" loading=\"eager\" />\n    </div>\n    <nav class=\"home-navbar\" aria-label=\"Main navigation\">\n      <div class=\"home-nav-container\">\n        <div class=\"home-logo\">\n          <a href=\"/\" class=\"logo-link\" aria-label=\"Webx Design Studio - Go to homepage\">\n            <img src=\"/assets/images/logos/webx-logo.svg\" alt=\"Webx Design Studio\" width=\"140\" height=\"40\" />\n          </a>\n        </div>\n        <a href=\"/pages/main/contact-page.html\" class=\"home-contact-btn\">\n          <span>CONTACT US</span>\n          <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" aria-hidden=\"true\">\n            <path d=\"M3 13L13 3M13 3H5M13 3V11\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n          </svg>\n        </a>\n      </div>\n    </nav>\n    <div class=\"page-wrapper\">\n      <div class=\"container\">\n        <div class=\"content\">\n          <nav class=\"breadcrumb-nav\" aria-label=\"Breadcrumb\">\n            <a href=\"/\" class=\"breadcrumb-link\">Home</a>\n            <span class=\"breadcrumb-separator\" aria-hidden=\"true\">&#8250;</span>\n            <a href=\"/pages/main/work.html\" class=\"breadcrumb-link\">Work</a>\n            <span class=\"breadcrumb-separator\" aria-hidden=\"true\">&#8250;</span>\n            <span class=\"breadcrumb-current\" aria-current=\"page\">Dharmesh Enterprise</span>\n          </nav>\n          <h1>Dharmesh Enterprise</h1>\n        </div>\n        <div class=\"mockup-container\">\n          <img src=\"/assets/images/work-card-mockup/de-mockup.png\" alt=\"Dharmesh Enterprise project mockup\" class=\"original-mockup\" width=\"700\" height=\"500\" loading=\"eager\" />\n        </div>\n      </div>\n    </div>\n  </section>\n</header>\n\n<main>\n<section class=\"about-section\" aria-label=\"About Dharmesh Enterprise\">\n  <div class=\"about-content\">\n    <h2>About Dharmesh Enterprise</h2>\n    <p class=\"about-description\">Add project overview, challenge, and design approach here.</p>\n    <div class=\"info-grid\">\n      <div class=\"info-item\"><h3>Industries</h3><p>Industry</p></div>\n      <div class=\"info-item\"><h3>Year</h3><p>2026</p></div>\n      <div class=\"info-item full-width\"><h3>Services</h3><p>UI UX Design</p></div>\n    </div>\n  </div>\n</section>\n\n<section class=\"challenge-solution-section\" aria-label=\"Challenge and solution\">\n  <div class=\"cs-container\">\n    <div class=\"cs-column\">\n      <h2>The Challenge</h2>\n      <ul class=\"cs-list\">\n        <li><div class=\"cs-list-content\"><span><strong>Challenge one:</strong> Add the first challenge point here.</span></div></li>\n      </ul>\n    </div>\n    <div class=\"cs-column\">\n      <h2>The Solution</h2>\n      <ul class=\"cs-list\">\n        <li><div class=\"cs-list-content\"><span><strong>Solution one:</strong> Add the first solution point here.</span></div></li>\n      </ul>\n    </div>\n  </div>\n</section>\n\n<section class=\"comparison-section\" aria-label=\"UX/UI before and after comparison\">\n  <div class=\"comparison-header\" aria-hidden=\"true\">\n    <div class=\"comparison-label\">UX</div>\n    <div class=\"comparison-label\">UI</div>\n  </div>\n  <div class=\"comparison-wrapper\">\n    <div class=\"before-after-container\" style=\"background:#1f1f1f;\">\n      <div class=\"before-after-slider\" role=\"group\" aria-label=\"Before and after design comparison slider\">\n        <figure class=\"before-image\"><img src=\"/assets/images/others/work.png\" alt=\"Dharmesh Enterprise before image\" width=\"800\" height=\"600\" loading=\"lazy\" /></figure>\n        <figure class=\"after-image\"><img src=\"/assets/images/work-card-mockup/de-mockup.png\" alt=\"Dharmesh Enterprise after image\" width=\"800\" height=\"600\" loading=\"lazy\" /></figure>\n        <div class=\"slider-handle\" aria-hidden=\"true\"><div class=\"handle-circle\"><svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><path d=\"M15 19L8 12L15 5\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg><svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\"><path d=\"M9 5L16 12L9 19\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></div><div class=\"handle-line\"></div></div>\n        <input type=\"range\" min=\"0\" max=\"100\" value=\"50\" class=\"slider-input\" id=\"comparison-slider\" aria-label=\"Drag to compare UX and UI designs\" />\n      </div>\n    </div>\n  </div>\n</section>\n\n<section class=\"visual-identity-section\" aria-label=\"Visual identity design\">\n  <div class=\"vi-container\">\n    <div class=\"section-header animate-fade-in\">\n      <p class=\"section-label\">Visual Identity</p>\n      <h2 class=\"section-title\">Design framework built for clarity and consistency</h2>\n    </div>\n    <div class=\"vi-scroll-wrapper\">\n      <div class=\"vi-grid\" id=\"viGrid\">\n        <div class=\"vi-card\"><div class=\"vi-card-image\"><img src=\"/assets/images/others/work.png\" alt=\"Dharmesh Enterprise visual identity\" width=\"400\" height=\"300\" loading=\"lazy\" /></div><h3 class=\"vi-card-title\">Colour Style</h3><p class=\"vi-card-description\">Add description here.</p></div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section class=\"design-system-section\" aria-label=\"Design system\">\n  <div class=\"ds-container\">\n    <div class=\"section-header animate-fade-in\">\n      <p class=\"section-label\">Design System</p>\n      <h2 class=\"section-title\">Document the interface system and components</h2>\n    </div>\n    <div class=\"ds-image-wrapper\">\n      <img src=\"/assets/images/others/work.png\" alt=\"Dharmesh Enterprise design system\" class=\"ds-image\" width=\"1200\" height=\"700\" loading=\"lazy\" />\n    </div>\n  </div>\n</section>\n\n<section class=\"web-ui-section\" aria-label=\"Web UI designs\">\n  <div class=\"web-ui-container\">\n    <div class=\"section-header animate-fade-in\">\n      <p class=\"section-label\">Web UI</p>\n      <h2 class=\"section-title\">Showcase the web experience</h2>\n    </div>\n    <div class=\"web-ui-slider-wrapper\"><div class=\"web-ui-slider-container\" id=\"webUiSliderContainer\"><div class=\"web-ui-slider\" id=\"webUiSlider\"><div class=\"web-ui-slide\"><img src=\"/assets/images/others/work.png\" alt=\"Dharmesh Enterprise web ui\" class=\"web-ui-image\" width=\"900\" height=\"600\" loading=\"lazy\" /></div></div></div></div>\n  </div>\n</section>\n\n<section class=\"web-ui-section\" aria-label=\"Mobile UI designs\">\n  <div class=\"web-ui-container\">\n    <div class=\"section-header animate-fade-in\">\n      <p class=\"section-label\">Mobile UI</p>\n      <h2 class=\"section-title\">Showcase the mobile experience</h2>\n    </div>\n    <div class=\"web-ui-slider-wrapper\"><div class=\"web-ui-slider-container\" id=\"mobileUiSliderContainer\"><div class=\"web-ui-slider\" id=\"mobileUiSlider\"><div class=\"web-ui-slide\"><img src=\"/assets/images/others/work.png\" alt=\"Dharmesh Enterprise mobile ui\" class=\"web-ui-image\" width=\"400\" height=\"700\" loading=\"lazy\" /></div></div></div></div>\n  </div>\n</section>\n\n<section class=\"impact-section animate-section\" aria-label=\"Impact and client testimonial\">\n  <div class=\"impact-container\">\n    <div class=\"section-header animate-fade-in\">\n      <div class=\"section-label\">Impact &amp; Achievements</div>\n      <h2 class=\"section-title\">From vision to impact - a team that delivers consistently</h2>\n    </div>\n    <div class=\"impact-slider-wrapper animate-slider\">\n      <div class=\"impact-slider\" id=\"impactSlider\">\n        <div class=\"impact-slide active\">\n          <div class=\"impact-quote-block\">\n            <img src=\"/assets/images/icons/quote-icon.svg\" alt=\"\" class=\"quote-icon\" aria-hidden=\"true\" width=\"32\" height=\"32\" loading=\"lazy\" />\n            <p class=\"quote-text\">\"Add testimonial or project impact statement here.\"</p>\n          </div>\n          <div class=\"impact-footer\">\n            <div class=\"author-card\">\n              <img src=\"/assets/images/blogs/auther-imag-ab.png\" alt=\"Client\" class=\"author-photo\" width=\"56\" height=\"56\" loading=\"lazy\" />\n              <div class=\"author-info\"><div class=\"author-name\">Client Name</div><div class=\"author-title\">Role / Company</div></div>\n            </div>\n            <div class=\"brand-logo\"><img src=\"/assets/images/work-card-mockup/de-mockup.png\" alt=\"Dharmesh Enterprise logo\" width=\"100\" height=\"50\" loading=\"lazy\" /></div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section class=\"about-section\" aria-label=\"Project outcomes\">\n  <div class=\"about-content\">\n    <h2>Key Outcomes</h2>\n    <div class=\"info-grid\">\n      <div class=\"info-item\"><h3>01</h3><p>Outcome one</p></div><div class=\"info-item\"><h3>02</h3><p>Outcome two</p></div><div class=\"info-item\"><h3>03</h3><p>Outcome three</p></div>\n    </div>\n  </div>\n</section>\n\n<section class=\"web-ui-section\" aria-label=\"Project gallery\">\n  <div class=\"web-ui-container\">\n    <div class=\"section-header animate-fade-in\">\n      <p class=\"section-label\">Gallery</p>\n      <h2 class=\"section-title\">Project Gallery</h2>\n    </div>\n    <div class=\"web-ui-slider-wrapper\"><div class=\"web-ui-slider-container\"><div class=\"web-ui-slider\"><div class=\"web-ui-slide\"><img src=\"/assets/images/others/work.png\" alt=\"Dharmesh Enterprise gallery image\" class=\"web-ui-image\" width=\"900\" height=\"600\" loading=\"lazy\" /></div></div></div></div>\n  </div>\n</section>\n\n<section class=\"next-work-section\" aria-label=\"Explore more case studies\"><div class=\"next-work-container\"><h2 class=\"next-work-heading\">EXPLORE MORE WORK</h2><div class=\"next-work-scroll-wrapper\"><div class=\"next-work-grid\" id=\"nextWorkGrid\"><a href=\"/pages/details/morphico-pdp.html\" class=\"next-work-card\" style=\"background-image: url('/assets/images/work-card-mockup/morphico-mockup.png');\"><div class=\"card-content\"><h3 class=\"card-title\">Morphico Wallpapers &amp; Murals</h3><p class=\"card-description\">Transformed luxury interiors by designing an immersive digital gallery that brings wallpaper artistry to life.</p><div class=\"card-tags\"><span class=\"card-tag\">Interior Brand / E-commerce</span></div></div><div class=\"card-mockup\"><img src=\"/assets/images/work-card-mockup/morphico-mockup.png\" alt=\"Morphico Wallpapers and Murals project mockup\" class=\"mockup-image\" width=\"200\" height=\"120\" loading=\"lazy\" /></div></a><a href=\"/pages/details/ab-pdp.html\" class=\"next-work-card\" style=\"background-image: url('/assets/images/work-card-mockup/ab-mockup.png');\"><div class=\"card-content\"><h3 class=\"card-title\">Arogya Bharat</h3><p class=\"card-description\">Architected a clinical UI/UX system that resolved navigation friction in the healthcare procurement journey.</p><div class=\"card-tags\"><span class=\"card-tag\">Healthcare / UI System</span></div></div><div class=\"card-mockup\"><img src=\"/assets/images/work-card-mockup/ab-mockup.png\" alt=\"Arogya Bharat project mockup\" class=\"mockup-image\" width=\"200\" height=\"120\" loading=\"lazy\" /></div></a><a href=\"/pages/details/tictax-pdp.html\" class=\"next-work-card\" style=\"background-image: url('/assets/images/work-card-mockup/tictax-mockup.png');\"><div class=\"card-content\"><h3 class=\"card-title\">Tictax</h3><p class=\"card-description\">Engineered frictionless fintech interfaces that turned complex tax saving into a premium digital experience.</p><div class=\"card-tags\"><span class=\"card-tag\">Fintech / Tax Platform</span></div></div><div class=\"card-mockup\"><img src=\"/assets/images/work-card-mockup/tictax-mockup.png\" alt=\"Tictax project mockup\" class=\"mockup-image\" width=\"200\" height=\"120\" loading=\"lazy\" /></div></a><a href=\"/pages/details/mecon-pdp.html\" class=\"next-work-card\" style=\"background-image: url('/assets/images/work-card-mockup/mecon-logo.png');\"><div class=\"card-content\"><h3 class=\"card-title\">Mecon</h3><p class=\"card-description\">Crafted a modern industrial identity that positioned the legacy manufacturer with fresh authority.</p><div class=\"card-tags\"><span class=\"card-tag\">Industrial / Brand Identity</span></div></div><div class=\"card-mockup\"><img src=\"/assets/images/work-card-mockup/mecon-logo.png\" alt=\"Mecon project identity\" class=\"mockup-image\" width=\"200\" height=\"120\" loading=\"lazy\" /></div></a><a href=\"/pages/details/gurukrupa-pdp.html\" class=\"next-work-card\" style=\"background-image: url('/assets/images/work-card-mockup/gurukrupa-mockup.png');\"><div class=\"card-content\"><h3 class=\"card-title\">Gurukrupa</h3><p class=\"card-description\">Forged a precision-led brand framework that unified a diverse industrial catalog.</p><div class=\"card-tags\"><span class=\"card-tag\">Industrial / Brand</span></div></div><div class=\"card-mockup\"><img src=\"/assets/images/work-card-mockup/gurukrupa-mockup.png\" alt=\"Gurukrupa project mockup\" class=\"mockup-image\" width=\"200\" height=\"120\" loading=\"lazy\" /></div></a><a href=\"/pages/details/manglam-pdp.html\" class=\"next-work-card\" style=\"background-image: url('/assets/images/work-card-mockup/mangalam-mockup.png');\"><div class=\"card-content\"><h3 class=\"card-title\">Manglam</h3><p class=\"card-description\">Modernized financial consultancy through a strategic identity built for stability and growth.</p><div class=\"card-tags\"><span class=\"card-tag\">Finance / Consultancy</span></div></div><div class=\"card-mockup\"><img src=\"/assets/images/work-card-mockup/mangalam-mockup.png\" alt=\"Manglam project mockup\" class=\"mockup-image\" width=\"200\" height=\"120\" loading=\"lazy\" /></div></a></div></div></div></section>\n\n<section class=\"cta-banner-section\" aria-label=\"Start your project\">\n  <div class=\"cta-banner-content\">\n    <h2 class=\"cta-banner-title\">Want a case study page like this?</h2>\n    <a href=\"/pages/main/contact-page.html\" class=\"cta-banner-button\">\n      <span>Start Your Project</span>\n      <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\"><path d=\"M7 17L17 7M17 7H7M17 7V17\" /></svg>\n    </a>\n  </div>\n</section>\n</main>\n\n<footer class=\"footer-section\" aria-label=\"Site footer\">\n  <div class=\"footer-container\">\n    <div class=\"footer-top\"><div class=\"footer-logo\"><img src=\"/assets/images/logos/webx-logo.svg\" alt=\"Webx Design Studio\" class=\"footer-logo-img\" width=\"140\" height=\"40\" loading=\"lazy\" /></div></div>\n    <div class=\"footer-section-block\"><h3 class=\"footer-heading\">Services</h3><div class=\"footer-links\"><a href=\"/pages/main/services.html\">UI/UX Design</a><a href=\"/pages/main/services.html\">Web Design</a><a href=\"/pages/main/services.html\">App Design</a><a href=\"/pages/main/services.html\">Marketing Emailer</a></div></div>\n    <div class=\"footer-section-block\"><h3 class=\"footer-heading\">Company</h3><div class=\"footer-links\"><a href=\"/pages/main/about.html\">About Us</a><a href=\"/pages/blogs/blogs.html\">Blog</a><a href=\"/pages/main/contact-page.html\">Contact</a></div></div>\n    <div class=\"footer-bottom\"><p class=\"footer-copyright\">&copy; 2026 Webx Design Studio. All rights reserved</p></div>\n  </div>\n  <div class=\"footer-bg-text\" aria-hidden=\"true\"><img src=\"/assets/images/logos/webx-footer-logo-large.svg\" alt=\"\" class=\"footer-bg-image\" loading=\"lazy\" /></div>\n</footer>\n\n<div class=\"more-menu-overlay\" id=\"moreMenu\" role=\"dialog\" aria-modal=\"true\" aria-label=\"Full navigation menu\"></div>\n<button class=\"scroll-to-top\" id=\"scrollToTop\" aria-label=\"Scroll to top of page\"><svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" xmlns=\"http:/www.w3.org/2000/svg\" aria-hidden=\"true\"><path d=\"M10 15V5M10 5L5 10M10 5L15 10\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></button>\n<nav class=\"bottom-navbar\" aria-label=\"Bottom navigation\"><div class=\"bottom-nav-logo\"><a href=\"/\" class=\"logo-link\" aria-label=\"Webx Design Studio - Go to homepage\"><img src=\"/assets/images/logos/webx-logo.svg\" alt=\"Webx Design Studio\" class=\"logo-full\" width=\"100\" height=\"30\" loading=\"lazy\" /><img src=\"/assets/images/icons/webx-icon.svg\" alt=\"Webx\" class=\"logo-icon\" width=\"32\" height=\"32\" loading=\"lazy\" /></a></div><div class=\"bottom-nav-container\"><a href=\"/\" class=\"nav-item\"><img src=\"/assets/images/others/home.png\" alt=\"\" class=\"nav-icon\" aria-hidden=\"true\" width=\"24\" height=\"24\" loading=\"lazy\" /><span class=\"nav-label\">Home</span></a><a href=\"/pages/main/work.html\" class=\"nav-item active\" aria-current=\"page\"><img src=\"/assets/images/others/work.png\" alt=\"\" class=\"nav-icon\" aria-hidden=\"true\" width=\"24\" height=\"24\" loading=\"lazy\" /><span class=\"nav-label\">Work</span></a><a href=\"/pages/main/services.html\" class=\"nav-item\"><img src=\"/assets/images/others/services.png\" alt=\"\" class=\"nav-icon\" aria-hidden=\"true\" width=\"24\" height=\"24\" loading=\"lazy\" /><span class=\"nav-label\">Services</span></a><a href=\"/pages/main/about.html\" class=\"nav-item\"><img src=\"/assets/images/others/about.png\" alt=\"\" class=\"nav-icon\" aria-hidden=\"t