        {
          "id": "work-project-dd18bfc3",
          "slug": "ab-pdp",
          "path": "/pages/details/ab-pdp.html",
          "status": "live",
          "mode": "raw",
          "cardTitle": "Arogya Bharat",
          "category": "Case Study",
          "summary": "Architected a clinical UI/UX system that resolved navigation friction in the healthcare procurement journey.",
          "thumbnailImage": "/assets/images/work-card-mockup/ab-mockup.png",
          "thumbnailAlt": "Arogya Bharat project mockup",
          "metaTitle": "Arogya Bharat | Webx Design Studio",
          "metaDescription": "Architected a clinical UI/UX system that resolved navigation friction in the healthcare procurement journey.",
          "rawHtml": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n\n<title>Arogya Bharat - Healthcare UI/UX Design Case Study | Webx Design Studio</title>\n<meta name=\"description\" content=\"How Webx Design Studio transformed Arogya Bharat's digital storefront with UI/UX design for healthcare instruments - simplifying complex medical data and purchasing paths.\" />\n<meta name=\"robots\" content=\"index, follow\" />\n<meta name=\"author\" content=\"Webx Design Studio\" />\n<meta name=\"theme-color\" content=\"#ff6b00\" />\n\n<link rel=\"canonical\" href=\"https://webxds.com/pages/details/ab-pdp.html\" />\n\n<meta property=\"og:type\" content=\"article\" />\n<meta property=\"og:title\" content=\"Arogya Bharat - Healthcare UI/UX Design Case Study | Webx Design Studio\" />\n<meta property=\"og:description\" content=\"How Webx Design Studio transformed Arogya Bharat's digital storefront with UI/UX design for healthcare instruments - simplifying complex medical data and purchasing paths.\" />\n<meta property=\"og:url\" content=\"https://webxds.com/pages/details/ab-pdp.html\" />\n<meta property=\"og:image\" content=\"https://webxds.com/assets/images/banners/ab-hero-banner.png\" />\n<meta property=\"og:image:width\" content=\"1200\" />\n<meta property=\"og:image:height\" content=\"630\" />\n<meta property=\"og:image:alt\" content=\"Arogya Bharat Healthcare UI/UX Case Study by Webx Design Studio\" />\n<meta property=\"og:site_name\" content=\"Webx Design Studio\" />\n<meta property=\"og:locale\" content=\"en_IN\" />\n\n<meta name=\"twitter:card\" content=\"summary_large_image\" />\n<meta name=\"twitter:title\" content=\"Arogya Bharat - Healthcare UI/UX Design Case Study | Webx Design Studio\" />\n<meta name=\"twitter:description\" content=\"How Webx Design Studio transformed Arogya Bharat's digital storefront with UI/UX design for healthcare instruments - simplifying complex medical data and purchasing paths.\" />\n<meta name=\"twitter:image\" content=\"https://webxds.com/assets/images/banners/ab-hero-banner.png\" />\n<meta name=\"twitter:image:alt\" content=\"Arogya Bharat Healthcare UI/UX Case Study by Webx Design Studio\" />\n\n<link rel=\"icon\" href=\"/assets/images/icons/favicon.png\" type=\"image/png\" sizes=\"32x32\" />\n<link rel=\"apple-touch-icon\" href=\"/assets/images/icons/favicon-180.png\" sizes=\"180x180\" />\n\n<link rel=\"manifest\" href=\"/manifest.json\" />\n\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\" />\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin />\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap\" rel=\"stylesheet\" />\n\n<link rel=\"stylesheet\" href=\"/css/style.css\" />\n\n<link rel=\"preload\" href=\"/assets/images/banners/ab-hero-banner.png\" as=\"image\" />\n\n<script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n  \"@type\": \"CreativeWork\",\n  \"name\": \"Arogya Bharat - Healthcare UI/UX Design Case Study\",\n  \"description\": \"How Webx Design Studio transformed Arogya Bharat's digital storefront with UI/UX design for healthcare instruments.\",\n  \"url\": \"https://webxds.com/pages/details/ab-pdp.html\",\n  \"image\": \"https://webxds.com/assets/images/banners/ab-hero-banner.png\",\n  \"author\": {\n    \"@type\": \"Organization\",\n    \"name\": \"Webx Design Studio\",\n    \"url\": \"https://webxds.com\"\n  },\n  \"dateCreated\": \"2024\",\n  \"keywords\": \"healthcare UI/UX design, medical instruments, Arogya Bharat, e-commerce, branding\"\n}\n</script>\n\n<script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n  \"@type\": \"BreadcrumbList\",\n  \"itemListElement\": [\n    {\n      \"@type\": \"ListItem\",\n      \"position\": 1,\n      \"name\": \"Home\",\n      \"item\": \"https://webxds.com/\"\n    },\n    {\n      \"@type\": \"ListItem\",\n      \"position\": 2,\n      \"name\": \"Work\",\n      \"item\": \"https://webxds.com/pages/main/work.html\"\n    },\n    {\n      \"@type\": \"ListItem\",\n      \"position\": 3,\n      \"name\": \"Arogya Bharat\",\n      \"item\": \"https://webxds.com/pages/details/ab-pdp.html\"\n    }\n  ]\n}\n</script>\n\n\n<script type=\"text/javascript\">\n    (function(c,l,a,r,i,t,y){\n        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};\n        t=l.createElement(r);t.async=1;t.src=\"https://www.clarity.ms/tag/\"+i;\n        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);\n    })(window, document, \"clarity\", \"script\", \"w2scyt23ol\");\n</script>\n</head>\n<body>\n\n<noscript>\n  <div style=\"padding: 20px; background: #111; color: #fff; text-align: center; font-family: sans-serif;\">\n    This website requires JavaScript to function correctly. Please enable JavaScript in your browser settings.\n  </div>\n</noscript>\n\n<!-- Hero Section -->\n<header>\n  <section class=\"pdp-hero-section\" aria-label=\"Arogya Bharat case study hero\">\n    <div class=\"hero-bg-morphico\" aria-hidden=\"true\">\n      <img src=\"/assets/images/banners/ab-hero-banner.png\" alt=\"\" class=\"hero-bg-image-morphico\" width=\"1440\" height=\"800\" loading=\"eager\" />\n    </div>\n    <nav class=\"home-navbar\" aria-label=\"Main navigation\">\n      <div class=\"home-nav-container\">\n        <div class=\"home-logo\">\n          <a href=\"/\" class=\"logo-link\" aria-label=\"Webx Design Studio - Go to homepage\">\n            <img src=\"/assets/images/logos/webx-logo.svg\" alt=\"Webx Design Studio\" width=\"140\" height=\"40\" />\n          </a>\n        </div>\n        <a href=\"/pages/main/contact-page.html\" class=\"home-contact-btn\">\n          <span>CONTACT US</span>\n          <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" aria-hidden=\"true\">\n            <path d=\"M3 13L13 3M13 3H5M13 3V11\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n          </svg>\n        </a>\n      </div>\n    </nav>\n    <div class=\"page-wrapper\">\n      <div class=\"container\">\n        <div class=\"content\">\n          <nav class=\"breadcrumb-nav\" aria-label=\"Breadcrumb\">\n            <a href=\"/\" class=\"breadcrumb-link\">Home</a>\n            <span class=\"breadcrumb-separator\" aria-hidden=\"true\">&#8250;</span>\n            <a href=\"/pages/main/work.html\" class=\"breadcrumb-link\">Work</a>\n            <span class=\"breadcrumb-separator\" aria-hidden=\"true\">&#8250;</span>\n            <span class=\"breadcrumb-current\" aria-current=\"page\">Arogya Bharat</span>\n          </nav>\n          <h1>Where Healthcare Innovation Meets Design Consistency</h1>\n        </div>\n        <div class=\"mockup-container\">\n          <img src=\"/assets/images/clients/ab-mockup.svg\" alt=\"Arogya Bharat healthcare e-commerce platform UI/UX mockup by Webx Design Studio\" class=\"original-mockup\" width=\"700\" height=\"500\" loading=\"eager\" />\n        </div>\n      </div>\n    </div>\n  </section>\n</header>\n\n<main>\n\n<!-- About Section -->\n<section class=\"about-section\" aria-label=\"About Arogya Bharat\">\n  <div class=\"about-content\">\n    <h2>About Arogya Bharat</h2>\n    <p class=\"about-description\">\n      Arogya Bharat is a leading provider of professional healthcare instruments, from Spirometer machines to pediatric mobility solutions. We transformed their digital storefront into a high-performance platform that reflects their commitment to excellence. By simplifying complex medical data and purchasing paths, we created a reliable bridge between advanced technology and the healthcare professionals who need it.\n    </p>\n    <div class=\"info-grid\">\n      <div class=\"info-item\">\n        <h3>Industries</h3>\n        <p>Medical Industries</p>\n      </div>\n      <div class=\"info-item\">\n        <h3>Year</h3>\n        <p>2024</p>\n      </div>\n      <div class=\"info-item full-width\">\n        <h3>Services</h3>\n        <p>Branding | UI UX Design | Social Media</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- Challenge and Solution Section -->\n<section class=\"challenge-solution-section\" aria-label=\"Challenge and solution\">\n  <div class=\"cs-container\">\n    <div class=\"cs-column\">\n      <img src=\"/assets/images/icons/ab-challenge-icon.svg\" alt=\"\" class=\"cs-icon\" aria-hidden=\"true\" width=\"48\" height=\"48\" loading=\"lazy\" />\n      <h2>The Challenge</h2>\n      <ul class=\"cs-list\">\n        <li>\n          <div class=\"cs-list-content\">\n            <span><strong>Navigation Friction:</strong> Users struggled to find specific medical equipment due to poor categorization</span>\n          </div>\n        </li>\n        <li>\n          <div class=\"cs-list-content\">\n            <span><strong>Information Gap:</strong> Insufficient product data and low-quality imagery led to buyer hesitation</span>\n          </div>\n        </li>\n        <li>\n          <div class=\"cs-list-content\">\n            <span><strong>Checkout Complexity:</strong> A multi-step, unclear checkout process caused high cart abandonment</span>\n          </div>\n        </li>\n        <li>\n          <div class=\"cs-list-content\">\n            <span><strong>Trust Deficit:</strong> A lack of visible certifications and reviews affected professional confidence</span>\n          </div>\n        </li>\n      </ul>\n    </div>\n    <div class=\"cs-column\">\n      <img src=\"/assets/images/icons/ab-solution-icon.svg\" alt=\"\" class=\"cs-icon\" aria-hidden=\"true\" width=\"48\" height=\"48\" loading=\"lazy\" />\n      <h2>The Solution</h2>\n      <ul class=\"cs-list\">\n        <li>\n          <div class=\"cs-list-content\">\n            <span><strong>Advanced Search:</strong> Implemented a well-structured menu and filters for effortless product discovery</span>\n          </div>\n        </li>\n        <li>\n          <div class=\"cs-list-content\">\n            <span><strong>Data-Rich Pages:</strong> Added detailed specifications and high-quality visuals for informed decision-making</span>\n          </div>\n        </li>\n        <li>\n          <div class=\"cs-list-content\">\n            <span><strong>Seamless Checkout:</strong> Simplified the payment journey with clear shipping policies and guest options</span>\n          </div>\n        </li>\n        <li>\n          <div class=\"cs-list-content\">\n            <span><strong>Credential Focus:</strong> Integrated testimonials and certifications to establish industry authority</span>\n          </div>\n        </li>\n      </ul>\n    </div>\n  </div>\n</section>\n\n<!-- UX/UI Comparison Section -->\n<section class=\"comparison-section\" aria-label=\"UX versus UI before and after comparison\">\n  <div class=\"comparison-header\" aria-hidden=\"true\">\n    <div class=\"comparison-label\">UX</div>\n    <div class=\"comparison-label\">UI</div>\n  </div>\n  <div class=\"comparison-wrapper\">\n    <div class=\"before-after-container\" style=\"background: #5349D5;\">\n      <div class=\"before-after-slider\" role=\"group\" aria-label=\"Before and after design comparison slider\">\n        <figure class=\"before-image\">\n          <img src=\"/assets/images/ui-elements/ui-after.png\" alt=\"Arogya Bharat UI design - after redesign\" width=\"800\" height=\"600\" loading=\"lazy\" />\n        </figure>\n        <figure class=\"after-image\">\n          <img src=\"/assets/images/ui-elements/ux-before.png\" alt=\"Arogya Bharat UX wireframe - before redesign\" width=\"800\" height=\"600\" loading=\"lazy\" />\n        </figure>\n        <div class=\"slider-handle\" aria-hidden=\"true\">\n          <div class=\"handle-circle\">\n            <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\">\n              <path d=\"M15 19L8 12L15 5\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            </svg>\n            <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\">\n              <path d=\"M9 5L16 12L9 19\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            </svg>\n          </div>\n          <div class=\"handle-line\"></div>\n        </div>\n        <input type=\"range\" min=\"0\" max=\"100\" value=\"50\" class=\"slider-input\" id=\"comparison-slider\" aria-label=\"Drag to compare UX and UI designs\" />\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- Visual Identity Section -->\n<section class=\"visual-identity-section\" aria-label=\"Visual identity design\">\n  <div class=\"vi-container\">\n    <div class=\"section-header animate-fade-in\">\n      <p class=\"section-label\">Visual Identity</p>\n      <h2 class=\"section-title\">Design framework bringing professional trust to medical commerce</h2>\n    </div>\n    <div class=\"vi-scroll-wrapper\">\n      <div class=\"vi-grid\" id=\"viGrid\">\n        <div class=\"vi-card\">\n          <div class=\"vi-card-image\">\n            <img src=\"/assets/images/ui-elements/vi-img-1.jpg\" alt=\"Arogya Bharat brand colour palette - deep blues and vibrant oranges for trust and vitality\" width=\"400\" height=\"300\" loading=\"lazy\" />\n          </div>\n          <h3 class=\"vi-card-title\">Colour Style</h3>\n          <p class=\"vi-card-description\">Deep blues convey reliability and professionalism, while vibrant oranges represent vitality and healthcare progress. Softer tones create a sense of balance and patient comfort.</p>\n        </div>\n        <div class=\"vi-card\">\n          <div class=\"vi-card-image\">\n            <img src=\"/assets/images/ui-elements/vi-img-2.jpg\" alt=\"Arogya Bharat iconography - clean medical-grade icons for equipment categories\" width=\"400\" height=\"300\" loading=\"lazy\" />\n          </div>\n          <h3 class=\"vi-card-title\">Iconography</h3>\n          <p class=\"vi-card-description\">We developed a custom set of clean, medical-grade icons. Every symbol is designed to provide instant recognition of complex equipment categories.</p>\n        </div>\n        <div class=\"vi-card\">\n          <div class=\"vi-card-image\">\n            <img src=\"/assets/images/ui-elements/vi-img-1.jpg\" alt=\"Arogya Bharat typography system - professional typefaces for clinical clarity\" width=\"400\" height=\"300\" loading=\"lazy\" />\n          </div>\n          <h3 class=\"vi-card-title\">Typography</h3>\n          <p class=\"vi-card-description\">The typography system was selected to communicate clinical precision and professional trust. Clean, structured typefaces guide healthcare professionals through product data with clarity and confidence.</p>\n        </div>\n        <div class=\"vi-card\">\n          <div class=\"vi-card-image\">\n            <img src=\"/assets/images/ui-elements/vi-img-2.jpg\" alt=\"Arogya Bharat design system - component library ensuring consistency across the platform\" width=\"400\" height=\"300\" loading=\"lazy\" />\n          </div>\n          <h3 class=\"vi-card-title\">Design System</h3>\n          <p class=\"vi-card-description\">A scalable design system was built to unify every touchpoint of the platform. Reusable components, spacing rules, and interaction patterns ensure a consistent and efficient user experience.</p>\n        </div>\n      </div>\n    </div>\n    <div class=\"vi-slider-controls\">\n      <div class=\"vi-progress-bar\" role=\"progressbar\" aria-label=\"Visual identity slider progress\">\n        <div class=\"vi-progress-line\"></div>\n        <div class=\"vi-progress-fill\" id=\"viProgressFill\"></div>\n      </div>\n      <div class=\"vi-navigation\">\n        <button class=\"vi-arrow vi-arrow-left\" id=\"viArrowLeft\" aria-label=\"Previous visual identity slide\">&#8592;</button>\n        <button class=\"vi-arrow vi-arrow-right\" id=\"viArrowRight\" aria-label=\"Next visual identity slide\">&#8594;</button>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- Design System Section -->\n<section class=\"design-system-section\" aria-label=\"Design system\">\n  <div class=\"ds-container\">\n    <div class=\"section-header animate-fade-in\">\n      <p class=\"section-label\">Design System</p>\n      <h2 class=\"section-title\">A cohesive library of elements ensuring style, flow, and clinical usability</h2>\n    </div>\n    <div class=\"ds-image-wrapper\">\n      <img src=\"/assets/images/ui-elements/ds-1.jpg\" alt=\"Arogya Bharat complete design system - components, colour tokens, and spacing guidelines\" class=\"ds-image\" width=\"1200\" height=\"700\" loading=\"lazy\" />\n    </div>\n  </div>\n</section>\n\n<!-- Web UI Section -->\n<section class=\"web-ui-section\" aria-label=\"Web UI designs\">\n  <div class=\"web-ui-container\">\n    <div class=\"section-header animate-fade-in\">\n      <p class=\"section-label\">Web UI</p>\n      <h2 class=\"section-title\">A smart e-commerce interface helping professionals find the right medical gear effortlessly</h2>\n    </div>\n    <div class=\"web-ui-slider-wrapper\">\n      <div class=\"web-ui-slider-container\" id=\"webUiSliderContainer\">\n        <div class=\"web-ui-slider\" id=\"webUiSlider\">\n          <div class=\"web-ui-slide\"><img src=\"/assets/images/ui-elements/web-ui-1.jpg\" alt=\"Arogya Bharat web UI - homepage design\" class=\"web-ui-image\" width=\"900\" height=\"600\" loading=\"lazy\" /></div>\n          <!-- <div class=\"web-ui-slide\"><img src=\"/assets/images/ui-elements/web-ui-1.jpg\" alt=\"Arogya Bharat web UI - product category page\" class=\"web-ui-image\" width=\"900\" height=\"600\" loading=\"lazy\" /></div>\n          <div class=\"web-ui-slide\"><img src=\"/assets/images/ui-elements/web-ui-1.jpg\" alt=\"Arogya Bharat web UI - product detail page\" class=\"web-ui-image\" width=\"900\" height=\"600\" loading=\"lazy\" /></div>\n          <div class=\"web-ui-slide\"><img src=\"/assets/images/ui-elements/web-ui-1.jpg\" alt=\"Arogya Bharat web UI - checkout and order page\" class=\"web-ui-image\" width=\"900\" height=\"600\" loading=\"lazy\" /></div> -->\n        </div>\n        <button class=\"glass-arrow-btn web-ui-prev\" id=\"webUiPrev\" aria-label=\"Previous web UI slide\">\n          <svg width=\"36\" height=\"36\" viewBox=\"0 0 36 36\" fill=\"none\" aria-hidden=\"true\">\n            <polyline points=\"22,10 13,18 22,26\" stroke=\"#fff\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n          </svg>\n        </button>\n        <button class=\"glass-arrow-btn web-ui-next\" id=\"webUiNext\" aria-label=\"Next web UI slide\">\n          <svg width=\"36\" height=\"36\" viewBox=\"0 0 36 36\" fill=\"none\" aria-hidden=\"true\">\n            <polyline points=\"14,10 23,18 14,26\" stroke=\"#fff\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n          </svg>\n        </button>\n      </div>\n      <div class=\"web-ui-slider-controls\">\n        <div class=\"web-ui-progress-bar\" role=\"progressbar\" aria-label=\"Web UI slider progress\">\n          <div class=\"progress-line\"></div>\n          <div class=\"progress-fill\" id=\"webUiProgressFill\"></div>\n        </div>\n        <div class=\"vi-navigation\">\n          <button class=\"vi-arrow vi-arrow-left\" id=\"webUiBottomPrev\" aria-label=\"Previous web UI slide\">&#8592;</button>\n          <button class=\"vi-arrow vi-arrow-right\" id=\"webUiBottomNext\" aria-label=\"Next web UI slide\">&#8594;</button>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- Mobile UI Section -->\n<section class=\"web-ui-section\" aria-label=\"Mobile UI designs\">\n  <div class=\"web-ui-container\">\n    <div class=\"section-header animate-fade-in\">\n      <p class=\"section-label\">Mobile UI</p>\n      <h2 class=\"section-title\">A mobile-first approach putting life-saving tools right at your fingertips</h2>\n    </div>\n    <div class=\"web-ui-slider-wrapper\">\n      <div class=\"web-ui-slider-container\" id=\"mobileUiSliderContainer\">\n        <div class=\"web-ui-slider\" id=\"mobileUiSlider\">\n          <div class=\"web-ui-slide\"><img src=\"/assets/images/ui-elements/mobile-ui-1.png\" alt=\"Arogya Bharat mobile UI - home screen design\" class=\"web-ui-image\" width=\"400\" height=\"700\" loading=\"lazy\" /></div>\n          <!-- <div class=\"web-ui-slide\"><img src=\"/assets/images/ui-elements/mobile-ui-1.png\" alt=\"Arogya Bharat mobile UI - product browse screen\" class=\"web-ui-image\" width=\"400\" height=\"700\" loading=\"lazy\" /></div>\n          <div class=\"web-ui-slide\"><img src=\"/assets/images/ui-elements/mobile-ui-1.png\" alt=\"Arogya Bharat mobile UI - product detail screen\" class=\"web-ui-image\" width=\"400\" height=\"700\" loading=\"lazy\" /></div>\n          <div class=\"web-ui-slide\"><img src=\"/assets/images/ui-elements/mobile-ui-1.png\" alt=\"Arogya Bharat mobile UI - cart and checkout screen\" class=\"web-ui-image\" width=\"400\" height=\"700\" loading=\"lazy\" /></div> -->\n        </div>\n        <button class=\"glass-arrow-btn web-ui-prev\" id=\"mobileUiPrev\" aria-label=\"Previous mobile UI slide\">\n          <svg width=\"36\" height=\"36\" viewBox=\"0 0 36 36\" fill=\"none\" aria-hidden=\"true\">\n            <polyline points=\"22,10 13,18 22,26\" stroke=\"#fff\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n          </svg>\n        </button>\n        <button class=\"glass-arrow-btn web-ui-next\" id=\"mobileUiNext\" aria-label=\"Next mobile UI slide\">\n          <svg width=\"36\" height=\"36\" viewBox=\"0 0 36 36\" fill=\"none\" aria-hidden=\"true\">\n            <polyline points=\"14,10 23,18 14,26\" stroke=\"#fff\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n          </svg>\n        </button>\n      </div>\n      <div class=\"web-ui-slider-controls\">\n        <div class=\"web-ui-progress-bar\" role=\"progressbar\" aria-label=\"Mobile UI slider progress\">\n          <div class=\"progress-line\"></div>\n          <div class=\"progress-fill\" id=\"mobileUiProgressFill\"></div>\n        </div>\n        <div class=\"vi-navigation\">\n          <button class=\"vi-arrow vi-arrow-left\" id=\"mobileUiBottomPrev\" aria-label=\"Previous mobile UI slide\">&#8592;</button>\n          <button class=\"vi-arrow vi-arrow-right\" id=\"mobileUiBottomNext\" aria-label=\"Next mobile UI slide\">&#8594;</button>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- Impact and Achievements Section -->\n<section class=\"impact-section animate-section\" aria-label=\"Impact and client testimonial\">\n  <div class=\"impact-container\">\n    <div class=\"section-header animate-fade-in\">\n      <div class=\"section-label\">Impact &amp; Achievements</div>\n      <h2 class=\"section-title\">From vision to impact - a team that delivers consistently</h2>\n    </div>\n    <div class=\"impact-slider-wrapper animate-slider\">\n      <div class=\"impact-slider\" id=\"impactSlider\">\n        <div class=\"impact-slide active\">\n          <div class=\"impact-quote-block\">\n            <img src=\"/assets/images/icons/quote-icon.svg\" alt=\"\" class=\"quote-icon\" aria-hidden=\"true\" width=\"32\" height=\"32\" loading=\"lazy\" />\n            <p class=\"quote-text\">\"Webx stands out for its ability to combine healthcare expertise with design innovation. Their collaborative mindset and professional approach resulted in solutions that exceeded our expectations.\"</p>\n          </div>\n          <div class=\"impact-footer\">\n            <div class=\"author-card\">\n              <img src=\"/assets/images/blogs/auther-imag-ab.png\" alt=\"Irfan N. Shaikh, Founder of Arogya Bharat\" class=\"author-photo\" width=\"56\" height=\"56\" loading=\"lazy\" />\n              <div class=\"author-info\">\n                <div class=\"author-name\">Irfan N. Shaikh</div>\n                <div class=\"author-title\">Founder, Arogya Bharat</div>\n              </div>\n            </div>\n            <div class=\"brand-logo\">\n              <img src=\"/assets/images/logos/ab-logo-1.png\" alt=\"Arogya Bharat Logo\" width=\"100\" height=\"50\" loading=\"lazy\" />\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- Next Work Section -->\n<section class=\"next-work-section\" aria-label=\"Explore more case studies\">\n  <div class=\"next-work-container\">\n    <h2 class=\"next-work-heading\">EXPLORE MORE WORK</h2>\n    <div class=\"next-work-scroll-wrapper\">\n      <div class=\"next-work-grid\" id=\"nextWorkGrid\">\n\n        <a href=\"/pages/details/morphico-pdp.html\" class=\"next-work-card\" style=\"background-image: url('/assets/images/clients/morphico-hero-banner.png');\">\n          <div class=\"card-content\">\n            <h3 class=\"card-title\">Morphico: Transforming Walls into Art</h3>\n            <p class=\"card-description\">Redefining interiors with a bold digital gallery that brings creativity to life. The platform enables seamless exploration and customization of premium wallpapers for homes and businesses.</p>\n            <div class=\"card-tags\">\n              <span class=\"card-tag\">User Interface Design</span>\n              <span class=\"card-tag\">User Experience Design</span>\n            </div>\n          </div>\n          <div class=\"card-mockup\">\n            <img src=\"/assets/images/clients/morphico-mockup.svg\" alt=\"Morphico - wallpaper and interior design UI/UX case study\" class=\"mockup-image\" width=\"200\" height=\"120\" loading=\"lazy\" />\n          </div>\n        </a>\n\n        <a href=\"/pages/details/tictax-pdp.html\" class=\"next-work-card\" style=\"background-image: url('/assets/images/banners/tictax-hero-banner.png');\">\n          <div class=\"card-content\">\n            <h3 class=\"card-title\">Tictax: Simplifying Complex Finance</h3>\n            <p class=\"card-description\">A clean fintech interface designed to turn complex tax processes into smooth digital experiences. This strategic approach successfully boosted user conversion rates by over 200%.</p>\n            <div class=\"card-tags\">\n              <span class=\"card-tag\">User Interface Design</span>\n              <span class=\"card-tag\">User Experience Design</span>\n            </div>\n          </div>\n          <div class=\"card-mockup\">\n            <img src=\"/assets/images/clients/tictax-mockup.svg\" alt=\"TicTax - fintech tax simplification UI/UX case study\" class=\"mockup-image\" width=\"200\" height=\"120\" loading=\"lazy\" />\n          </div>\n        </a>\n\n        <a href=\"/pages/details/mecon-pdp.html\" class=\"next-work-card\" style=\"background-image: url('/assets/images/clients/mecon-hero-banner-bg.png');\">\n          <div class=\"card-content\">\n            <h3 class=\"card-title\">Mecon: Shaping Industrial Authority</h3>\n            <p class=\"card-description\">Transforming the strength of brass manufacturing into a sophisticated global brand identity. This visual narrative highlights engineering excellence and precision for the international export market.</p>\n            <div class=\"card-tags\">\n              <span class=\"card-tag\">User Interface Design</span>\n              <span class=\"card-tag\">User Experience Design</span>\n            </div>\n          </div>\n          <div class=\"card-mockup\">\n            <img src=\"/assets/images/clients/mecon-mockup.svg\" alt=\"Mecon - industrial brass manufacturing brand identity case study\" class=\"mockup-image mecon-logo\" width=\"200\" height=\"120\" loading=\"lazy\" />\n          </div>\n        </a>\n\n        <a href=\"/pages/details/gurukrupa-pdp.html\" class=\"next-work-card\" style=\"background-image: url('/assets/images/clients/gurukrupa-hero-banner-bg.png');\">\n          <div class=\"card-content\">\n            <h3 class=\"card-title\">Gurukrupa: Forging Engineering Excellence</h3>\n            <p class=\"card-description\">A visual identity rooted in geometric accuracy and industrial strength for high-precision manufacturing. The design system unifies a diverse parts catalog under one professional, global brand.</p>\n            <div class=\"card-tags\">\n              <span class=\"card-tag\">User Interface Design</span>\n              <span class=\"card-tag\">User Experience Design</span>\n            </div>\n          </div>\n          <div class=\"card-mockup\">\n            <img src=\"/assets/images/clients/gurukrupa-mockup.svg\" alt=\"Gurukrupa - engineering manufacturing brand visual identity case study\" class=\"mockup-image mecon-logo\" width=\"200\" height=\"120\" loading=\"lazy\" />\n          </div>\n        </a>\n\n        <a href=\"/pages/details/manglam-pdp.html\" class=\"next-work-card\" style=\"background-image: url('/assets/images/clients/manglam-hero-banner-bg.png');\">\n          <div class=\"card-content\">\n            <h3 class=\"card-title\">Manglam: Converting Through Clarity</h3>\n            <p class=\"card-description\">Reimagining financial consultancy with a modern identity that symbolizes stability and growth. Reorganized messaging makes complex taxation and loan services accessible and trustworthy for every client.</p>\n            <div class=\"card-tags\">\n              <span class=\"card-tag\">User Interface Design</span>\n              <span class=\"card-tag\">User Experience Design</span>\n            </div>\n          </div>\n          <div class=\"card-mockup\">\n            <img src=\"/assets/images/clients/manglam-mockup.svg\" alt=\"Manglam - financial consultancy brand identity case study\" class=\"mockup-image mecon-logo\" width=\"200\" height=\"120\" loading=\"lazy\" />\n          </div>\n        </a>\n\n        <a href=\"/pages/details/de-pdp.html\" class=\"next-work-card\" style=\"background-image: url('/assets/images/banners/de-hero-banner-bg.png');\">\n          <div class=\"card-content\">\n            <h3 class=\"card-title\">Dharmesh Enterprises: Empowering Business Growth</h3>\n            <p class=\"card-description\">A unified management application designed to streamline fragmented workflows and operational chaos. The result is a simple, powerful tool that provides entrepreneurs with total clarity and control.</p>\n            <div class=\"card-tags\">\n              <span class=\"card-tag\">User Interface Design</span>\n              <span class=\"card-tag\">User Experience Design</span>\n            </div>\n          </div>\n          <div class=\"card-mockup\">\n            <img src=\"/assets/images/clients/de-mockup.png\" alt=\"Dharmesh Enterprises - business management app UI/UX case study\" class=\"mockup-image mecon-logo\" width=\"200\" height=\"120\" loading=\"lazy\" />\n          </div>\n        </a>\n\n      </div>\n    </div>\n    <div class=\"web-ui-slider-controls\">\n      <div class=\"web-ui-progress-bar\" role=\"progressbar\" aria-label=\"More work slider progress\">\n        <div class=\"progress-line\"></div>\n        <div class=\"progress-fill\" id=\"nwProgress\"></div>\n      </div>\n      <div class=\"vi-navigation\">\n        <button class=\"vi-arrow vi-arrow-left\" id=\"nwPrev\" aria-label=\"Previous work\">&#8592;</button>\n        <button class=\"vi-arrow vi-arrow-right\" id=\"nwNext\" aria-label=\"Next work\">&#8594;</button>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- CTA Banner Section -->\n<section class=\"cta-banner-section\" aria-label=\"Start your project\">\n  <div class=\"cta-banner-content\">\n    <h2 class=\"cta-banner-title\">Ready to build something meaningful?</h2>\n    <a href=\"/pages/main/contact-page.html\" class=\"cta-banner-button\">\n      <span>START YOUR PROJECT</span>\n      <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\">\n        <path d=\"M7 17L17 7M17 7H7M17 7V17\" />\n      </svg>\n    </a>\n  </div>\n</section>\n\n</main>\n\n<!-- Footer Section -->\n<footer class=\"footer-section\" aria-label=\"Site footer\">\n  <div class=\"footer-container\">\n    <div class=\"footer-top\">\n      <div class=\"footer-logo\">\n        <img src=\"/assets/images/logos/webx-logo.svg\" alt=\"Webx Design Studio\" class=\"footer-logo-img\" width=\"140\" height=\"40\" loading=\"lazy\" />\n      </div>\n      <div class=\"footer-social\">\n        <a href=\"https://www.linkedin.com/in/piyushgohil8889/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"social-icon\" aria-label=\"Webx Design Studio on LinkedIn\">\n          <img src=\"/assets/images/icons/linkedin-icon.png\" alt=\"LinkedIn\" class=\"social-icon-img\" width=\"24\" height=\"24\" loading=\"lazy\" />\n        </a>\n        <a href=\"https://dribbble.com/desinger8889\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"social-icon\" aria-label=\"Webx Design Studio on Dribbble\">\n          <img src=\"/assets/images/icons/dribbble-icon.png\" alt=\"Dribbble\" class=\"social-icon-img\" width=\"24\" height=\"24\" loading=\"lazy\" />\n        </a>\n        <a href=\"https://www.behance.net/Piyushgohil8889\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"social-icon\" aria-label=\"Webx Design Studio on Behance\">\n          <img src=\"/assets/images/icons/behance-icon.png\" alt=\"Behance\" class=\"social-icon-img\" width=\"24\" height=\"24\" loading=\"lazy\" />\n        </a>\n      </div>\n    </div>\n    <div class=\"footer-section-block\">\n      <h3 class=\"footer-heading\">\n        Services\n        <button class=\"footer-toggle\" aria-label=\"Toggle Services menu\" aria-expanded=\"false\">\n          <span class=\"accordion-arrow-circle\">\n            <svg class=\"arrow-svg\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http:/www.w3.org/2000/svg\" aria-hidden=\"true\">\n              <path d=\"M5 12H19M19 12L12 5M19 12L12 19\" stroke=\"black\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n            </svg>\n          </span>\n        </button>\n      </h3>\n      <div class=\"footer-links\">\n        <a href=\"/pages/main/services.html\">UI/UX Design</a>\n        <a href=\"/pages/main/services.html\">Web Design</a>\n        <a href=\"/pages/main/services.html\">App Design</a>\n        <a href=\"/pages/main/services.html\">Marketing Emailer</a>\n        <a href=\"/pages/main/services.html\">Social Media</a>\n        <a href=\"/pages/main/services.html\">Logo Design</a>\n        <a href=\"/pages/main/services.html\">Graphics Design</a>\n        <a href=\"/pages/main/services.html\">Tool Design</a>\n        <a href=\"/pages/main/services.html\">Document Design</a>\n        <a href=\"/pages/main/services.html\">ETC Design</a>\n      </div>\n    </div>\n    <div class=\"footer-section-block\">\n      <h3 class=\"footer-heading\">\n        Company\n        <button class=\"footer-toggle\" aria-label=\"Toggle Company menu\" aria-expanded=\"false\">\n          <span class=\"accordion-arrow-circle\">\n            <svg class=\"arrow-svg\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http:/www.w3.org/2000/svg\" aria-hidden=\"true\">\n              <path d=\"M5 12H19M19 12L12 5M19 12L12 19\" stroke=\"black\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n            </svg>\n          </span>\n        </button>\n      </h3>\n      <div class=\"footer-links\">\n        <a href=\"/pages/main/about.html\">About Us</a>\n        <a href=\"/pages/blogs/blogs.html\">Blog</a>\n        <a href=\"/pages/main/contact-page.html\">Contact</a>\n        <a href=\"/pages/legal/privacy-policy.html\">Privacy Policy</a>\n        <a href=\"/pages/legal/term-condition.html\">Terms of Service</a>\n      </div>\n    </div>\n    <div class=\"footer-bottom\">\n      <p class=\"footer-copyright\">&copy; 2026 Webx Design Studio. All rights reserved</p>\n    </div>\n  </div>\n  <div class=\"footer-bg-text\" aria-hidden=\"true\">\n    <img src=\"/assets/images/logos/webx-footer-logo-large.svg\" alt=\"\" class=\"footer-bg-image\" loading=\"lazy\" />\n  </div>\n</footer>\n\n<!-- More Menu -->\n<div class=\"more-menu-overlay\" id=\"moreMenu\" role=\"dialog\" aria-modal=\"true\" aria-label=\"Full navigation menu\">\n  <div class=\"more-menu-inner\">\n    <div class=\"more-menu-left\">\n      <div class=\"more-menu-column\">\n        <a href=\"/\" class=\"more-link\"><span class=\"more-link-label\">Home</span></a>\n        <a href=\"/pages/main/work.html\" class=\"more-link\"><span class=\"more-link-label\">Work</span></a>\n        <a href=\"/pages/main/services.html\" class=\"more-link\"><span class=\"more-link-label\">Services</span></a>\n        <a href=\"/pages/main/faq.html\" class=\"more-link\"><span class=\"more-link-label\">FAQ</span></a>\n      </div>\n      <div class=\"more-menu-column\">\n        <a href=\"/pages/main/about.html\" class=\"more-link\"><span class=\"more-link-label\">About</span></a>\n        <a href=\"/pages/blogs/blogs.html\" class=\"more-link\"><span class=\"more-link-label\">Blog</span></a>\n        <a href=\"/pages/main/contact-page.html\" class=\"more-link\"><span class=\"more-link-label\">Contact</span></a>\n        <a href=\"/pages/legal/term-condition.html\" class=\"more-link\"><span class=\"more-link-label\">Term &amp; Conditions</span></a>\n        <a href=\"/pages/legal/privacy-policy.html\" class=\"more-link\"><span class=\"more-link-label\">Privacy Policy</span></a>\n      </div>\n    </div>\n    <aside class=\"more-menu-right\">\n      <div class=\"more-cta-content\">\n        <h2 class=\"more-cta-title\">\n          Let's create<br>\n          experiences<br>\n          together.\n        </h2>\n        <p class=\"more-cta-sub\">We value our connection and want to create lasting memories.</p>\n        <a href=\"/pages/main/contact-page.html\" class=\"more-cta-button\">\n          <span>CONTACT US</span>\n          <svg width=\"18\" height=\"18\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http:/www.w3.org/2000/svg\" aria-hidden=\"true\">\n            <path d=\"M3 13L13 3M13 3H5M13 3V11\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n          </svg>\n        </a>\n      </div>\n    </aside>\n  </div>\n</div>\n\n<!-- Scroll to Top Button -->\n<button class=\"scroll-to-top\" id=\"scrollToTop\" aria-label=\"Scroll to top of page\">\n  <svg width=\"20\" height=\"20\" viewBox=\"0 0 20 20\" fill=\"none\" xmlns=\"http:/www.w3.org/2000/svg\" aria-hidden=\"true\">\n    <path d=\"M10 15V5M10 5L5 10M10 5L15 10\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n  </svg>\n</button>\n\n<!-- Bottom Navigation Bar -->\n<nav class=\"bottom-navbar\" aria-label=\"Bottom navigation\">\n  <div class=\"bottom-nav-logo\">\n    <a href=\"/\" class=\"logo-link\" aria-label=\"Webx Design Studio - Go to homepage\">\n      <img src=\"/assets/images/logos/webx-logo.svg\" alt=\"Webx Design Studio\" class=\"logo-full\" width=\"100\" height=\"30\" loading=\"lazy\" />\n      <img src=\"/assets/images/icons/webx-icon.svg\" alt=\"Webx\" class=\"logo-icon\" width=\"32\" height=\"32\" loading=\"lazy\" />\n    </a>\n  </div>\n  <div class=\"bottom-nav-container\">\n    <a href=\"/\" class=\"nav-item\">\n      <img src=\"/assets/images/others/home.png\" alt=\"\" class=\"nav-icon\" aria-hidden=\"true\" width=\"24\" height=\"24\" loading=\"lazy\" />\n      <span class=\"nav-label\">Home</span>\n    </a>\n    <a href=\"/pages/main/work.html\" class=\"nav-item active\" aria-current=\"page\">\n      <img src=\"/assets/images/others/work.png\" alt=\"\" class=\"nav-icon\" aria-hidden=\"true\" width=\"24\" height=\"24\" loading=\"lazy\" />\n      <span class=\"nav-label\">Work</span>\n    </a>\n    <a href=\"/pages/main/services.html\" class=\"nav-item\">\n      <img src=\"/assets/images/others/services.png\" alt=\"\" class=\"nav-icon\" aria-hidden=\"true\" width=\"24\" height=\"24\" loading=\"lazy\" />\n      <span class=\"nav-label\">Services</span>\n    </a>\n    <a href=\"/pages/main/about.html\" class=\"nav-item\">\n      <img src=\"/assets/images/others/about.png\" alt=\"\" class=\"nav-icon\" aria-hidden=\"true\" width=\"24\" height=\"24\" loading=\"lazy\" />\n      <span class=\"nav-label\">About</span>\n    </a>\n    <a href=\"/pages/main/contact-page.html\" class=\"nav-item\">\n      <img src=\"/assets/images/others/contact.png\" alt=\"\" class=\"nav-icon\" aria-hidden=\"true\" width=\"24\" height=\"24\" loading=\"lazy\" />\n      <span class=\"nav-label\">Contact</span>\n    </a>\n    <button class=\"nav-item more-toggle\" type=\"button\" aria-label=\"Open full navigation menu\" aria-expanded=\"false\" aria-controls=\"moreMenu\">\n      <svg class=\"more-icon\" viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n        <line x1=\"5\" y1=\"8\" x2=\"19\" y2=\"8\" />\n        <line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\" />\n        <line x1=\"5\" y1=\"16\" x2=\"19\" y2=\"16\" />\n      </svg>\n      <span class=\"nav-label\">More</span>\n    </button>\n  </div>\n</nav>\n\n<script src=\"/js/script.js?v=20260311-2\"></script>\n<script>\n  if ('serviceWorker' in navigator) {\n    window.addEventListener('load', function() {\n      navigator.serviceWorker.register('/sw.js').catch(function(err) {\n        console.warn('Service worker registration failed:', err);\n      });\n    });\n  }\n</script>\n\n</body>\n</html>",
