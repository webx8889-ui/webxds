      "sections": [
        {
          "id": "faq-section-7927acab",
          "label": "FAQ page header",
          "enabled": true,
          "html": "<header>\n  <section class=\"service-hero-section\" aria-label=\"FAQ page header\">\n    <nav class=\"home-navbar\" aria-label=\"Main navigation\">\n      <div class=\"home-nav-container\">\n        <div class=\"home-logo\">\n          <a href=\"/\" class=\"logo-link\" aria-label=\"Webx Design Studio - Go to homepage\">\n            <img src=\"/assets/images/logos/webx-logo.svg\" alt=\"Webx Design Studio\" width=\"140\" height=\"40\" loading=\"eager\" />\n          </a>\n        </div>\n        <a href=\"/pages/main/contact-page.html\" class=\"home-contact-btn\">\n          <span>CONTACT US</span>\n          <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" aria-hidden=\"true\">\n            <path d=\"M3 13L13 3M13 3H5M13 3V11\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          </svg>\n        </a>\n      </div>\n    </nav>\n  </section>\n</header>"
        },
        {
          "id": "faq-section-440c5ba3",
          "label": "Frequently asked questions",
          "enabled": true,
          "html": "<section class=\"faq-section animate-section\" aria-label=\"Frequently asked questions\">\n      <div class=\"faq-container\">\n        <div class=\"section-header animate-fade-in\">\n          <p class=\"section-label\">Frequently Asked Questions</p>\n          <h2 class=\"section-title\">Find answers to common questions about our services</h2>\n        </div>\n\n        <div class=\"faq-accordion animate-stagger\">\n\n          <div class=\"faq-item active\">\n            <button class=\"faq-question\" aria-expanded=\"true\" aria-controls=\"faq-answer-1\">\n              <span>What does a UI/UX design agency actually do?</span>\n              <span class=\"faq-icon\" aria-hidden=\"true\">+</span>\n            </button>\n            <div class=\"faq-answer\" id=\"faq-answer-1\" role=\"region\">\n              <p>A UI/UX design agency like Webx helps businesses build digital products that are easy to use. We handle everything from <span style=\"color: #fff\">user research</span> and <span style=\"color: #fff\">wireframes</span> to the final <span style=\"color: #fff\">visual design</span> of websites and apps.</p>\n            </div>\n          </div>\n\n          <div class=\"faq-item\">\n            <button class=\"faq-question\" aria-expanded=\"false\" aria-controls=\"faq-answer-2\">\n              <span>How does better UI/UX design help my business?</span>\n              <span class=\"faq-icon\" aria-hidden=\"true\">+</span>\n            </button>\n            <div class=\"faq-answer\" id=\"faq-answer-2\" role=\"region\">\n              <p>Great design is about more than looks. It improves how users <span style=\"color: #fff\">feel and connect</span> with your brand. By making your platform intuitive and meaningful, we help increase user engagement and can boost <span style=\"color: #fff\">conversion rates</span> by over 200%.</p>\n            </div>\n          </div>\n\n          <div class=\"faq-item\">\n            <button class=\"faq-question\" aria-expanded=\"false\" aria-controls=\"faq-answer-3\">\n              <span>Do you work with early-stage startups?</span>\n              <span class=\"faq-icon\" aria-hidden=\"true\">+</span>\n            </button>\n            <div class=\"faq-answer\" id=\"faq-answer-3\" role=\"region\">\n              <p>Yes. We specialize in helping startups turn early ideas into <span style=\"color: #fff\">refined design systems</span>. We build with clarity and intention to help new brands create a strong presence and scale quickly.</p>\n            </div>\n          </div>\n\n          <div class=\"faq-item\">\n            <button class=\"faq-question\" aria-expanded=\"false\" aria-controls=\"faq-answer-4\">\n              <span>What industries do you specialize in?</span>\n              <span class=\"faq-icon\" aria-hidden=\"true\">+</span>\n            </button>\n            <div class=\"faq-answer\" id=\"faq-answer-4\" role=\"region\">\n              <p>We have served over <span style=\"color: #fff\">10 industries globally</span>. Our portfolio includes work in <span style=\"color: #fff\">healthcare, fintech, e-commerce</span>, and <span style=\"color: #fff\">corporate platforms</span>.</p>\n            </div>\n          </div>\n\n          <div class=\"faq-item\">\n            <button class=\"faq-question\" aria-expanded=\"false\" aria-controls=\"faq-answer-5\">\n              <span>Can you help with custom tools like SaaS dashboards?</span>\n              <span class=\"faq-icon\" aria-hidden=\"true\">+</span>\n            </button>\n            <div class=\"faq-answer\" id=\"faq-answer-5\" role=\"region\">\n              <p>Absolutely. We design dashboards and internal digital systems shaped for <span style=\"color: #fff\">usability and scale</span>. Our goal is to take complex processes and turn them into smooth, professional experiences.</p>\n            </div>\n          </div>\n\n          <div class=\"faq-item\">\n            <button class=\"faq-question\" aria-expanded=\"false\" aria-controls=\"faq-answer-6\">\n              <span>What tools and methods do you use?</span>\n              <span class=\"faq-icon\" aria-hidden=\"true\">+</span>\n            </button>\n            <div class=\"faq-answer\" id=\"faq-answer-6\" role=\"region\">\n              <p>Our team uses a mix of <span style=\"color: #fff\">modern design thinking</span> and emerging technology like <span style=\"color: #fff\">AI</span> to push digital experiences forward. Every project is built on human insight to ensure the results are both intuitive and effective.</p>\n            </div>\n          </div>\n\n          <div class=\"faq-item \"> <button class=\"faq-question\" aria-expanded=\"false\"\n                            aria-controls=\"faq-answer\"> <span>How much does a professional UI/UX design project\n                                cost?</span> <span class=\"faq-icon\" aria-hidden=\"true\">+</span> </button>\n                        <div class=\"faq-answer\" id=\"faq-answer-7\" role=\"region\">\n                            <p>Costs depend on the project complexity and features. A high-performance website usually\n                                ranges from Rs. 25,000 to Rs. 50,000, while custom SaaS platforms or enterprise\n                                solutions can range from Rs. 1,00,000 to Rs. 5,00,000+. We provide a custom quote after\n                                understanding your specific goals.</p>\n                        </div>\n                    </div>\n                    <div class=\"faq-item\"> <button class=\"faq-question\" aria-expanded=\"false\"\n                            aria-controls=\"faq-answer\"> <span>How long does it take to design a website or app?</span>\n                            <span class=\"faq-icon\" aria-hidden=\"true\">+</span> </button>\n                        <div class=\"faq-answer\" id=\"faq-answer-8\" role=\"region\">\n                            <p>Timelines vary based on the scope of work. A standard responsive website takes roughly 3\n                                to 5 weeks, whereas complex mobile apps or internal digital systems may take 10 to 12\n                                weeks to ensure a polished, user-ready result.</p>\n                        </div>\n                    </div>\n                    <div class=\"faq-item\"> <button class=\"faq-question\" aria-expanded=\"false\"\n                            aria-controls=\"faq-answer\"> <span>Do you handle marketing mailers and document\n                                designs?</span> <span class=\"faq-icon\" aria-hidden=\"true\">+</span> </button>\n                        <div class=\"faq-answer\" id=\"faq-answer-9\" role=\"region\">\n                            <p>Yes. We provide a full range of creatives, including beautifully structured marketing\n                                emails and impactful reports or decks. This ensures your brand identity remains\n                                consistent across every digital and professional touchpoint.</p>\n                        </div>\n                    </div>\n                    <div class=\"faq-item\"> <button class=\"faq-question\" aria-expanded=\"false\"\n                            aria-controls=\"faq-answer\"> <span>Can your design studio help improve our conversion\n                                rates?</span> <span class=\"faq-icon\" aria-hidden=\"true\">+</span> </button>\n                        <div class=\"faq-answer\" id=\"faq-answer-10\" role=\"region\">\n                            <p>Absolutely. We focus on user research and interaction flows designed specifically to\n                                guide attention and inspire action. Our strategic approach has helped clients boost\n                                their conversion rates by over 200%.</p>\n                        </div>\n                    </div>\n\n                    <div class=\"faq-item \"> <button class=\"faq-question\" aria-expanded=\"false\"\n                            aria-controls=\"faq-answer\"> <span>How much does a website or app design cost?</span> <span\n                                class=\"faq-icon\" aria-hidden=\"true\">+</span> </button>\n                        <div class=\"faq-answer\" id=\"faq-answer-11\" role=\"region\">\n                            <p>Costs vary based on complexity and features. A professional website typically ranges from\n                                Rs. 25,000 to Rs. 50,000, while custom e-commerce or SaaS solutions range from Rs.\n                                1,00,000 to Rs. 5,00,000+. We provide detailed quotes after understanding your specific\n                                needs.</p>\n                        </div>\n                    </div>\n                    <div class=\"faq-item\"> <button class=\"faq-question\" aria-expanded=\"false\"\n                            aria-controls=\"faq-answer\"> <span>How do you use AI in your design process?</span> <span\n                                class=\"faq-icon\" aria-hidden=\"true\">+</span> </button>\n                        <div class=\"faq-answer\" id=\"faq-answer-12\" role=\"region\">\n                            <p>We use emerging AI tools to push digital experiences forward and improve efficiency. This\n                                allows us to focus more on human insight and strategic thinking to craft meaningful\n                                solutions.</p>\n                        </div>\n                    </div>\n                    <div class=\"faq-item\"> <button class=\"faq-question\" aria-expanded=\"false\"\n                            aria-controls=\"faq-answer\"> <span>Can you help with branding from scratch?</span> <span\n                                class=\"faq-icon\" aria-hidden=\"true\">+</span> </button>\n                        <div class=\"faq-answer\" id=\"faq-answer-13\" role=\"region\">\n                            <p>Yes. From early ideas to refined design systems, we build with clarity and intention. We\n                                create full identity systems, logos, and visuals that define your brand.</p>\n                        </div>\n                    </div>\n                    <div class=\"faq-item\"> <button class=\"faq-question\" aria-expanded=\"false\"\n                            aria-controls=\"faq-answer\"> <span>How do you ensure the design fits our audience?</span>\n                            <span class=\"faq-icon\" aria-hidden=\"true\">+</span> </button>\n                        <div class=\"faq-answer\" id=\"faq-answer-14\" role=\"region\">\n                            <p>Every project starts with understanding people first. We delve deep into your unique\n                                needs and target audience to craft intuitive solutions.</p>\n                        </div>\n                    </div>\n\n        </div>\n      </div>\n    </section>"
        },
        {
          "id": "faq-section-102784ab",
          "label": "Site footer",
          "enabled": true,
          "html": "<footer class=\"footer-section\" aria-label=\"Site footer\">\n  <div class=\"footer-container\">\n    <div class=\"footer-top\">\n      <div class=\"footer-logo\">\n        <img src=\"/assets/images/logos/webx-logo.svg\" alt=\"Webx Design Studio\" class=\"footer-logo-img\" width=\"140\" height=\"40\" loading=\"lazy\" />\n      </div>\n      <div class=\"footer-social\">\n        <a href=\"https://www.linkedin.com/in/piyushgohil8889/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"social-icon\" aria-label=\"Webx Design Studio on LinkedIn\">\n          <img src=\"/assets/images/icons/linkedin-icon.png\" alt=\"LinkedIn\" class=\"social-icon-img\" width=\"24\" height=\"24\" loading=\"lazy\" />\n        </a>\n        <a href=\"https://dribbble.com/desinger8889\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"social-icon\" aria-label=\"Webx Design Studio on Dribbble\">\n          <img src=\"/assets/images/icons/dribbble-icon.png\" alt=\"Dribbble\" class=\"social-icon-img\" width=\"24\" height=\"24\" loading=\"lazy\" />\n        </a>\n        <a href=\"https://www.behance.net/Piyushgohil8889\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"social-icon\" aria-label=\"Webx Design Studio on Behance\">\n          <img src=\"/assets/images/icons/behance-icon.png\" alt=\"Behance\" class=\"social-icon-img\" width=\"24\" height=\"24\" loading=\"lazy\" />\n        </a>\n      </div>\n    </div>\n    <div class=\"footer-section-block\">\n      <h3 class=\"footer-heading\">\n        Services\n        <button class=\"footer-toggle\" aria-label=\"Toggle Services menu\" aria-expanded=\"false\">\n          <span class=\"accordion-arrow-circle\">\n            <svg class=\"arrow-svg\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http:/www.w3.org/2000/svg\" aria-hidden=\"true\">\n              <path d=\"M5 12H19M19 12L12 5M19 12L12 19\" stroke=\"black\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n            </svg>\n          </span>\n        </button>\n      </h3>\n      <div class=\"footer-links\">\n        <a href=\"/pages/main/services.html\">UI/UX Design</a>\n        <a href=\"/pages/main/services.html\">Web Design</a>\n        <a href=\"/pages/main/services.html\">App Design</a>\n        <a href=\"/pages/main/services.html\">Marketing Emailer</a>\n        <a href=\"/pages/main/services.html\">Social Media</a>\n        <a href=\"/pages/main/services.html\">Logo Design</a>\n        <a href=\"/pages/main/services.html\">Graphics Design</a>\n        <a href=\"/pages/main/services.html\">Tool Design</a>\n        <a href=\"/pages/main/services.html\">Document Design</a>\n        <a href=\"/pages/main/services.html\">ETC Design</a>\n      </div>\n    </div>\n    <div class=\"footer-section-block\">\n      <h3 class=\"footer-heading\">\n        Company\n        <button class=\"footer-toggle\" aria-label=\"Toggle Company menu\" aria-expanded=\"false\">\n          <span class=\"accordion-arrow-circle\">\n            <svg class=\"arrow-svg\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http:/www.w3.org/2000/svg\" aria-hidden=\"true\">\n              <path d=\"M5 12H19M19 12L12 5M19 12L12 19\" stroke=\"black\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n            </svg>\n          </span>\n        </button>\n      </h3>\n      <div class=\"footer-links\">\n        <a href=\"/pages/main/about.html\">About Us</a>\n        <a href=\"/pages/blogs/blogs.html\">Blog</a>\n        <a href=\"/pages/main/contact-page.html\">Contact</a>\n        <a href=\"/pages/legal/privacy-policy.html\">Privacy Policy</a>\n        <a href=\"/pages/legal/term-condition.html\">Terms of Service</a>\n      </div>\n    </div>\n    <div class=\"footer-bottom\">\n      <p class=\"footer-copyright\">&copy; 2026 Webx Design Studio. All rights reserved</p>\n    </div>\n  </div>\n  <div class=\"footer-bg-text\" aria-hidden=\"true\">\n    <img src=\"/assets/images/logos/webx-footer-logo-large.svg\" alt=\"\" class=\"footer-bg-image\" width=\"600\" height=\"200\" loading=\"lazy\" />\n  </div>\n</footer>"
        },
