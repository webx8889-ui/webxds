      "sections": [
        {
          "id": "thank-you-page-section-1b3d9cc9",
          "label": "Service Hero Section",
          "enabled": true,
          "html": "<section class=\"service-hero-section\">\r\n    <!-- Navbar -->\r\n    <nav class=\"home-navbar\">\r\n      <div class=\"home-nav-container\">\r\n        <div class=\"home-logo\">\r\n          <a href=\"/\" class=\"logo-link\">\r\n            <img src=\"/assets/images/logos/webx-logo.svg\" alt=\"Webx Design Studio\">\r\n          </a>\r\n        </div>\r\n        <a href=\"/pages/main/contact-page.html\" class=\"home-contact-btn\">\r\n          <span>CONTACT US</span>\r\n          <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\r\n            <path d=\"M3 13L13 3M13 3H5M13 3V11\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"\r\n              stroke-linejoin=\"round\" />\r\n          </svg>\r\n        </a>\r\n      </div>\r\n    </nav>\r\n  </section>"
        },
        {
          "id": "thank-you-page-section-d5a766ee",
          "label": "Success Message Section",
          "enabled": true,
          "html": "<section class=\"success-message-section\">\r\n    <div class=\"success-outer-container\">\r\n      <!-- Empty Box on Top -->\r\n      <div class=\"success-image-box\">\r\n        <img src=\"/assets/images/banners/thank-you-banner.png\" alt=\"thank-you-banner\" class=\"services-image\">\r\n      </div>\r\n  </section>"
        },
        {
          "id": "thank-you-page-section-1243579a",
          "label": "Reimagining Section",
          "enabled": true,
          "html": "<section class=\"reimagining-section\">\r\n    <div class=\"reimagining-container\">\r\n      <!-- Stats Box -->\r\n      <div class=\"stats-box\">\r\n        <div class=\"stat-item\">\r\n          <div class=\"stat-number\" data-target=\"5\">0</div>\r\n          <div class=\"stat-label\">Years of Expertise</div>\r\n        </div>\r\n        <div class=\"stat-divider\"></div>\r\n        <div class=\"stat-item\">\r\n          <div class=\"stat-number\" data-target=\"11\">0</div>\r\n          <div class=\"stat-label\">Projects Delivered</div>\r\n        </div>\r\n        <div class=\"stat-divider\"></div>\r\n        <div class=\"stat-item\">\r\n          <div class=\"stat-number\" data-target=\"101\">0</div>\r\n          <div class=\"stat-label\">Creative Pros</div>\r\n        </div>\r\n        <div class=\"stat-divider\"></div>\r\n        <div class=\"stat-item\">\r\n          <div class=\"stat-number\" data-target=\"10\">0</div>\r\n          <div class=\"stat-label\">Industries Serviced</div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </section>"
        },
        {
          "id": "thank-you-page-section-0fee8eb0",
          "label": "Latest blog posts",
          "enabled": true,
          "html": "<section class=\"blog-section animate-section\" aria-label=\"Latest blog posts\">\r\n      <div class=\"blog-container\">\r\n        <div class=\"section-header animate-fade-in\">\r\n          <p class=\"section-label\">Today's Blogs</p>\r\n          <h2 class=\"section-title\">Check out our blog for the latest tips, tricks, and happenings in business and design.</h2>\r\n        </div>\r\n\r\n        <div class=\"blog-slider-wrapper\">\r\n          <div class=\"blog-slider animate-cards\">\r\n\r\n            <!-- Blog Card 1 -->\r\n            <div class=\"blog-card\">\r\n              <div class=\"blog-image\">\r\n               \r\n                <img src=\"/assets/images/blogs/blog-img-1.png\" alt=\"AI-Driven Personalization in UI/UX Design 2026 - blog post featured image\" width=\"400\" height=\"240\" loading=\"lazy\" />\r\n              </div>\r\n              <div class=\"blog-content\">\r\n                <h3 class=\"blog-card-title\">AI-Driven Personalization: The UX/UI Design Trend Your Business Cannot Ignore in 2026</h3>\r\n                <div class=\"blog-meta\">\r\n                  <div class=\"blog-tags\">\r\n                    <span class=\"blog-tag\">ai powered user interfaces</span>\r\n                    <span class=\"blog-tag\">does ux affect seo</span>\r\n                    <span class=\"blog-tag\">2026 ux ui design trends</span>\r\n                  </div>\r\n                  <span class=\"blog-date\"><time datetime=\"2025-04-16\">Date: 16 Apr 25</time></span>\r\n                </div>\r\n                <p class=\"blog-excerpt\">In 2026, UI/UX design has shifted from \"one layout fits all\" to interfaces that actually think with your users. Thanks to AI-driven personalization, websites and apps can now adapt content, layout, and even navigation in real time based on each user's behavior, context, and intent.</p>\r\n                <a href=\"/pages/blogs/blog.html\" class=\"blog-read-more\" aria-label=\"Read more about AI-Driven Personalization in UI/UX Design 2026\">\r\n                  <span>READ MORE</span>\r\n                  <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" aria-hidden=\"true\">\r\n                    <path d=\"M3 13L13 3M13 3H5M13 3V11\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                  </svg>\r\n                </a>\r\n              </div>\r\n            </div>\r\n\r\n            <!-- Blog Card 2 -->\r\n            <div class=\"blog-card\">\r\n              <div class=\"blog-image\">\r\n                <img src=\"/assets/images/blogs/blog-img-2.png\" alt=\"Apple Design Study - 10 UX Lessons for 2026 - blog post featured image\" width=\"400\" height=\"240\" loading=\"lazy\" />\r\n              </div>\r\n              <div class=\"blog-content\">\r\n                <h3 class=\"blog-card-title\">Apple Design Study: 10 UX Lessons You Can Apply to Your Products in 2026</h3>\r\n                <div class=\"blog-meta\">\r\n                  <div class=\"blog-tags\">\r\n                    <span class=\"blog-tag\">apple design study</span>\r\n                    <span class=\"blog-tag\">apple ux case study</span>\r\n                    <span class=\"blog-tag\">ios design principles</span>\r\n                  </div>\r\n                  <span class=\"blog-date\"><time datetime=\"2025-04-16\">Date: 16 Apr 25</time></span>\r\n                </div>\r\n                <p class=\"blog-excerpt\">Apple is not just a tech company - it is a masterclass in product design and user experience. From the first iPhone to the latest visionOS interfaces, Apple has consistently set the bar for how digital products should look, feel, and behave.</p>\r\n                <a href=\"/pages/blogs/blog-apple.html\" class=\"blog-read-more\" aria-label=\"Read more about Apple Design Study UX Lessons 2026\">\r\n                  <span>READ MORE</span>\r\n                  <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" aria-hidden=\"true\">\r\n                    <path d=\"M3 13L13 3M13 3H5M13 3V11\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                  </svg>\r\n                </a>\r\n              </div>\r\n            </div>\r\n\r\n            <!-- Blog Card 3 -->\r\n            <div class=\"blog-card\">\r\n              <div class=\"blog-image\">\r\n                <img src=\"/assets/images/blogs/blog-img-3.png\" alt=\"How to Design a High-Converting Landing Page in 2026 - blog post featured image\" width=\"400\" height=\"240\" loading=\"lazy\" />\r\n              </div>\r\n              <div class=\"blog-content\">\r\n                <h3 class=\"blog-card-title\">How to Design a High-Converting Landing Page in 2026: UX &amp; CRO Complete Guide</h3>\r\n                <div class=\"blog-meta\">\r\n                  <div class=\"blog-tags\">\r\n                    <span class=\"blog-tag\">high converting landing page</span>\r\n                    <span class=\"blog-tag\">landing page ux design</span>\r\n                    <span class=\"blog-tag\">conversion rate optimization</span>\r\n                  </div>\r\n                  <span class=\"blog-date\"><time datetime=\"2026-02-18\">Date: 18 Feb 26</time></span>\r\n                </div>\r\n                <p class=\"blog-excerpt\">Your landing page is often the final gateway between a visitor's interest and a real business action - whether that is a signup, a purchase, a demo booking, or a lead form submission.</p>\r\n                <a href=\"/pages/blogs/blog-3.html\" class=\"blog-read-more\" aria-label=\"Read more about designing a high-converting landing page in 2026\">\r\n                  <span>READ MORE</span>\r\n                  <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" aria-hidden=\"true\">\r\n                    <path d=\"M3 13L13 3M13 3H5M13 3V11\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                  </svg>\r\n                </a>\r\n              </div>\r\n            </div>\r\n\r\n            <!-- Blog Card 4 -->\r\n            <div class=\"blog-card\">\r\n              <div class=\"blog-image\">\r\n                <img src=\"/assets/images/blogs/blog-img-4.png\" alt=\"10 Signs It's Time to Redesign Your Website in 2026 - blog post featured image\" width=\"400\" height=\"240\" loading=\"lazy\" />\r\n              </div>\r\n              <div class=\"blog-content\">\r\n                <h3 class=\"blog-card-title\">10 Signs It's Time to Redesign Your Website in 2026: Full Redesign Checklist</h3>\r\n                <div class=\"blog-meta\">\r\n                  <div class=\"blog-tags\">\r\n                    <span class=\"blog-tag\">website redesign 2026</span>\r\n                    <span class=\"blog-tag\">when to redesign website</span>\r\n                    <span class=\"blog-tag\">website redesign checklist</span>\r\n                  </div>\r\n                  <span class=\"blog-date\"><time datetime=\"2026-02-18\">Date: 18 Feb 26</time></span>\r\n                </div>\r\n                <p class=\"blog-excerpt\">Most businesses redesign their website too late. By the time they finally decide to act, their website has already been quietly losing them traffic, leads, and revenue for months - sometimes years - without them realising it.</p>\r\n                <a href=\"/pages/blogs/blog-4.html\" class=\"blog-read-more\" aria-label=\"Read more about 10 signs it's time to redesign your website in 2026\">\r\n                  <span>READ MORE</span>\r\n                  <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" aria-hidden=\"true\">\r\n                    <path d=\"M3 13L13 3M13 3H5M13 3V11\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                  </svg>\r\n                </a>\r\n              </div>\r\n            </div>\r\n\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"blog-slider-controls\">\r\n          <div class=\"blog-progress-bar\" role=\"progressbar\" aria-label=\"Blog slider progress\">\r\n            <div class=\"blog-progress-bg\"></div>\r\n            <div class=\"blog-progress-fill\"></div>\r\n          </div>\r\n          <div class=\"blog-navigation\">\r\n            <button class=\"blog-arrow blog-prev\" aria-label=\"Previous blog post\">&larr;</button>\r\n            <button class=\"blog-arrow blog-next\" aria-label=\"Next blog post\">&rarr;</button>\r\n          </div>\r\n        </div>\r\n\r\n      </div>\r\n    </section>"
        },
        {
          "id": "thank-you-page-section-942d0fe1",
          "label": "LinkedIn",
          "enabled": true,
          "html": "<footer class=\"footer-section animate-section\">\r\n    <div class=\"footer-container\">\r\n\r\n        <!-- Footer Top Content -->\r\n        <div class=\"footer-top animate-fade-in\">\r\n\r\n            <!-- Logo -->\r\n            <div class=\"footer-logo\">\r\n                <img src=\"/assets/images/logos/webx-logo.svg\" alt=\"Webx Design Studio\" class=\"footer-logo-img\">\r\n            </div>\r\n\r\n            <!-- Social Links -->\r\n            <div class=\"footer-social\">\r\n                <a href=\"https://www.linkedin.com/in/piyushgohil8889/\" target=\"_blank\" class=\"social-icon\" aria-label=\"LinkedIn\">\r\n                    <img src=\"/assets/images/icons/linkedin-icon.png\" alt=\"LinkedIn\" class=\"social-icon-img\">\r\n                </a>\r\n                <a href=\"https://dribbble.com/desinger8889\" target=\"_blank\" class=\"social-icon\" aria-label=\"Dribbble\">\r\n                    <img src=\"/assets/images/icons/dribbble-icon.png\" alt=\"Dribbble\" class=\"social-icon-img\">\r\n                </a>\r\n                <a href=\"https://www.behance.net/Piyushgohil8889\" target=\"_blank\" class=\"social-icon\" aria-label=\"Behance\">\r\n                    <img src=\"/assets/images/icons/behance-icon.png\" alt=\"Behance\" class=\"social-icon-img\">\r\n                </a>\r\n            </div>\r\n\r\n        </div>\r\n\r\n        <!-- Services Section -->\r\n        <div class=\"footer-section-block animate-slide-up\">\r\n            <h3 class=\"footer-heading\">\r\n                Services\r\n                <button class=\"footer-toggle\" aria-label=\"Toggle Services\">\r\n                    <span class=\"accordion-arrow-circle\">\r\n                        <svg class=\"arrow-svg\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http:/www.w3.org/2000/svg\">\r\n                            <path d=\"M5 12H19M19 12L12 5M19 12L12 19\" stroke=\"black\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                        </svg>\r\n                    </span>\r\n                </button>\r\n            </h3>\r\n            <div class=\"footer-links\">\r\n                <a href=\"/pages/main/services.html\">UI/UX Design</a>\r\n                <a href=\"/pages/main/services.html\">Web Design</a>\r\n                <a href=\"/pages/main/services.html\">App Design</a>\r\n                <a href=\"/pages/main/services.html\">Marketing Emailer</a>\r\n                <a href=\"/pages/main/services.html\">Social Media</a>\r\n                <a href=\"/pages/main/services.html\">Logo Design</a>\r\n                <a href=\"/pages/main/services.html\">Graphics Design</a>\r\n                <a href=\"/pages/main/services.html\">Tool Design</a>\r\n                <a href=\"/pages/main/services.html\">Document Design</a>\r\n                <a href=\"/pages/main/services.html\">ETC Design</a>\r\n            </div>\r\n        </div>\r\n\r\n        <!-- Company Section -->\r\n        <div class=\"footer-section-block animate-slide-up\">\r\n            <h3 class=\"footer-heading\">\r\n                Company\r\n                <button class=\"footer-toggle\" aria-label=\"Toggle Company\">\r\n                    <span class=\"accordion-arrow-circle\">\r\n                        <svg class=\"arrow-svg\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http:/www.w3.org/2000/svg\">\r\n                            <path d=\"M5 12H19M19 12L12 5M19 12L12 19\" stroke=\"black\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                        </svg>\r\n                    </span>\r\n                </button>\r\n            </h3>\r\n            <div class=\"footer-links\">\r\n                <a href=\"/pages/main/about.html\">About Us</a>\r\n                <a href=\"/pages/blogs/blogs.html\">Blog</a>\r\n                \r\n                <a href=\"/pages/main/contact-page.html\">Contact</a>\r\n                <a href=\"/pages/legal/privacy-policy.html\">Privacy Policy</a>\r\n                <a href=\"/pages/legal/term-condition.html\">Terms of Service</a>\r\n            </div>\r\n        </div>\r\n\r\n        <!-- Copyright -->\r\n        <div class=\"footer-bottom animate-fade-in\">\r\n            <p class=\"footer-copyright\">&copy; 2025 Webx Design Studio. All rights reserved</p>\r\n        </div>\r\n\r\n    </div>\r\n\r\n    <!-- Large Background Text with Image - OUTSIDE container -->\r\n    <div class=\"footer-bg-text\">\r\n        <img src=\"/assets/images/logos/webx-footer-logo-large.svg\" alt=\"Webx\" class=\"footer-bg-image\">\r\n    </div>\r\n\r\n</footer>"
        }
