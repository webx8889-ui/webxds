      "sections": [
        {
          "id": "about-section-e70ced47",
          "label": "About page hero",
          "enabled": true,
          "html": "<header>\r\n        <section class=\"service-hero-section\" aria-label=\"About page hero\">\r\n            <nav class=\"home-navbar\" aria-label=\"Main navigation\">\r\n                <div class=\"home-nav-container\">\r\n                    <div class=\"home-logo\"> <a href=\"/\" class=\"logo-link\"\r\n                            aria-label=\"Webx Design Studio - Go to homepage\"> <img\r\n                                src=\"/assets/images/logos/webx-logo.svg\" alt=\"Webx Design Studio\" width=\"140\"\r\n                                height=\"40\" /> </a> </div> <a href=\"/pages/main/contact-page.html\"\r\n                        class=\"home-contact-btn\"> <span>CONTACT US</span> <svg width=\"16\" height=\"16\"\r\n                            viewBox=\"0 0 16 16\" fill=\"none\" aria-hidden=\"true\">\r\n                            <path d=\"M3 13L13 3M13 3H5M13 3V11\" stroke=\"currentColor\" stroke-width=\"2\"\r\n                                stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                        </svg> </a>\r\n                </div>\r\n            </nav>\r\n        </section>\r\n    </header>"
        },
        {
          "id": "about-section-e838c0a9",
          "label": "About Webx Design Studio introduction",
          "enabled": true,
          "html": "<section class=\"services-section\" aria-label=\"About Webx Design Studio introduction\">\r\n            <div class=\"services-container\">\r\n                <h1 class=\"about-page-title\">Creative Thinkers. Problem Solvers. Design Partners.</h1>\r\n                <p class=\"services-description\"> At Webx Design Studio, design is more than how things look; it is how\r\n                    they feel, flow, and connect. We cultivate a space where new ideas and unique viewpoints are\r\n                    encouraged to shape digital experiences across products, platforms, and brands. </p>\r\n                <div class=\"services-image-wrapper\"> <img src=\"/assets/images/banners/about-banner.png\"\r\n                        alt=\"Webx Design Studio team - creative UI/UX designers and strategists in India\"\r\n                        class=\"services-image\" width=\"1200\" height=\"600\" loading=\"eager\" /> </div>\r\n            </div>\r\n        </section>"
        },
        {
          "id": "about-section-16418dd7",
          "label": "Studio statistics",
          "enabled": true,
          "html": "<section class=\"reimagining-section animate-section\" aria-label=\"Studio statistics\">\r\n            <div class=\"reimagining-container\">\r\n                <div class=\"stats-box\" role=\"list\" aria-label=\"Webx Design Studio key statistics\">\r\n                    <div class=\"stat-item\" role=\"listitem\">\r\n                        <div class=\"stat-number\" data-target=\"5\">0</div>\r\n                        <div class=\"stat-label\">Years of Studio Excellence</div>\r\n                    </div>\r\n                    <div class=\"stat-divider\" aria-hidden=\"true\"></div>\r\n                    <div class=\"stat-item\" role=\"listitem\">\r\n                        <div class=\"stat-number\" data-target=\"11\">0</div>\r\n                        <div class=\"stat-label\">Products &amp; Platforms Designed</div>\r\n                    </div>\r\n                    <div class=\"stat-divider\" aria-hidden=\"true\"></div>\r\n                    <div class=\"stat-item\" role=\"listitem\">\r\n                        <div class=\"stat-number\" data-target=\"101\">0</div>\r\n                        <div class=\"stat-label\">Creative Deliverables Crafted</div>\r\n                    </div>\r\n                    <div class=\"stat-divider\" aria-hidden=\"true\"></div>\r\n                    <div class=\"stat-item\" role=\"listitem\">\r\n                        <div class=\"stat-number\" data-target=\"10\">0</div>\r\n                        <div class=\"stat-label\">Industries Served Globally</div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </section>"
        },
        {
          "id": "about-section-fffd4935",
          "label": "Our design process",
          "enabled": true,
          "html": "<section class=\"services-accordion-section\" aria-label=\"Our design process\">\r\n            <div class=\"services-accordion-container\">\r\n                <div class=\"section-header\">\r\n                    <p class=\"section-label\">Our Process</p>\r\n                    <h2 class=\"section-title\">The Driving Force behind our People and Projects</h2>\r\n                </div>\r\n                <div class=\"accordion-item active\"> <button class=\"accordion-header\" aria-expanded=\"true\"\r\n                        aria-controls=\"process-content-1\"> <span class=\"accordion-number\">01</span>\r\n                        <h3 class=\"accordion-title\">Define</h3> <span class=\"accordion-arrow-circle\" aria-hidden=\"true\">\r\n                            <svg class=\"arrow-svg\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http:/www.w3.org/2000/svg\">\r\n                                <path d=\"M5 12H19M19 12L12 5M19 12L12 19\" stroke=\"black\" stroke-width=\"2.5\"\r\n                                    stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                            </svg> </span>\r\n                    </button>\r\n                    <div class=\"accordion-content\" id=\"process-content-1\" role=\"region\">\r\n                        <div class=\"accordion-content-inner\">\r\n                            <p class=\"accordion-text\">Setting the North Star. We strip away the fluff to align your\r\n                                business goals with real human needs. No guesswork here; just a sharp, purpose-driven\r\n                                roadmap that ensures we are building the right thing for the right people.</p>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n                <div class=\"accordion-item\"> <button class=\"accordion-header\" aria-expanded=\"false\"\r\n                        aria-controls=\"process-content-2\"> <span class=\"accordion-number\">02</span>\r\n                        <h3 class=\"accordion-title\">Discover</h3> <span class=\"accordion-arrow-circle\"\r\n                            aria-hidden=\"true\"> <svg class=\"arrow-svg\" viewBox=\"0 0 24 24\" fill=\"none\"\r\n                                xmlns=\"http:/www.w3.org/2000/svg\">\r\n                                <path d=\"M5 12H19M19 12L12 5M19 12L12 19\" stroke=\"black\" stroke-width=\"2.5\"\r\n                                    stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                            </svg> </span>\r\n                    </button>\r\n                    <div class=\"accordion-content\" id=\"process-content-2\" role=\"region\">\r\n                        <div class=\"accordion-content-inner\">\r\n                            <p class=\"accordion-text\">Going down the rabbit hole. We hunt for the \"why\" behind the\r\n                                \"what.\" By tearing down competitor strategies and analyzing user behavior, we find the\r\n                                creative gaps that allow your brand to actually stand out rather than just fit in.</p>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n                <div class=\"accordion-item\"> <button class=\"accordion-header\" aria-expanded=\"false\"\r\n                        aria-controls=\"process-content-3\"> <span class=\"accordion-number\">03</span>\r\n                        <h3 class=\"accordion-title\">Develop</h3> <span class=\"accordion-arrow-circle\"\r\n                            aria-hidden=\"true\"> <svg class=\"arrow-svg\" viewBox=\"0 0 24 24\" fill=\"none\"\r\n                                xmlns=\"http:/www.w3.org/2000/svg\">\r\n                                <path d=\"M5 12H19M19 12L12 5M19 12L12 19\" stroke=\"black\" stroke-width=\"2.5\"\r\n                                    stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                            </svg> </span>\r\n                    </button>\r\n                    <div class=\"accordion-content\" id=\"process-content-3\" role=\"region\">\r\n                        <div class=\"accordion-content-inner\">\r\n                            <p class=\"accordion-text\">Turning pixels into power. This is where raw concepts become\r\n                                high-fidelity reality. We build, stress-test, and iterate through constant feedback\r\n                                loops until the interface feels intuitive and the experience feels effortless.</p>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n                <div class=\"accordion-item\"> <button class=\"accordion-header\" aria-expanded=\"false\"\r\n                        aria-controls=\"process-content-4\"> <span class=\"accordion-number\">04</span>\r\n                        <h3 class=\"accordion-title\">Deliver</h3> <span class=\"accordion-arrow-circle\"\r\n                            aria-hidden=\"true\"> <svg class=\"arrow-svg\" viewBox=\"0 0 24 24\" fill=\"none\"\r\n                                xmlns=\"http:/www.w3.org/2000/svg\">\r\n                                <path d=\"M5 12H19M19 12L12 5M19 12L12 19\" stroke=\"black\" stroke-width=\"2.5\"\r\n                                    stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                            </svg> </span>\r\n                    </button>\r\n                    <div class=\"accordion-content\" id=\"process-content-4\" role=\"region\">\r\n                        <div class=\"accordion-content-inner\">\r\n                            <p class=\"accordion-text\">Hitting the big green button. We ship high-performance digital\r\n                                products engineered for the long haul. This is not just a handoff; it is the launch of a\r\n                                polished, professional asset designed to move the needle and scale with your business.\r\n                            </p>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </section>"
        },
        {
          "id": "about-section-0708eb25",
          "label": "Our core values",
          "enabled": true,
          "html": "<section class=\"about-values-section animate-section\" aria-label=\"Our core values\">\r\n            <div class=\"about-values-container\">\r\n                <div class=\"section-header\">\r\n                    <p class=\"section-label\">Our Core Value</p>\r\n                    <h2 class=\"section-title\">Why Visionary Brands Choose Webx</h2>\r\n                </div>\r\n                <div class=\"about-values-scroll-wrapper\">\r\n                    <div class=\"about-values-grid animate-cards\">\r\n                        <div class=\"about-value-card\">\r\n                            <div class=\"about-value-card-inner\">\r\n                                <div class=\"about-value-icon\"> <img src=\"/assets/images/clients/client-first-icon.png\"\r\n                                        alt=\"Client First - building partnerships through communication\" width=\"48\"\r\n                                        height=\"48\" loading=\"lazy\" /> </div>\r\n                                <div class=\"about-value-content\">\r\n                                    <h3 class=\"about-value-title\">Client First</h3>\r\n                                    <p class=\"about-value-description\">Building strong partnerships through clear\r\n                                        communication and dedicated project support.</p>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                        <div class=\"about-value-card\">\r\n                            <div class=\"about-value-card-inner\">\r\n                                <div class=\"about-value-icon\"> <img src=\"/assets/images/icons/user-centric-icon.png\"\r\n                                        alt=\"User-Centric - interviews and testing for loved products\" width=\"48\"\r\n                                        height=\"48\" loading=\"lazy\" /> </div>\r\n                                <div class=\"about-value-content\">\r\n                                    <h3 class=\"about-value-title\">User-Centric</h3>\r\n                                    <p class=\"about-value-description\">Using interviews and testing to build products\r\n                                        people actually love using.</p>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                        <div class=\"about-value-card\">\r\n                            <div class=\"about-value-card-inner\">\r\n                                <div class=\"about-value-icon\"> <img src=\"/assets/images/icons/result-driven-icon.png\"\r\n                                        alt=\"Result-Driven - analytics and performance for business growth\" width=\"48\"\r\n                                        height=\"48\" loading=\"lazy\" /> </div>\r\n                                <div class=\"about-value-content\">\r\n                                    <h3 class=\"about-value-title\">Result-Driven</h3>\r\n                                    <p class=\"about-value-description\">Focusing on analytics and performance to deliver\r\n                                        real business growth.</p>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                        <div class=\"about-value-card\">\r\n                            <div class=\"about-value-card-inner\">\r\n                                <div class=\"about-value-icon\"> <img src=\"/assets/images/icons/integrated-icon.png\"\r\n                                        alt=\"Integrated - design strategy and technology for seamless ecosystem\"\r\n                                        width=\"48\" height=\"48\" loading=\"lazy\" /> </div>\r\n                                <div class=\"about-value-content\">\r\n                                    <h3 class=\"about-value-title\">Integrated</h3>\r\n                                    <p class=\"about-value-description\">Combining design, strategy, and technology for a\r\n                                        seamless digital ecosystem.</p>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                        <div class=\"about-value-card\">\r\n                            <div class=\"about-value-card-inner\">\r\n                                <div class=\"about-value-icon\"> <img src=\"/assets/images/icons/security-icon.png\"\r\n                                        alt=\"Security - robust safety and privacy in every digital product\" width=\"48\"\r\n                                        height=\"48\" loading=\"lazy\" /> </div>\r\n                                <div class=\"about-value-content\">\r\n                                    <h3 class=\"about-value-title\">Security</h3>\r\n                                    <p class=\"about-value-description\">Ensuring every digital product is built with\r\n                                        robust safety and privacy.</p>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                        <div class=\"about-value-card\">\r\n                            <div class=\"about-value-card-inner\">\r\n                                <div class=\"about-value-icon\"> <img src=\"/assets/images/icons/scalability-icon.png\"\r\n                                        alt=\"Scalability - flexible systems that grow with your business\" width=\"48\"\r\n                                        height=\"48\" loading=\"lazy\" /> </div>\r\n                                <div class=\"about-value-content\">\r\n                                    <h3 class=\"about-value-title\">Scalability</h3>\r\n                                    <p class=\"about-value-description\">Designing flexible systems that grow effortlessly\r\n                                        alongside your expanding business.</p>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n                <div class=\"about-values-progress-bar\" role=\"progressbar\" aria-label=\"Values slider progress\">\r\n                    <div class=\"about-values-progress-bg\"></div>\r\n                    <div class=\"about-values-progress-fill\"></div>\r\n                </div>\r\n                <div class=\"about-values-navigation\"> <button class=\"about-values-arrow about-values-prev\"\r\n                        aria-label=\"Previous value\">&#8592;</button> <button\r\n                        class=\"about-values-arrow about-values-next\" aria-label=\"Next value\">&#8594;</button> </div>\r\n            </div>\r\n        </section>"
        },
        {
          "id": "about-section-6495fda2",
          "label": "Yearly delivery track record",
          "enabled": true,
          "html": "<section class=\"track-record-section\" aria-label=\"Yearly delivery track record\">\r\n            <div class=\"track-record-container\">\r\n                <div class=\"section-header\">\r\n                    <p class=\"section-label\">From Vision to Reality</p>\r\n                    <h2 class=\"section-title\">A Proven Track Record of Yearly Delivery</h2>\r\n                </div>\r\n                <div class=\"track-record-tabs\" role=\"tablist\" aria-label=\"Select year\"> <button class=\"track-record-tab\"\r\n                        data-year=\"2023\" data-index=\"0\" role=\"tab\" aria-selected=\"false\">2023</button> <button\r\n                        class=\"track-record-tab\" data-year=\"2024\" data-index=\"1\" role=\"tab\"\r\n                        aria-selected=\"false\">2024</button> <button class=\"track-record-tab active\" data-year=\"2025\"\r\n                        data-index=\"2\" role=\"tab\" aria-selected=\"true\">2025</button> </div>\r\n                <div class=\"track-tabs-progress\" aria-hidden=\"true\">\r\n                    <div class=\"track-progress-fill\"></div>\r\n                    <div class=\"track-year-dots\">\r\n                        <div class=\"track-year-dot\" data-year=\"2023\"></div>\r\n                        <div class=\"track-year-dot\" data-year=\"2024\"></div>\r\n                        <div class=\"track-year-dot active\" data-year=\"2025\"></div>\r\n                    </div>\r\n                </div>\r\n                <div class=\"track-record-stats\" role=\"list\" aria-label=\"2025 deliverables\">\r\n                    <div class=\"track-stat-item\" role=\"listitem\"><span class=\"track-stat-label\" data-stat=\"website\">5+\r\n                            Website</span></div>\r\n                    <div class=\"track-stat-item\" role=\"listitem\"><span class=\"track-stat-label\" data-stat=\"app\">100+\r\n                            App</span></div>\r\n                    <div class=\"track-stat-item\" role=\"listitem\"><span class=\"track-stat-label\" data-stat=\"emailer\">1k+\r\n                            Emailer</span></div>\r\n                    <div class=\"track-stat-item\" role=\"listitem\"><span class=\"track-stat-label\" data-stat=\"logos\">5\r\n                            Logos</span></div>\r\n                    <div class=\"track-stat-item\" role=\"listitem\"><span class=\"track-stat-label\" data-stat=\"tools\">3\r\n                            Tools</span></div>\r\n                    <div class=\"track-stat-item\" role=\"listitem\"><span class=\"track-stat-label\" data-stat=\"graphics\">1k+\r\n                            Graphics</span></div>\r\n                </div>\r\n                <div class=\"track-record-media\">\r\n                    <div class=\"track-media-placeholder\"> <img src=\"/gif/gif-2025.gif\"\r\n                            alt=\"Webx Design Studio 2025 project highlights animated showcase\" width=\"800\" height=\"450\"\r\n                            loading=\"lazy\" /> </div>\r\n                </div>\r\n            </div>\r\n        </section>"
        },
        {
          "id": "about-section-c98a96df",
          "label": "Client testimonials",
          "enabled": true,
          "html": "<section class=\"impact-section animate-section\" aria-label=\"Client testimonials\">\r\n            <div class=\"impact-container\">\r\n                <div class=\"section-header animate-fade-in\">\r\n                    <div class=\"section-label\">The Impact</div>\r\n                    <h2 class=\"section-title\">From vision to real results, a team that delivers consistently</h2>\r\n                </div>\r\n                <div class=\"impact-slider-wrapper animate-slider\">\r\n                    <div class=\"impact-slider\" id=\"impactSlider\" role=\"list\">\r\n                        <div class=\"impact-slide active\" role=\"listitem\">\r\n                            <div class=\"impact-quote-block\"> <img src=\"/assets/images/icons/quote-icon.svg\" alt=\"\"\r\n                                    class=\"quote-icon\" aria-hidden=\"true\" width=\"32\" height=\"32\" loading=\"lazy\" />\r\n                                <p class=\"quote-text\">\"Webx Design Studio stands out for its ability to combine\r\n                                    healthcare expertise with creative thinking. Their collaborative mindset, strong\r\n                                    workflow, and professional approach resulted in solutions that exceeded\r\n                                    expectations. A truly dependable team.\"</p>\r\n                            </div>\r\n                            <div class=\"impact-footer\">\r\n                                <div class=\"author-card\"> <img src=\"/assets/images/blogs/auther-imag-ab.png\"\r\n                                        alt=\"Irfan N. Shaikh, Founder of Arogya Bharat\" class=\"author-photo\" width=\"56\"\r\n                                        height=\"56\" loading=\"lazy\" />\r\n                                    <div class=\"author-info\">\r\n                                        <div class=\"author-name\">Irfan N. Shaikh</div>\r\n                                        <div class=\"author-title\">Founder, Arogya Bharat</div>\r\n                                    </div>\r\n                                </div>\r\n                                <div class=\"brand-logo\"> <img src=\"/assets/images/logos/ab-logo-1.png\"\r\n                                        alt=\"Arogya Bharat Logo\" width=\"100\" height=\"50\" loading=\"lazy\" /> </div>\r\n                            </div>\r\n                        </div>\r\n                        <div class=\"impact-slide\" role=\"listitem\">\r\n                            <div class=\"impact-quote-block\"> <img src=\"/assets/images/icons/quote-icon.svg\" alt=\"\"\r\n                                    class=\"quote-icon\" aria-hidden=\"true\" width=\"32\" height=\"32\" loading=\"lazy\" />\r\n                                <p class=\"quote-text\">\"Working with the team transformed our digital presence\r\n                                    completely. Their strategic approach and attention to detail resulted in a product\r\n                                    our users truly appreciate. The collaboration was smooth, timely, and exceeded\r\n                                    expectations.\"</p>\r\n                            </div>\r\n                            <div class=\"impact-footer\">\r\n                                <div class=\"author-card\"> <img src=\"/assets/images/blogs/auther-imag-ab.png\"\r\n                                        alt=\"Archit Sankhe, Founder of Morphico\" class=\"author-photo\" width=\"56\"\r\n                                        height=\"56\" loading=\"lazy\" />\r\n                                    <div class=\"author-info\">\r\n                                        <div class=\"author-name\">Archit Sankhe</div>\r\n                                        <div class=\"author-title\">Founder, Morphico</div>\r\n                                    </div>\r\n                                </div>\r\n                                <div class=\"brand-logo\"> <img src=\"/assets/images/clients/morphico-logo.png\"\r\n                                        alt=\"Morphico Logo\" width=\"100\" height=\"50\" loading=\"lazy\" /> </div>\r\n                            </div>\r\n                        </div>\r\n                        <div class=\"impact-slide\" role=\"listitem\">\r\n                            <div class=\"impact-quote-block\"> <img src=\"/assets/images/icons/quote-icon.svg\" alt=\"\"\r\n                                    class=\"quote-icon\" aria-hidden=\"true\" width=\"32\" height=\"32\" loading=\"lazy\" />\r\n                                <p class=\"quote-text\">\"Exceptional creativity paired with technical excellence. The team\r\n                                    delivered a seamless product flow that helped boost our conversion rates by over\r\n                                    200%. Their professionalism made this project a success.\"</p>\r\n                            </div>\r\n                            <div class=\"impact-footer\">\r\n                                <div class=\"author-card\"> <img src=\"/assets/images/blogs/auther-imag-ab.png\"\r\n                                        alt=\"Ashay Khandhar, Founder of Tictax\" class=\"author-photo\" width=\"56\"\r\n                                        height=\"56\" loading=\"lazy\" />\r\n                                    <div class=\"author-info\">\r\n                                        <div class=\"author-name\">Ashay Khandhar</div>\r\n                                        <div class=\"author-title\">Founder, Tictax</div>\r\n                                    </div>\r\n                                </div>\r\n                                <div class=\"brand-logo\"> <img src=\"/assets/images/clients/tictax-logo.png\"\r\n                                        alt=\"Tictax Logo\" width=\"100\" height=\"50\" loading=\"lazy\" /> </div>\r\n                            </div>\r\n                        </div>\r\n                        <div class=\"impact-slide\" role=\"listitem\">\r\n                            <div class=\"impact-quote-block\"> <img src=\"/assets/images/icons/quote-icon.svg\" alt=\"\"\r\n                                    class=\"quote-icon\" aria-hidden=\"true\" width=\"32\" height=\"32\" loading=\"lazy\" />\r\n                                <p class=\"quote-text\">\"The clarity they brought to our platform made a real difference.\r\n                                    Everything feels structured, modern, and easy to navigate.\"</p>\r\n                            </div>\r\n                            <div class=\"impact-footer\">\r\n                                <div class=\"author-card\"> <img src=\"/assets/images/blogs/auther-imag-ab.png\"\r\n                                        alt=\"Ajay Kanjariya, Founder of Mecon\" class=\"author-photo\" width=\"56\"\r\n                                        height=\"56\" loading=\"lazy\" />\r\n                                    <div class=\"author-info\">\r\n                                        <div class=\"author-name\">Ajay Kanjariya</div>\r\n                                        <div class=\"author-title\">Founder, Mecon</div>\r\n                                    </div>\r\n                                </div>\r\n                                <div class=\"brand-logo\"> <img src=\"/assets/images/clients/mecon-logo.png\"\r\n                                        alt=\"Mecon Logo\" width=\"100\" height=\"50\" loading=\"lazy\" /> </div>\r\n                            </div>\r\n                        </div>\r\n                        <div class=\"impact-slide\" role=\"listitem\">\r\n                            <div class=\"impact-quote-block\"> <img src=\"/assets/images/icons/quote-icon.svg\" alt=\"\"\r\n                                    class=\"quote-icon\" aria-hidden=\"true\" width=\"32\" height=\"32\" loading=\"lazy\" />\r\n                                <p class=\"quote-text\">\"Our brand visuals and online presence improved significantly\r\n                                    after working with Webx Design Studio.\"</p>\r\n                            </div>\r\n                            <div class=\"impact-footer\">\r\n                                <div class=\"author-card\"> <img src=\"/assets/images/blogs/auther-imag-ab.png\"\r\n                                        alt=\"Punit Bhatti, Founder of Gurukrupa\" class=\"author-photo\" width=\"56\"\r\n                                        height=\"56\" loading=\"lazy\" />\r\n                                    <div class=\"author-info\">\r\n                                        <div class=\"author-name\">Punit Bhatti</div>\r\n                                        <div class=\"author-title\">Founder, Gurukrupa</div>\r\n                                    </div>\r\n                                </div>\r\n                                <div class=\"brand-logo\"> <img src=\"/assets/images/clients/gurukrupa-logo.png\"\r\n                                        alt=\"Gurukrupa Logo\" width=\"100\" height=\"50\" loading=\"lazy\" /> </div>\r\n                            </div>\r\n                        </div>\r\n                        <div class=\"impact-slide\" role=\"listitem\">\r\n                            <div class=\"impact-quote-block\"> <img src=\"/assets/images/icons/quote-icon.svg\" alt=\"\"\r\n                                    class=\"quote-icon\" aria-hidden=\"true\" width=\"32\" height=\"32\" loading=\"lazy\" />\r\n                                <p class=\"quote-text\">\"The team understood our goals quickly and delivered exactly what\r\n                                    we needed, on time and with great quality.\"</p>\r\n                            </div>\r\n                            <div class=\"impact-footer\">\r\n                                <div class=\"author-card\"> <img src=\"/assets/images/blogs/auther-imag-ab.png\"\r\n                                        alt=\"Dhaval Vora, Founder of Manglam\" class=\"author-photo\" width=\"56\"\r\n                                        height=\"56\" loading=\"lazy\" />\r\n                                    <div class=\"author-info\">\r\n                                        <div class=\"author-name\">Dhaval Vora</div>\r\n                                        <div class=\"author-title\">Founder, Manglam</div>\r\n                                    </div>\r\n                                </div>\r\n                                <div class=\"brand-logo\"> <img src=\"/assets/images/clients/manglam-logo.png\"\r\n                                        alt=\"Manglam Logo\" width=\"100\" height=\"50\" loading=\"lazy\" /> </div>\r\n                            </div>\r\n                        </div>\r\n                        <div class=\"impact-slide\" role=\"listitem\">\r\n                            <div class=\"impact-quote-block\"> <img src=\"/assets/images/icons/quote-icon.svg\" alt=\"\"\r\n                                    class=\"quote-icon\" aria-hidden=\"true\" width=\"32\" height=\"32\" loading=\"lazy\" />\r\n                                <p class=\"quote-text\">\"Exceptional design paired with technical excellence. The team\r\n                                    delivered a seamless user experience that boosted our conversion rates by 200%.\r\n                                    Their professionalism and dedication made this project a huge success.\"</p>\r\n                            </div>\r\n                            <div class=\"impact-footer\">\r\n                                <div class=\"author-card\"> <img src=\"/assets/images/blogs/auther-imag-ab.png\"\r\n                                        alt=\"Dharmesh Enterprise founder\" class=\"author-photo\" width=\"56\" height=\"56\"\r\n                                        loading=\"lazy\" />\r\n                                    <div class=\"author-info\">\r\n                                        <div class=\"author-name\">Dharmesh Enterprise</div>\r\n                                        <div class=\"author-title\">Founder</div>\r\n                                    </div>\r\n                                </div>\r\n                                <div class=\"brand-logo\"> <img src=\"/assets/images/clients/de-logo.png\"\r\n                                        alt=\"Dharmesh Enterprise Logo\" width=\"100\" height=\"50\" loading=\"lazy\" /> </div>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n                <div class=\"impact-slider-controls\">\r\n                    <div class=\"impact-progress-bar\" role=\"progressbar\" aria-label=\"Testimonials slider progress\">\r\n                        <div class=\"impact-progress-bg\"></div>\r\n                        <div class=\"impact-progress-fill\" id=\"impactProgressBar\"></div>\r\n                    </div>\r\n                    <div class=\"impact-navigation\"> <button class=\"impact-arrow impact-prev\" id=\"impactPrev\"\r\n                            aria-label=\"Previous testimonial\">&#8592;</button> <button class=\"impact-arrow impact-next\"\r\n                            id=\"impactNext\" aria-label=\"Next testimonial\">&#8594;</button> </div>\r\n                </div>\r\n            </div>\r\n        </section>"
        },
        {
          "id": "about-section-8be54441",
          "label": "Site footer",
          "enabled": true,
          "html": "<footer class=\"footer-section\" aria-label=\"Site footer\">\r\n        <div class=\"footer-container\">\r\n            <div class=\"footer-top\">\r\n                <div class=\"footer-logo\"> <img src=\"/assets/images/logos/webx-logo.svg\" alt=\"Webx Design Studio\"\r\n                        class=\"footer-logo-img\" width=\"140\" height=\"40\" loading=\"lazy\" /> </div>\r\n                <div class=\"footer-social\"> <a href=\"https://www.linkedin.com/in/piyushgohil8889/\" target=\"_blank\"\r\n                        rel=\"noopener noreferrer\" class=\"social-icon\" aria-label=\"Webx Design Studio on LinkedIn\"> <img\r\n                            src=\"/assets/images/icons/linkedin-icon.png\" alt=\"LinkedIn\" class=\"social-icon-img\"\r\n                            width=\"24\" height=\"24\" loading=\"lazy\" /> </a> <a href=\"https://dribbble.com/desinger8889\"\r\n                        target=\"_blank\" rel=\"noopener noreferrer\" class=\"social-icon\"\r\n                        aria-label=\"Webx Design Studio on Dribbble\"> <img src=\"/assets/images/icons/dribbble-icon.png\"\r\n                            alt=\"Dribbble\" class=\"social-icon-img\" width=\"24\" height=\"24\" loading=\"lazy\" /> </a> <a\r\n                        href=\"https://www.behance.net/Piyushgohil8889\" target=\"_blank\" rel=\"noopener noreferrer\"\r\n                        class=\"social-icon\" aria-label=\"Webx Design Studio on Behance\"> <img\r\n                            src=\"/assets/images/icons/behance-icon.png\" alt=\"Behance\" class=\"social-icon-img\" width=\"24\"\r\n                            height=\"24\" loading=\"lazy\" /> </a> </div>\r\n            </div>\r\n            <div class=\"footer-section-block\">\r\n                <h3 class=\"footer-heading\"> Services <button class=\"footer-toggle\" aria-label=\"Toggle Services menu\"\r\n                        aria-expanded=\"false\"> <span class=\"accordion-arrow-circle\"> <svg class=\"arrow-svg\"\r\n                                viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http:/www.w3.org/2000/svg\" aria-hidden=\"true\">\r\n                                <path d=\"M5 12H19M19 12L12 5M19 12L12 19\" stroke=\"black\" stroke-width=\"2.5\"\r\n                                    stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                            </svg> </span> </button> </h3>\r\n                <div class=\"footer-links\"> <a href=\"/pages/main/services.html\">UI/UX Design</a> <a\r\n                        href=\"/pages/main/services.html\">Web Design</a> <a href=\"/pages/main/services.html\">App\r\n                        Design</a> <a href=\"/pages/main/services.html\">Marketing Emailer</a> <a\r\n                        href=\"/pages/main/services.html\">Social Media</a> <a href=\"/pages/main/services.html\">Logo\r\n                        Design</a> <a href=\"/pages/main/services.html\">Graphics Design</a> <a\r\n                        href=\"/pages/main/services.html\">Tool Design</a> <a href=\"/pages/main/services.html\">Document\r\n                        Design</a> <a href=\"/pages/main/services.html\">ETC Design</a> </div>\r\n            </div>\r\n            <div class=\"footer-section-block\">\r\n                <h3 class=\"footer-heading\"> Company <button class=\"footer-toggle\" aria-label=\"Toggle Company menu\"\r\n                        aria-expanded=\"false\"> <span class=\"accordion-arrow-circle\"> <svg class=\"arrow-svg\"\r\n                                viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http:/www.w3.org/2000/svg\" aria-hidden=\"true\">\r\n                                <path d=\"M5 12H19M19 12L12 5M19 12L12 19\" stroke=\"black\" stroke-width=\"2.5\"\r\n                                    stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                            </svg> </span> </button> </h3>\r\n                <div class=\"footer-links\"> <a href=\"/pages/main/about.html\">About Us</a> <a\r\n                        href=\"/pages/blogs/blogs.html\">Blog</a> <a href=\"/pages/main/contact-page.html\">Contact</a> <a\r\n                        href=\"/pages/legal/privacy-policy.html\">Privacy Policy</a> <a\r\n                        href=\"/pages/legal/term-condition.html\">Terms of Service</a> </div>\r\n            </div>\r\n            <div class=\"footer-bottom\">\r\n                <p class=\"footer-copyright\">&copy; 2026 Webx Design Studio. All rights reserved</p>\r\n            </div>\r\n        </div>\r\n        <div class=\"footer-bg-text\" aria-hidden=\"true\"> <img src=\"/assets/images/logos/webx-footer-logo-large.svg\"\r\n                alt=\"\" class=\"footer-bg-image\" loading=\"lazy\" /> </div>\r\n    </footer>"
