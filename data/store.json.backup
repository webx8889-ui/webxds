      "sections": [
        {
          "id": "service-form-section-f044f02b",
          "label": "Service Hero Section",
          "enabled": true,
          "html": "<section class=\"service-hero-section\">\r\n    <!-- Navbar -->\r\n    <nav class=\"home-navbar\">\r\n      <div class=\"home-nav-container\">\r\n        <div class=\"home-logo\">\r\n          <a href=\"/\" class=\"logo-link\">\r\n            <img src=\"/assets/images/logos/webx-logo.svg\" alt=\"Webox Design Studio\">\r\n          </a>\r\n        </div>\r\n        <a href=\"/pages/main/contact-page.html\" class=\"home-contact-btn\">\r\n          <span>CONTACT US</span>\r\n          <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\r\n            <path d=\"M3 13L13 3M13 3H5M13 3V11\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"\r\n              stroke-linejoin=\"round\" />\r\n          </svg>\r\n        </a>\r\n      </div>\r\n    </nav>\r\n  </section>"
        },
        {
          "id": "service-form-section-f33d46cc",
          "label": "Let's Build Something Amazing",
          "enabled": true,
          "html": "<section class=\"contact-section\">\r\n    <div class=\"contact-container\">\r\n      <div class=\"contact-header\">\r\n        <h2 class=\"contact-title\">Let's Build Something Amazing</h2>\r\n        <p class=\"contact-subtitle\">\r\n          Tell us about your project requirements and our team will craft a perfect solution tailored to your business\r\n          needs.\r\n        </p>\r\n      </div>\r\n      <form class=\"contact-form\" id=\"contactForm\" novalidate>\r\n        <div class=\"contact-row\">\r\n          <!-- Full Name Field -->\r\n          <div class=\"contact-field\">\r\n            <label>Full Name <span class=\"astric\">*</span></label>\r\n            <input type=\"text\" name=\"name\" id=\"fullName\" placeholder=\"Enter your Full Name\" required\r\n              pattern=\"[A-Za-z/s]+\" data-error=\"Please enter only alphabetic characters\">\r\n            <span class=\"error-message\" id=\"nameError\"></span>\r\n          </div>\r\n          <!-- Email Field -->\r\n          <div class=\"contact-field\">\r\n            <label>Email Address <span class=\"astric\">*</span></label>\r\n            <input type=\"email\" name=\"email\" id=\"emailInput\" placeholder=\"you@email.com\" required\r\n              data-error=\"Please enter a valid email address\">\r\n            <span class=\"error-message\" id=\"emailError\"></span>\r\n          </div>\r\n          <!-- Phone Number Field with Country Code -->\r\n          <div class=\"contact-field\">\r\n            <label>Phone Number <span class=\"astric\">*</span></label>\r\n            <div class=\"phone-input-wrapper\">\r\n              <select class=\"country-code-select\" name=\"countryCode\" id=\"countryCode\">\n                <option value=\"+91\" data-flag=\"IN\" selected>IN +91</option>\n                <option value=\"+1\" data-flag=\"US\">US +1</option>\n                <option value=\"+44\" data-flag=\"UK\">UK +44</option>\n                <option value=\"+971\" data-flag=\"UAE\">UAE +971</option>\n                <option value=\"+61\" data-flag=\"AU\">AU +61</option>\n                <option value=\"+81\" data-flag=\"JP\">JP +81</option>\n                <option value=\"+86\" data-flag=\"CN\">CN +86</option>\n                <option value=\"+65\" data-flag=\"SG\">SG +65</option>\n                <option value=\"+60\" data-flag=\"MY\">MY +60</option>\n                <option value=\"+92\" data-flag=\"PK\">PK +92</option>\n                <option value=\"+880\" data-flag=\"BD\">BD +880</option>\n                <option value=\"+94\" data-flag=\"LK\">LK +94</option>\n              </select>\r\n              <input type=\"tel\" name=\"phone\" id=\"phoneInput\" placeholder=\"1234567890\" required maxlength=\"10\"\r\n                pattern=\"[0-9]{10}\" data-error=\"Please enter exactly 10 digits\">\r\n            </div>\r\n            <span class=\"error-message\" id=\"phoneError\"></span>\r\n          </div>\r\n        </div>\r\n        <div class=\"contact-row\">\r\n          <!-- Budget Field -->\r\n          <div class=\"contact-field\">\r\n            <label>Project Budget</label>\r\n            <div class=\"budget-input-wrapper\">\r\n              <span class=\"rupee-symbol\">Rs</span>\r\n              <input type=\"text\" name=\"budget\" id=\"budgetInput\" placeholder=\"Enter your budget amount\" maxlength=\"10\">\r\n            </div>\r\n            <span class=\"error-message\" id=\"budgetError\"></span>\r\n          </div>\r\n          <!-- Services Field -->\r\n          <div class=\"contact-field contact-services\">\r\n            <label>Project Type </label>\r\n            <div class=\"services-grid\">\r\n              <label class=\"service-checkbox\">\r\n                <input type=\"checkbox\" name=\"service\" value=\"UI/UX Design\" checked>\r\n                <span class=\"checkmark\"></span>\r\n                <span class=\"service-label\">UI/UX Design</span>\r\n              </label>\r\n              <label class=\"service-checkbox\">\r\n                <input type=\"checkbox\" name=\"service\" value=\"Website Development\">\r\n                <span class=\"checkmark\"></span>\r\n                <span class=\"service-label\">Website Development</span>\r\n              </label>\r\n              <label class=\"service-checkbox\">\r\n                <input type=\"checkbox\" name=\"service\" value=\"Mobile Application\">\r\n                <span class=\"checkmark\"></span>\r\n                <span class=\"service-label\">Mobile Application</span>\r\n              </label>\r\n              <label class=\"service-checkbox\">\r\n                <input type=\"checkbox\" name=\"service\" value=\"Branding & Identity\">\r\n                <span class=\"checkmark\"></span>\r\n                <span class=\"service-label\">Branding &amp; Identity</span>\r\n              </label>\r\n              <label class=\"service-checkbox\">\r\n                <input type=\"checkbox\" name=\"service\" value=\"Other\">\r\n                <span class=\"checkmark\"></span>\r\n                <span class=\"service-label\">Other</span>\r\n              </label>\r\n            </div>\r\n            <span class=\"error-message\" id=\"servicesError\"></span>\r\n          </div>\r\n        </div>\r\n        <!-- Project Details -->\r\n        <div class=\"contact-row contact-details-row\">\r\n          <div class=\"contact-field full-width\">\r\n            <label>Project Details</label>\r\n            <textarea name=\"message\" id=\"projectDetails\" rows=\"3\" required minlength=\"20\"\r\n              data-error=\"Please enter at least 20 characters\"\r\n              placeholder=\"Tell us about your project goals, target audience, key features needed, and any reference websites or inspirations...\"></textarea>\r\n            <span class=\"error-message\" id=\"messageError\"></span>\r\n          </div>\r\n        </div>\r\n        <!-- reCAPTCHA -->\r\n        <div class=\"contact-row\">\r\n          <div class=\"contact-field\">\r\n            <div class=\"g-recaptcha\" data-sitekey=\"6Lf79jssAAAAAMXwKYN49fxYYxdxE_kTa53O0vwf\"\r\n              data-callback=\"enableSubmitBtn\" data-expired-callback=\"disableSubmitBtn\"></div>\r\n            <span class=\"error-message\" id=\"recaptchaError\"></span>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- Submit Button -->\r\n        <div class=\"contact-actions\">\r\n          <button type=\"submit\" class=\"accordion-cta-button\" id=\"submitBtn\" disabled>\r\n            <span>SEND</span>\r\n            <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\r\n              <path d=\"M3 13L13 3M13 3H5M13 3V11\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"\r\n                stroke-linejoin=\"round\" />\r\n            </svg>\r\n          </button>\r\n        </div>\r\n      </form>\r\n    </div>\r\n  </section>"
        },
        {
          "id": "service-form-section-67cf2f23",
          "label": "Success Message Section",
          "enabled": true,
          "html": "<section class=\"success-message-section\" id=\"successMessage\" style=\"display: none;\">\r\n    <div class=\"success-outer-container\">\r\n      <!-- Empty Box on Top -->\r\n      <div class=\"success-image-box\">\r\n        <img src=\"/assets/images/banners/thank-you-banner.png\" alt=\"thank-you-banner\" class=\"services-image\">\r\n      </div>\r\n  </section>"
        },
        {
          "id": "service-form-section-b57bf3f4",
          "label": "Reimagining Section",
          "enabled": true,
          "html": "<section class=\"reimagining-section\">\r\n    <div class=\"reimagining-container\">\r\n      <!-- Stats Box -->\r\n      <div class=\"stats-box\">\r\n        <div class=\"stat-item\">\r\n          <div class=\"stat-number\" data-target=\"5\">0</div>\r\n          <div class=\"stat-label\">Years of Expertise</div>\r\n        </div>\r\n        <div class=\"stat-divider\"></div>\r\n        <div class=\"stat-item\">\r\n          <div class=\"stat-number\" data-target=\"11\">0</div>\r\n          <div class=\"stat-label\">Projects Delivered</div>\r\n        </div>\r\n        <div class=\"stat-divider\"></div>\r\n        <div class=\"stat-item\">\r\n          <div class=\"stat-number\" data-target=\"101\">0</div>\r\n          <div class=\"stat-label\">Creative Pros</div>\r\n        </div>\r\n        <div class=\"stat-divider\"></div>\r\n        <div class=\"stat-item\">\r\n          <div class=\"stat-number\" data-target=\"10\">0</div>\r\n          <div class=\"stat-label\">Industries Serviced</div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </section>"
        },
        {
          "id": "service-form-section-4e4be16e",
          "label": "Footer Section Form",
          "enabled": true,
