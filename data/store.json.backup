      "meta": "Portfolio of creative projects - Morphico, Arogya Bharat, Tictax and more.",
      "projects": [
        {
          "id": "work-project-0a89c5f6",
          "slug": "morphico-pdp",
          "path": "/pages/details/morphico-pdp.html",
          "status": "live",
          "mode": "raw",
          "cardTitle": "Morphico Wallpapers & Murals",
          "category": "Case Study",
          "summary": "Transformed luxury interiors by designing an immersive digital gallery that brings wallpaper artistry to life.",
          "thumbnailImage": "/assets/images/work-card-mockup/morphico-mockup.png",
          "thumbnailAlt": "Morphico Wallpapers and Murals project mockup",
          "metaTitle": "Morphico Wallpapers & Murals | Webx Design Studio",
          "metaDescription": "Transformed luxury interiors by designing an immersive digital gallery that brings wallpaper artistry to life.",
          "rawHtml": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n\n<title>Morphico - Wallpaper &amp; Interior Design UI/UX Case Study | Webx Design Studio</title>\n<meta name=\"description\" content=\"Webx Design Studio redesigned Morphico's digital presence to match their physical elegance - a seamless online journey for premium wallpapers and wall murals.\" />\n<meta name=\"robots\" content=\"index, follow\" />\n<meta name=\"author\" content=\"Webx Design Studio\" />\n<meta name=\"theme-color\" content=\"#ff6b00\" />\n\n<link rel=\"canonical\" href=\"https://webxds.com/pages/details/morphico-pdp.html\" />\n\n<meta property=\"og:type\" content=\"article\" />\n<meta property=\"og:title\" content=\"Morphico - Wallpaper &amp; Interior Design UI/UX Case Study | Webx Design Studio\" />\n<meta property=\"og:description\" content=\"Webx Design Studio redesigned Morphico's digital presence to match their physical elegance - a seamless online journey for premium wallpapers and wall murals.\" />\n<meta property=\"og:url\" content=\"https://webxds.com/pages/details/morphico-pdp.html\" />\n<meta property=\"og:image\" content=\"https://webxds.com/assets/images/clients/morphico-hero-banner.png\" />\n<meta property=\"og:image:width\" content=\"1200\" />\n<meta property=\"og:image:height\" content=\"630\" />\n<meta property=\"og:image:alt\" content=\"Morphico UI/UX Case Study by Webx Design Studio\" />\n<meta property=\"og:site_name\" content=\"Webx Design Studio\" />\n<meta property=\"og:locale\" content=\"en_IN\" />\n\n<meta name=\"twitter:card\" content=\"summary_large_image\" />\n<meta name=\"twitter:title\" content=\"Morphico - Wallpaper &amp; Interior Design UI/UX Case Study | Webx Design Studio\" />\n<meta name=\"twitter:description\" content=\"Webx Design Studio redesigned Morphico's digital presence to match their physical elegance - a seamless online journey for premium wallpapers and wall murals.\" />\n<meta name=\"twitter:image\" content=\"https://webxds.com/assets/images/clients/morphico-hero-banner.png\" />\n<meta name=\"twitter:image:alt\" content=\"Morphico UI/UX Case Study by Webx Design Studio\" />\n\n<link rel=\"icon\" href=\"/assets/images/icons/favicon.png\" type=\"image/png\" sizes=\"32x32\" />\n<link rel=\"apple-touch-icon\" href=\"/assets/images/icons/favicon-180.png\" sizes=\"180x180\" />\n\n<link rel=\"manifest\" href=\"/manifest.json\" />\n\n<link rel=\"preconnect\" href=\"https://fonts.googleapis.com\" />\n<link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin />\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap\" rel=\"stylesheet\" />\n\n<link rel=\"stylesheet\" href=\"/css/style.css\" />\n\n<link rel=\"preload\" href=\"/assets/images/clients/morphico-hero-banner.png\" as=\"image\" />\n\n<script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n  \"@type\": \"CreativeWork\",\n  \"name\": \"Morphico - Wallpaper & Interior Design UI/UX Case Study\",\n  \"description\": \"Webx Design Studio redesigned Morphico's digital presence to match their physical elegance - a seamless online journey for premium wallpapers and wall murals.\",\n  \"url\": \"https://webxds.com/pages/details/morphico-pdp.html\",\n  \"image\": \"https://webxds.com/assets/images/clients/morphico-hero-banner.png\",\n  \"author\": {\n    \"@type\": \"Organization\",\n    \"name\": \"Webx Design Studio\",\n    \"url\": \"https://webxds.com\"\n  },\n  \"dateCreated\": \"2024\",\n  \"keywords\": \"UI/UX design, wallpaper, interior design, web design, visual identity\"\n}\n</script>\n\n<script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n  \"@type\": \"BreadcrumbList\",\n  \"itemListElement\": [\n    {\n      \"@type\": \"ListItem\",\n      \"position\": 1,\n      \"name\": \"Home\",\n      \"item\": \"https://webxds.com/\"\n    },\n    {\n      \"@type\": \"ListItem\",\n      \"position\": 2,\n      \"name\": \"Work\",\n      \"item\": \"https://webxds.com/pages/main/work.html\"\n    },\n    {\n      \"@type\": \"ListItem\",\n      \"position\": 3,\n      \"name\": \"Morphico\",\n      \"item\": \"https://webxds.com/pages/details/morphico-pdp.html\"\n    }\n  ]\n}\n</script>\n\n\n<script type=\"text/javascript\">\n    (function(c,l,a,r,i,t,y){\n        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};\n        t=l.createElement(r);t.async=1;t.src=\"https://www.clarity.ms/tag/\"+i;\n        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);\n    })(window, document, \"clarity\", \"script\", \"w2scyt23ol\");\n</script>\n</head>\n<body>\n\n<noscript>\n  <div style=\"padding: 20px; background: #111; color: #fff; text-align: center; font-family: sans-serif;\">\n    This website requires JavaScript to function correctly. Please enable JavaScript in your browser settings.\n  </div>\n</noscript>\n\n<!-- Hero Section -->\n<header>\n  <section class=\"pdp-hero-section\" aria-label=\"Morphico case study hero\">\n    <div class=\"hero-bg-morphico\" aria-hidden=\"true\">\n      <img src=\"/assets/images/admin-content/1775653043935-frame-1984080049.png\" alt=\"\" class=\"hero-bg-image-morphico\" width=\"1440\" height=\"800\" loading=\"eager\">\n    </div>\n    <nav class=\"home-navbar\" aria-label=\"Main navigation\">\n      <div class=\"home-nav-container\">\n        <div class=\"home-logo\">\n          <a href=\"/\" class=\"logo-link\" aria-label=\"Webx Design Studio - Go to homepage\">\n            <img src=\"/assets/images/logos/webx-logo.svg\" alt=\"Webx Design Studio\" width=\"140\" height=\"40\">\n          </a>\n        </div>\n        <a href=\"/pages/main/contact-page.html\" class=\"home-contact-btn\">\n          <span>CONTACT US</span>\n          <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" aria-hidden=\"true\">\n            <path d=\"M3 13L13 3M13 3H5M13 3V11\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path>\n          </svg>\n        </a>\n      </div>\n    </nav>\n    <div class=\"page-wrapper\">\n      <div class=\"container\">\n        <div class=\"content\">\n          <nav class=\"breadcrumb-nav\" aria-label=\"Breadcrumb\">\n            <a href=\"/\" class=\"breadcrumb-link\">Home</a>\n            <span class=\"breadcrumb-separator\" aria-hidden=\"true\">›</span>\n            <a href=\"/pages/main/work.html\" class=\"breadcrumb-link\">Work</a>\n            <span class=\"breadcrumb-separator\" aria-hidden=\"true\">›</span>\n            <span class=\"breadcrumb-current\" aria-current=\"page\">Morphico</span>\n          </nav>\n          <h1>\n            Where Creativity Transforms Walls into Experiences\n          </h1>\n        </div>\n        <div class=\"mockup-container\">\n          <img src=\"/assets/images/clients/morphico-mockup-hero.svg\" alt=\"Morphico website UI/UX design mockup by Webx Design Studio\" class=\"original-mockup\" width=\"700\" height=\"500\" loading=\"eager\">\n        </div>\n      </div>\n    </div>\n  </section>\n</header>\n\n<main>\n\n<!-- About Section -->\n<section class=\"about-section\" aria-label=\"About Morphico\">\n  <div class=\"about-content\">\n    <h2>About Morphico</h2>\n    <p class=\"about-description\">\n      Morphico is a creative hub for transforming interiors through innovative wall designs and wallpapers. We redesigned their digital presence to match their physical elegance, offering high-quality, customizable solutions that bring personality to any space. Our goal was to redefine how people experience their walls through a seamless online journey.\n    </p>\n    <div class=\"info-grid\">\n      <div class=\"info-item\">\n        <h3>Industries</h3>\n        <p>Wallpapers &amp; Murals</p>\n      </div>\n      <div class=\"info-item\">\n        <h3>Year</h3>\n        <p>2024</p>\n      </div>\n      <div class=\"info-item full-width\">\n        <h3>Services</h3>\n        <p>UI UX Design &amp; Visual Identity</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- Challenge and Solution Section -->\n<section class=\"challenge-solution-section\" aria-label=\"Challenge and solution\">\n  <div class=\"cs-container\">\n    <div class=\"cs-column\">\n      <img src=\"/assets/images/icons/morphico-challenge-icon.svg\" alt=\"\" class=\"cs-icon\" aria-hidden=\"true\" width=\"48\" height=\"48\" loading=\"lazy\" />\n      <h2>The Challenge</h2>\n      <ul class=\"cs-list\">\n        <li>\n          <div class=\"cs-list-content\">\n            <span><strong>Platform Gap:</strong> Lack of an effective online space to showcase unique wall design solutions</span>\n          </div>\n        </li>\n        <li>\n          <div class=\"cs-list-content\">\n            <span><strong>User Connection:</strong> Difficulty engaging homeowners and businesses looking for premium decor</span>\n          </div>\n        </li>\n        <li>\n          <div class=\"cs-list-content\">\n            <span><strong>Visual Friction:</strong> Absence of a modern, cohesive interface that reflects creative expertise</span>\n          </div>\n        </li>\n        <li>\n          <div class=\"cs-list-content\">\n            <span><strong>Brand Edge:</strong> Inability to communicate creativity, leading to a weaker competitive edge</span>\n          </div>\n        </li>\n      </ul>\n    </div>\n    <div class=\"cs-column\">\n      <img src=\"/assets/images/icons/morphico-solution-icon.svg\" alt=\"\" class=\"cs-icon\" aria-hidden=\"true\" width=\"48\" height=\"48\" loading=\"lazy\" />\n      <h2>The Solution</h2>\n      <ul class=\"cs-list\">\n        <li>\n          <div class=\"cs-list-content\">\n            <span><strong>Digital Gallery:</strong> Designed a high-impact website to showcase creative wall solutions effectively</span>\n          </div>\n        </li>\n        <li>\n          <div class=\"cs-list-content\">\n            <span><strong>Intuitive Flow:</strong> Built an interface that allows users to explore and customize designs easily</span>\n          </div>\n        </li>\n        <li>\n          <div class=\"cs-list-content\">\n            <span><strong>Unified Identity:</strong> Developed a consistent digital brand with modern visuals and clear messaging</span>\n          </div>\n        </li>\n        <li>\n          <div class=\"cs-list-content\">\n            <span><strong>Market Reach:</strong> Improved accessibility to help Morphico connect with its target audience</span>\n          </div>\n        </li>\n      </ul>\n    </div>\n  </div>\n</section>\n\n<!-- UX/UI Comparison Section -->\n<section class=\"comparison-section\" aria-label=\"UX versus UI before and after comparison\">\n  <div class=\"comparison-header\" aria-hidden=\"true\">\n    <div class=\"comparison-label\">UX</div>\n    <div class=\"comparison-label\">UI</div>\n  </div>\n  <div class=\"comparison-wrapper\">\n    <div class=\"before-after-container\" style=\"background: #8F5B51;\">\n      <div class=\"before-after-slider\" role=\"group\" aria-label=\"Before and after design comparison slider\">\n        <figure class=\"before-image\">\n          <img src=\"/assets/images/clients/morphico-ux-before.png\" alt=\"Morphico UX wireframe - before redesign\" width=\"800\" height=\"600\" loading=\"lazy\" />\n        </figure>\n        <figure class=\"after-image\">\n          <img src=\"/assets/images/clients/morphico-ui-after.png\" alt=\"Morphico UI design - after redesign\" width=\"800\" height=\"600\" loading=\"lazy\" />\n        </figure>\n        <div class=\"slider-handle\" aria-hidden=\"true\">\n          <div class=\"handle-circle\">\n            <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\">\n              <path d=\"M15 19L8 12L15 5\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            </svg>\n            <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\">\n              <path d=\"M9 5L16 12L9 19\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n            </svg>\n          </div>\n          <div class=\"handle-line\"></div>\n        </div>\n        <input type=\"range\" min=\"0\" max=\"100\" value=\"50\" class=\"slider-input\" id=\"comparison-slider\" aria-label=\"Drag to compare UX and UI designs\" />\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- Visual Identity Section -->\n<section class=\"visual-identity-section\" aria-label=\"Visual identity design\">\n  <div class=\"vi-container\">\n    <div class=\"section-header animate-fade-in\">\n      <p class=\"section-label\">Visual Identity</p>\n      <h2 class=\"section-title\">Design framework bringing creativity to interiors with modern elegance</h2>\n    </div>\n    <div class=\"vi-scroll-wrapper\">\n      <div class=\"vi-grid\" id=\"viGrid\">\n        <div class=\"vi-card\">\n          <div class=\"vi-card-image\">\n            <img src=\"/assets/images/clients/morphico-vi-img-1.jpg\" alt=\"Morphico brand colour palette - balancing artistic expression with luxury\" width=\"400\" height=\"300\" loading=\"lazy\" />\n          </div>\n          <h3 class=\"vi-card-title\">Colour Style</h3>\n          <p class=\"vi-card-description\">We used a palette that balances artistic expression with professional trust. The shades are designed to highlight the wall art while creating a sense of luxury and comfort.</p>\n        </div>\n        <div class=\"vi-card\">\n          <div class=\"vi-card-image\">\n            <img src=\"/assets/images/clients/morphico-vi-img-2.jpg\" alt=\"Morphico iconography - minimal modern icons for navigation\" width=\"400\" height=\"300\" loading=\"lazy\" />\n          </div>\n          <h3 class=\"vi-card-title\">Iconography</h3>\n          <p class=\"vi-card-description\">The icons are minimal and modern, ensuring they guide the user without distracting from the mural designs. Every element focuses on clarity and ease of navigation.</p>\n        </div>\n        <div class=\"vi-card\">\n          <div class=\"vi-card-image\">\n            <img src=\"/assets/images/clients/morphico-vi-img-1.jpg\" alt=\"Morphico typography system - clean modern typefaces for premium brand feel\" width=\"400\" height=\"300\" loading=\"lazy\" />\n          </div>\n          <h3 class=\"vi-card-title\">Typography</h3>\n          <p class=\"vi-card-description\">The typography system was chosen to complement the visual richness of Morphico's wall art. Clean, modern typefaces create hierarchy and guide users through content with clarity and elegance.</p>\n        </div>\n        <div class=\"vi-card\">\n          <div class=\"vi-card-image\">\n            <img src=\"/assets/images/clients/morphico-vi-img-2.jpg\" alt=\"Morphico design system - components and guidelines for consistent experience\" width=\"400\" height=\"300\" loading=\"lazy\" />\n          </div>\n          <h3 class=\"vi-card-title\">Design System</h3>\n          <p class=\"vi-card-description\">A unified design system was built to ensure consistent visual language across every touchpoint. Components, spacing, and interaction patterns were documented to support scalable growth.</p>\n        </div>\n      </div>\n    </div>\n    <div class=\"vi-slider-controls\">\n      <div class=\"vi-progress-bar\" role=\"progressbar\" aria-label=\"Visual identity slider progress\">\n        <div class=\"vi-progress-line\"></div>\n        <div class=\"vi-progress-fill\" id=\"viProgressFill\"></div>\n      </div>\n      <div class=\"vi-navigation\">\n        <button class=\"vi-arrow vi-arrow-left\" id=\"viArrowLeft\" aria-label=\"Previous visual identity slide\">&#8592;</button>\n        <button class=\"vi-arrow vi-arrow-right\" id=\"viArrowRight\" aria-label=\"Next visual identity slide\">&#8594;</button>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- Design System Section -->\n<section class=\"design-system-section\" aria-label=\"Design system\">\n  <div class=\"ds-container\">\n    <div class=\"section-header animate-fade-in\">\n      <p class=\"section-label\">Design System</p>\n      <h2 class=\"section-title\">Smart web interfaces ensuring style, flow, and total usability</h2>\n    </div>\n    <div class=\"ds-image-wrapper\">\n      <img src=\"/assets/images/clients/morphico-ds-1.jpg\" alt=\"Morphico complete design system - components, colours, and spacing guidelines\" class=\"ds-image\" width=\"1200\" height=\"700\" loading=\"lazy\" />\n    </div>\n  </div>\n</section>\n\n<!-- Web UI Section -->\n<section class=\"web-ui-section\" aria-label=\"Web UI designs\">\n  <div class=\"web-ui-container\">\n    <div class=\"section-header animate-fade-in\">\n      <p class=\"section-label\">Web UI</p>\n      <h2 class=\"section-title\">Modern web experiences allowing users to explore designs effortlessly</h2>\n    </div>\n    <div class=\"web-ui-slider-wrapper\">\n      <div class=\"web-ui-slider-container\" id=\"webUiSliderContainer\">\n        <div class=\"web-ui-slider\" id=\"webUiSlider\">\n          <div class=\"web-ui-slide\"><img src=\"/assets/images/clients/morphico-web-ui-1.jpg\" alt=\"Morphico web UI - homepage design\" class=\"web-ui-image\" width=\"900\" height=\"600\" loading=\"lazy\" /></div>\n          <!-- <div class=\"web-ui-slide\"><img src=\"/assets/images/clients/morphico-web-ui-1.jpg\" alt=\"Morphico web UI - product gallery page\" class=\"web-ui-image\" width=\"900\" height=\"600\" loading=\"lazy\" /></div>\n          <div class=\"web-ui-slide\"><img src=\"/assets/images/clients/morphico-web-ui-1.jpg\" alt=\"Morphico web UI - product detail page\" class=\"web-ui-image\" width=\"900\" height=\"600\" loading=\"lazy\" /></div>\n          <div class=\"web-ui-slide\"><img src=\"/assets/images/clients/morphico-web-ui-1.jpg\" alt=\"Morphico web UI - contact and inquiry page\" class=\"web-ui-image\" width=\"900\" height=\"600\" loading=\"lazy\" /></div> -->\n        </div>\n        <button class=\"glass-arrow-btn web-ui-prev\" id=\"webUiPrev\" aria-label=\"Previous web UI slide\">\n          <svg width=\"36\" height=\"36\" viewBox=\"0 0 36 36\" fill=\"none\" aria-hidden=\"true\">\n            <polyline points=\"22,10 13,18 22,26\" stroke=\"#fff\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n          </svg>\n        </button>\n        <button class=\"glass-arrow-btn web-ui-next\" id=\"webUiNext\" aria-label=\"Next web UI slide\">\n          <svg width=\"36\" height=\"36\" viewBox=\"0 0 36 36\" fill=\"none\" aria-hidden=\"true\">\n            <polyline points=\"14,10 23,18 14,26\" stroke=\"#fff\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n          </svg>\n        </button>\n      </div>\n      <div class=\"web-ui-slider-controls\">\n        <div class=\"web-ui-progress-bar\" role=\"progressbar\" aria-label=\"Web UI slider progress\">\n          <div class=\"progress-line\"></div>\n          <div class=\"progress-fill\" id=\"webUiProgressFill\"></div>\n        </div>\n        <div class=\"vi-navigation\">\n          <button class=\"vi-arrow vi-arrow-left\" id=\"webUiBottomPrev\" aria-label=\"Previous web UI slide\">&#8592;</button>\n          <button class=\"vi-arrow vi-arrow-right\" id=\"webUiBottomNext\" aria-label=\"Next web UI slide\">&#8594;</button>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- Mobile UI Section -->\n<section class=\"web-ui-section\" aria-label=\"Mobile UI designs\">\n  <div class=\"web-ui-container\">\n    <div class=\"section-header animate-fade-in\">\n      <p class=\"section-label\">Mobile UI</p>\n      <h2 class=\"section-title\">Mobile-first design putting stylish wall art at your fingertips</h2>\n    </div>\n    <div class=\"web-ui-slider-wrapper\">\n      <div class=\"web-ui-slider-container\" id=\"mobileUiSliderContainer\">\n        <div class=\"web-ui-slider\" id=\"mobileUiSlider\">\n          <div class=\"web-ui-slide\"><img src=\"/assets/images/clients/morphico-mobile-ui-1.jpg\" alt=\"Morphico mobile UI - home screen design\" class=\"web-ui-image\" width=\"400\" height=\"700\" loading=\"lazy\" /></div>\n          <!-- <div class=\"web-ui-slide\"><img src=\"/assets/images/clients/morphico-mobile-ui-1.jpg\" alt=\"Morphico mobile UI - product browse screen\" class=\"web-ui-image\" width=\"400\" height=\"700\" loading=\"lazy\" /></div>\n          <div class=\"web-ui-slide\"><img src=\"/assets/images/clients/morphico-mobile-ui-1.jpg\" alt=\"Morphico mobile UI - product detail screen\" class=\"web-ui-image\" width=\"400\" height=\"700\" loading=\"lazy\" /></div>\n          <div class=\"web-ui-slide\"><img src=\"/assets/images/clients/morphico-mobile-ui-1.jpg\" alt=\"Morphico mobile UI - inquiry and contact screen\" class=\"web-ui-image\" width=\"400\" height=\"700\" loading=\"lazy\" /></div> -->\n        </div>\n        <button class=\"glass-arrow-btn web-ui-prev\" id=\"mobileUiPrev\" aria-label=\"Previous mobile UI slide\">\n          <svg width=\"36\" height=\"36\" viewBox=\"0 0 36 36\" fill=\"none\" aria-hidden=\"true\">\n            <polyline points=\"22,10 13,18 22,26\" stroke=\"#fff\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n          </svg>\n        </button>\n        <button class=\"glass-arrow-btn web-ui-next\" id=\"mobileUiNext\" aria-label=\"Next mobile UI slide\">\n          <svg width=\"36\" height=\"36\" viewBox=\"0 0 36 36\" fill=\"none\" aria-hidden=\"true\">\n            <polyline points=\"14,10 23,18 14,26\" stroke=\"#fff\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n          </svg>\n        </button>\n      </div>\n      <div class=\"web-ui-slider-controls\">\n        <div class=\"web-ui-progress-bar\" role=\"progressbar\" aria-label=\"Mobile UI slider progress\">\n          <div class=\"progress-line\"></div>\n          <div class=\"progress-fill\" id=\"mobileUiProgressFill\"></div>\n        </div>\n        <div class=\"vi-navigation\">\n          <button class=\"vi-arrow vi-arrow-left\" id=\"mobileUiBottomPrev\" aria-label=\"Previous mobile UI slide\">&#8592;</button>\n          <button class=\"vi-arrow vi-arrow-right\" id=\"mobileUiBottomNext\" aria-label=\"Next mobile UI slide\">&#8594;</button>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- Impact and Achievements Section -->\n<section class=\"impact-section animate-section\" aria-label=\"Impact and client testimonial\">\n  <div class=\"impact-container\">\n    <div class=\"section-header animate-fade-in\">\n      <div class=\"section-label\">Impact &amp; Achievements</div>\n      <h2 class=\"section-title\">From vision to impact - a team that delivers consistently</h2>\n    </div>\n    <div class=\"impact-slider-wrapper animate-slider\">\n      <div class=\"impact-slider\" id=\"impactSlider\">\n        <div class=\"impact-slide active\">\n          <div class=\"impact-quote-block\">\n            <img src=\"/assets/images/icons/quote-icon.svg\" alt=\"\" class=\"quote-icon\" aria-hidden=\"true\" width=\"32\" height=\"32\" loading=\"lazy\" />\n            <p class=\"quote-text\">\"The team transformed our digital presence. Their strategic approach and attention to detail resulted in a product that our users absolutely love.\"</p>\n          </div>\n          <div class=\"impact-footer\">\n            <div class=\"author-card\">\n              <img src=\"/assets/images/blogs/auther-imag-ab.png\" alt=\"Archit Sankhe, Founder of Morphico\" class=\"author-photo\" width=\"56\" height=\"56\" loading=\"lazy\" />\n              <div class=\"author-info\">\n                <div class=\"author-name\">Archit Sankhe</div>\n                <div class=\"author-title\">Founder, Morphico</div>\n              </div>\n            </div>\n            <div class=\"brand-logo\" style=\"background: linear-gradient(120deg, #ad6c5f 0%, #8F5B51 100%);\">\n              <img src=\"/assets/images/clients/morphico-logo.png\" alt=\"Morphico Logo\" width=\"100\" height=\"50\" loading=\"lazy\" />\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- Next Work Section -->\n<section class=\"next-work-section\" aria-label=\"Explore more case studies\">\n  <div class=\"next-work-container\">\n    <h2 class=\"next-work-heading\">EXPLORE MORE WORK</h2>\n    <div class=\"next-work-scroll-wrapper\">\n      <div class=\"next-work-grid\" id=\"nextWorkGrid\">\n\n        <a href=\"/pages/details/tictax-pdp.html\" class=\"next-work-card\" style=\"background-image: url('/assets/images/banners/tictax-hero-banner.png');\">\n          <div class=\"card-content\">\n            <h3 class=\"card-title\">TicTax: Simplifying Tax for Everyone</h3>\n            <p class=\"card-description\">A clean fintech interface designed to turn complex tax processes into smooth digital experiences. This strategic approach successfully boosted user conversion rates by over 200%.</p>\n            <div class=\"card-tags\">\n              <span class=\"card-tag\">User Interface Design</span>\n              <span class=\"card-tag\">User Experience Design</span>\n            </div>\n          </div>\n          <div class=\"card-mockup\">\n            <img src=\"/assets/images/clients/tictax-mockup.svg\" alt=\"TicTax - tax simplification app UI/UX case study\" class=\"mockup-image mecon-logo\" width=\"200\" height=\"120\" loading=\"lazy\" />\n          </div>\n        </a>\n\n        <a href=\"/pages/details/ab-pdp.html\" class=\"next-work-card\" style=\"background-image: url('/assets/images/banners/ab-hero-banner.png');\">\n          <div class=\"card-content\">\n            <h3 class=\"card-title\">Arogya Bharat: Health for All</h3>\n            <p class=\"card-description\">Simplifying healthcare navigation through clear, accessible, and user-first digital journeys. This professional platform bridges the gap between complex medical instruments and intuitive usability.</p>\n            <div class=\"card-tags\">\n              <span class=\"card-tag\">User Interface Design</span>\n              <span class=\"card-tag\">User Experience Design</span>\n            </div>\n          </div>\n          <div class=\"card-mockup\">\n            <img src=\"/assets/images/clients/ab-mockup.svg\" alt=\"Arogya Bharat - healthcare platform UI/UX case study\" class=\"mockup-image mecon-logo\" width=\"200\" height=\"120\" loading=\"lazy\" />\n          </div>\n        </a>\n\n        <a href=\"/pages/details/mecon-pdp.html\" class=\"next-work-card\" style=\"background-image: url('/assets/images/clients/mecon-hero-banner-bg.png');\">\n          <div class=\"card-content\">\n            <h3 class=\"card-title\">Mecon: Industrial Precision, Digital Clarity</h3>\n            <p class=\"card-description\">Transforming a complex industrial brand into a clean, navigable digital experience. A structured information hierarchy communicates technical expertise without overwhelming the user.</p>\n            <div class=\"card-tags\">\n              <span class=\"card-tag\">User Interface Design</span>\n              <span class=\"card-tag\">User Experience Design</span>\n            </div>\n          </div>\n          <div class=\"card-mockup\">\n            <img src=\"/assets/images/clients/mecon-mockup.svg\" alt=\"Mecon - industrial brand digital experience case study\" class=\"mockup-image mecon-logo\" width=\"200\" height=\"120\" loading=\"lazy\" />\n          </div>\n        </a>\n\n        <a href=\"/pages/details/gurukrupa-pdp.html\" class=\"next-work-card\" style=\"background-image: url('/assets/images/clients/gurukrupa-hero-banner-bg.png');\">\n          <div class=\"card-content\">\n            <h3 class=\"card-title\">Gurukrupa: Forging Engineering Excellence</h3>\n            <p class=\"card-description\">A visual identity rooted in geometric accuracy and industrial strength for high-precision manufacturing. The design system unifies a diverse parts catalog under one professional, global brand.</p>\n            <div class=\"card-tags\">\n              <span class=\"card-tag\">User Interface Design</span>\n              <span class=\"card-tag\">User Experience Design</span>\n            </div>\n          </div>\n          <div class=\"card-mockup\">\n            <img src=\"/assets/images/clients/gurukrupa-mockup.svg\" alt=\"Gurukrupa - engineering brand visual identity case study\" class=\"mockup-image mecon-logo\" width=\"200\" height=\"120\" loading=\"lazy\" />\n          </div>\n        </a>\n\n        <a href=\"/pages/details/manglam-pdp.html\" class=\"next-work-card\" style=\"background-image: url('/assets/images/clients/manglam-hero-banner-bg.png');\">\n          <div class=\"card-content\">\n            <h3 class=\"card-title\">Manglam: Converting Through Clarity</h3>\n            <p class=\"card-description\">Reimagining financial consultancy with a modern identity that symbolizes stability and growth. Reorganized messaging makes complex taxation and loan services accessible and trustworthy for every client.</p>\n            <div class=\"card-tags\">\n              <span class=\"card-tag\">User Interface Design</span>\n              <span class=\"card-tag\">User Experience Design</span>\n            </div>\n          </div>\n          <div class=\"card-mockup\">\n            <img src=\"/assets/images/clients/manglam-mockup.svg\" alt=\"Manglam - financial consultancy brand identity case study\" class=\"mockup-image mecon-logo\" width=\"200\" height=\"120\" loading=\"lazy\" />\n          </div>\n        </a>\n\n        <a href=\"/pages/details/de-pdp.html\" class=\"next-work-card\" style=\"background-image: url('/assets/images/banners/de-hero-banner-bg.png');\">\n          <div class=\"card-content\">\n            <h3 class=\"card-title\">Dharmesh Enterprises: Empowering Business Growth</h3>\n            <p class=\"card-description\">A unified management application designed to streamline fragmented workflows and operational chaos. The result is a simple, powerful tool that provides entrepreneurs with total clarity and control.</p>\n            <div class=\"card-tags\">\n              <span class=\"card-tag\">User Interface Design</span>\n              <span class=\"card-tag\">User Experience Design</span>\n            </div>\n          </div>\n          <div class=\"card-mockup\">\n            <img src=\"/assets/images/clients/de-mockup.png\" alt=\"Dharmesh Enterprises - business management app UI/UX case study\" class=\"mockup-image mecon-logo\" width=\"200\" height=\"120\" loading=\"lazy\" />\n          </div>\n        </a>\n\n      </div>\n    </div>\n    <div class=\"web-ui-slider-controls\">\n      <div class=\"web-ui-progress-bar\" role=\"progressbar\" aria-label=\"More work slider progress\">\n        <div class=\"progress-line\"></div>\n        <div class=\"progress-fill\" id=\"nwProgress\"></div>\n      </div>\n      <div class=\"vi-navigation\">\n        <button class=\"vi-arrow vi-arrow-left\" id=\"nwPrev\" aria-label=\"Previous work\">&#8592;</button>\n        <button class=\"vi-arrow vi-arrow-right\" id=\"nwNext\" aria-label=\"Next work\">&#8594;</button>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- CTA Banner Section -->\n<section class=\"cta-banner-section\" aria-label=\"Start your project\">\n  <div class=\"cta-banner-content\">\n    <h2 class=\"cta-banner-title\">Ready to build something meaningful?</h2>\n    <a href=\"/pages/main/contact-page.html\" class=\"cta-banner-button\">\n      <span>START YOUR PROJECT</span>\n      <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\">\n        <path d=\"M7 17L17 7M17 7H7M17 7V17\" />\n      </svg>\n    </a>\n  </div>\n</section>\n\n</main>\n\n<!-- Footer Section -->\n<footer class=\"footer-section\" aria-label=\"Site footer\">\n  <div class=\"footer-container\">\n    <div class=\"footer-top\">\n      <div class=\"footer-logo\">\n        <img src=\"/assets/images/logos/webx-logo.svg\" alt=\"Webx Design Studio\" class=\"footer-logo-img\" width=\"140\" height=\"40\" loading=\"lazy\" />\n      </div>\n      <div class=\"footer-social\">\n        <a href=\"https://www.linkedin.com/in/piyushgohil8889/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"social-icon\" aria-label=\"Webx Design Studio on LinkedIn\">\n          <img src=\"/assets/images/icons/linkedin-icon.png\" alt=\"LinkedIn\" class=\"social-icon-img\" width=\"24\" height=\"24\" loading=\"lazy\" />\n        </a>\n        <a href=\"https://dribbble.com/desinger8889\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"social-icon\" aria-label=\"Webx Design Studio on Dribbble\">\n          <img src=\"/assets/images/icons/dribbble-icon.png\" alt=\"Dribbble\" class=\"social-icon-img\" width=\"24\" height=\"24\" loading=\"lazy\" />\n        </a>\n        <a href=\"https://www.behance.net/Piyushgohil8889\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"social-icon\" aria-label=\"Webx Design Studio on Behance\">\n          <img src=\"/assets/images/icons/behance-icon.png\" alt=\"Behance\" class=\"social-icon-img\" width=\"24\" height=\"24\" loading=\"lazy\" />\n        </a>\n      </div>\n    </div>\n    <div class=\"footer-section-block\">\n      <h3 class=\"footer-heading\">\n        Services\n        <button class=\"footer-toggle\" aria-label=\"Toggle Services menu\" aria-expanded=\"false\">\n          <span class=\"accordion-arrow-circle\">\n            <svg class=\"arrow-svg\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http:/www.w3.org/2000/svg\" aria-hidden=\"true\">\n              <path d=\"M5 12H19M19 12L12 5M19 12L12 19\" stroke=\"black\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke