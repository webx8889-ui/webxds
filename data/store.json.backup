        {
          "type": "static",
          "html": "<div class=\"more-menu-overlay\" id=\"moreMenu\" role=\"dialog\" aria-modal=\"true\" aria-label=\"Full navigation menu\">\r\n        <div class=\"more-menu-inner\">\r\n            <div class=\"more-menu-left\">\r\n                <div class=\"more-menu-column\"> <a href=\"/\" class=\"more-link\"><span\r\n                            class=\"more-link-label\">Home</span></a> <a href=\"/pages/main/work.html\"\r\n                        class=\"more-link\"><span class=\"more-link-label\">Work</span></a> <a\r\n                        href=\"/pages/main/services.html\" class=\"more-link\"><span\r\n                            class=\"more-link-label\">Services</span></a> <a href=\"/pages/main/faq.html\"\r\n                        class=\"more-link\"><span class=\"more-link-label\">FAQ</span></a> </div>\r\n                <div class=\"more-menu-column\"> <a href=\"/pages/main/about.html\" class=\"more-link\"><span\r\n                            class=\"more-link-label\">About</span></a> <a href=\"/pages/blogs/blogs.html\"\r\n                        class=\"more-link\"><span class=\"more-link-label\">Blog</span></a> <a\r\n                        href=\"/pages/main/contact-page.html\" class=\"more-link\"><span\r\n                            class=\"more-link-label\">Contact</span></a> <a href=\"/pages/legal/term-condition.html\"\r\n                        class=\"more-link\"><span class=\"more-link-label\">Term &amp; Conditions</span></a> <a\r\n                        href=\"/pages/legal/privacy-policy.html\" class=\"more-link\"><span class=\"more-link-label\">Privacy\r\n                            Policy</span></a> </div>\r\n            </div>\r\n            <aside class=\"more-menu-right\">\r\n                <div class=\"more-cta-content\">\r\n                    <h2 class=\"more-cta-title\"> Ready to build something meaningful? </h2>\r\n                    <p class=\"more-cta-sub\">Let's take your vision and turn it into a high-performing digital reality.\r\n                    </p> <a href=\"/pages/main/contact-page.html\" class=\"more-cta-button\"> <span>CONTACT US</span> <svg\r\n                            width=\"18\" height=\"18\" viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http:/www.w3.org/2000/svg\"\r\n                            aria-hidden=\"true\">\r\n                            <path d=\"M3 13L13 3M13 3H5M13 3V11\" stroke=\"currentColor\" stroke-width=\"2\"\r\n                                stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                        </svg> </a>\r\n                </div>\r\n            </aside>\r\n        </div>\r\n    </div>"
        },
