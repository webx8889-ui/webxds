      "meta": "Explore Webx Design Studio services - UI/UX design, website development, app design, branding, pitch decks, social media creatives, emailers, and SaaS dashboards.",
      "displayName": "Services",
      "summary": "main page • 7 editable sections",
      "templateStart": "<!DOCTYPE html>\r\n<html lang=\"en\">\r\n\r\n<head>\r\n    <meta charset=\"UTF-8\" />\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\r\n    <title>Our Services | UI/UX Design, Web &amp; App Development | Webx Design Studio</title>\r\n    <meta name=\"description\"\r\n        content=\"Explore Webx Design Studio services - UI/UX design, website development, app design, branding, pitch decks, social media creatives, emailers, and SaaS dashboards.\" />\r\n    <meta name=\"robots\" content=\"index, follow\" />\r\n    <meta name=\"author\" content=\"Webx Design Studio\" />\r\n    <meta name=\"theme-color\" content=\"#ff6b00\" />\r\n    <link rel=\"canonical\" href=\"https://webxds.com/pages/main/services.html\" />\r\n    <meta property=\"og:type\" content=\"website\" />\r\n    <meta property=\"og:title\" content=\"Our Services | UI/UX Design, Web &amp; App Development | Webx Design Studio\" />\r\n    <meta property=\"og:description\"\r\n        content=\"Explore Webx Design Studio services - UI/UX design, website development, app design, branding, pitch decks, social media creatives, emailers, and SaaS dashboards.\" />\r\n    <meta property=\"og:url\" content=\"https://webxds.com/pages/main/services.html\" />\r\n    <meta property=\"og:image\" content=\"https://webxds.com/assets/images/others/webx-og-image.png\" />\r\n    <meta property=\"og:image:width\" content=\"1200\" />\r\n    <meta property=\"og:image:height\" content=\"630\" />\r\n    <meta property=\"og:image:alt\" content=\"Webx Design Studio - UI/UX Design Services\" />\r\n    <meta property=\"og:site_name\" content=\"Webx Design Studio\" />\r\n    <meta property=\"og:locale\" content=\"en_IN\" />\r\n    <meta name=\"twitter:card\" content=\"summary_large_image\" />\r\n    <meta name=\"twitter:title\" content=\"Our Services | UI/UX Design, Web &amp; App Development | Webx Design Studio\" />\r\n    <meta name=\"twitter:description\"\r\n        content=\"Explore Webx Design Studio services - UI/UX design, website development, app design, branding, pitch decks, social media creatives, emailers, and SaaS dashboards.\" />\r\n    <meta name=\"twitter:image\" content=\"https://webxds.com/assets/images/others/webx-og-image.png\" />\r\n    <meta name=\"twitter:image:alt\" content=\"Webx Design Studio - UI/UX Design Services\" />\r\n    <link rel=\"icon\" href=\"/assets/images/icons/favicon.png\" type=\"image/png\" sizes=\"32x32\" />\r\n    <link rel=\"apple-touch-icon\" href=\"/assets/images/icons/favicon-180.png\" sizes=\"180x180\" />\r\n    <link rel=\"manifest\" href=\"/manifest.json\" />\r\n    <link rel=\"stylesheet\" href=\"/css/style.css\" />\r\n    <link rel=\"preload\" href=\"/assets/images/hero/hero-mockup.jpg\" as=\"image\" />\r\n    <script\r\n        type=\"application/ld+json\">{  \"@context\": \"https://schema.org\",  \"@type\": \"Organization\",  \"name\": \"Webx Design Studio\",  \"url\": \"https://webxds.com\",  \"logo\": \"https://webxds.com/assets/images/logos/webx-logo.svg\",  \"description\": \"UI/UX design agency India specializing in websites, apps, full-stack development and digital products.\",  \"address\": {    \"@type\": \"PostalAddress\",    \"addressCountry\": \"IN\",    \"addressRegion\": \"Gujarat\"  },  \"sameAs\": [    \"https://www.linkedin.com/in/piyushgohil8889\",    \"https://dribbble.com/desinger8889\",    \"https://www.behance.net/Piyushgohil8889\"  ]}</script>\r\n    <script\r\n        type=\"application/ld+json\">{  \"@context\": \"https://schema.org\",  \"@type\": \"BreadcrumbList\",  \"itemListElement\": [    {      \"@type\": \"ListItem\",      \"position\": 1,      \"name\": \"Home\",      \"item\": \"https://webxds.com/\"    },    {      \"@type\": \"ListItem\",      \"position\": 2,      \"name\": \"Services\",      \"item\": \"https://webxds.com/pages/main/services.html\"    }  ]}</script>\r\n    <script\r\n        type=\"application/ld+json\">{  \"@context\": \"https://schema.org\",  \"@type\": \"Service\",  \"serviceType\": \"UI/UX Design & Web Development\",  \"provider\": {    \"@type\": \"Organization\",    \"name\": \"Webx Design Studio\",    \"url\": \"https://webxds.com\"  },  \"hasOfferCatalog\": {    \"@type\": \"OfferCatalog\",    \"name\": \"Webx Design Studio Services\",    \"itemListElement\": [      { \"@type\": \"Offer\", \"itemOffered\": { \"@type\": \"Service\", \"name\": \"Website Design & Development\" } },      { \"@type\": \"Offer\", \"itemOffered\": { \"@type\": \"Service\", \"name\": \"Mobile & Web App Design\" } },      { \"@type\": \"Offer\", \"itemOffered\": { \"@type\": \"Service\", \"name\": \"Brand Identity & Logo Design\" } },      { \"@type\": \"Offer\", \"itemOffered\": { \"@type\": \"Service\", \"name\": \"Pitch Deck & Document Design\" } },      { \"@type\": \"Offer\", \"itemOffered\": { \"@type\": \"Service\", \"name\": \"Social Media Creatives\" } },      { \"@type\": \"Offer\", \"itemOffered\": { \"@type\": \"Service\", \"name\": \"Marketing Emailer Design\" } },      { \"@type\": \"Offer\", \"itemOffered\": { \"@type\": \"Service\", \"name\": \"SaaS Dashboard & Custom Tools\" } }    ]  }}</script>\r\n</head>\r\n\r\n<body>",
