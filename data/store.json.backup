      "templateStart": "<!DOCTYPE html>\r\n<html lang=\"en\">\r\n\r\n<head>\r\n  <meta charset=\"UTF-8\" />\r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\r\n  <title>Start Your Project | Service Request Form | Webx Design Studio</title>\r\n  <meta name=\"description\" content=\"Tell us about your project. Fill out our service request form and the Webx Design Studio team will craft a tailored solution for your business needs.\" />\r\n  <link rel=\"canonical\" href=\"https://webxds.com/pages/system/service-form.html\" />\r\n  <meta name=\"robots\" content=\"noindex, follow\" />\r\n  <link rel=\"stylesheet\" href=\"/css/style.css\">\r\n  <link rel=\"icon\" href=\"/assets/images/icons/favicon.svg\" type=\"image/x-icon\">\r\n  <script src=\"https://www.google.com/recaptcha/api.js\" async defer></script>\r\n  <script type=\"text/javascript\" src=\"https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js\">\r\n  </script>\r\n</head>\r\n\r\n<body>",
      "templateEnd": "</body>\r\n\r\n</html>\r\n\r\n\r\n\r\n\r\n\r\n\r\n",
