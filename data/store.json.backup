      "meta": "Explore all Webx Design Studio blogs in one place. Read practical insights on UX, UI, CRO, website redesign, and product design strategy.",
      "displayName": "Blogs",
      "summary": "blogs page • 4 editable sections",
      "templateStart": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>Blogs | Webx Design Studio - UX, UI, CRO and Design Insights</title>\n  <meta name=\"description\" content=\"Explore all Webx Design Studio blogs in one place. Read practical insights on UX, UI, CRO, website redesign, and product design strategy.\" />\n  <meta name=\"robots\" content=\"index, follow\" />\n  <meta name=\"author\" content=\"Webx Design Studio\" />\n  <meta name=\"theme-color\" content=\"#ff6b00\" />\n  <link rel=\"canonical\" href=\"https://webxds.com/pages/blogs/blogs.html\" />\n\n  <meta property=\"og:type\" content=\"website\" />\n  <meta property=\"og:title\" content=\"Blogs | Webx Design Studio\" />\n  <meta property=\"og:description\" content=\"Read all Webx Design Studio blog posts on UX, UI, CRO, and digital product strategy.\" />\n  <meta property=\"og:url\" content=\"https://webxds.com/pages/blogs/blogs.html\" />\n  <meta property=\"og:image\" content=\"https://webxds.com/assets/images/others/webx-og-image.png\" />\n  <meta property=\"og:image:width\" content=\"1200\" />\n  <meta property=\"og:image:height\" content=\"630\" />\n  <meta property=\"og:image:alt\" content=\"Webx Design Studio blogs and design insights\" />\n  <meta property=\"og:site_name\" content=\"Webx Design Studio\" />\n  <meta property=\"og:locale\" content=\"en_IN\" />\n\n  <meta name=\"twitter:card\" content=\"summary_large_image\" />\n  <meta name=\"twitter:title\" content=\"Blogs | Webx Design Studio\" />\n  <meta name=\"twitter:description\" content=\"Read all Webx Design Studio blog posts on UX, UI, CRO, and digital product strategy.\" />\n  <meta name=\"twitter:image\" content=\"https://webxds.com/assets/images/others/webx-og-image.png\" />\n  <meta name=\"twitter:image:alt\" content=\"Webx Design Studio blogs and design insights\" />\n\n  <link rel=\"icon\" href=\"/assets/images/icons/favicon.png\" type=\"image/png\" sizes=\"32x32\" />\n  <link rel=\"apple-touch-icon\" href=\"/assets/images/icons/favicon-180.png\" sizes=\"180x180\" />\n  <link rel=\"manifest\" href=\"/manifest.json\" />\n  <link rel=\"stylesheet\" href=\"/css/style.css\" />\n\n  <script type=\"application/ld+json\">\n  {\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"CollectionPage\",\n    \"name\": \"Webx Design Studio Blogs\",\n    \"description\": \"All blog posts published by Webx Design Studio.\",\n    \"url\": \"https://webxds.com/pages/blogs/blogs.html\",\n    \"publisher\": {\n      \"@type\": \"Organization\",\n      \"name\": \"Webx Design Studio\",\n      \"url\": \"https://webxds.com\"\n    }\n  }\n  </script>\n\n  <script type=\"application/ld+json\">\n  {\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"BreadcrumbList\",\n    \"itemListElement\": [\n      {\n        \"@type\": \"ListItem\",\n        \"position\": 1,\n        \"name\": \"Home\",\n        \"item\": \"https://webxds.com/\"\n      },\n      {\n        \"@type\": \"ListItem\",\n        \"position\": 2,\n        \"name\": \"Blogs\",\n        \"item\": \"https://webxds.com/pages/blogs/blogs.html\"\n      }\n    ]\n  }\n  </script>\n\n  <style>\n\n    :root{\n  --c-bg-hero:#FEA800;\n  --c-bg-black:#000000;\n  --c-white:#ffffff;\n  --c-muted:#b8b8b8;\n  --c-line:#2a2a2a;\n  --c-accent:#FEA800;\n  --space-x: clamp(20px, 4vw, 105px);\n  --space-y: clamp(24px, 5vw, 78px);\n  --radius: 0px;\n  --shadow-lg: 0 30px 60px rgba(0,0,0,.4);\n  --max-content-width: 1440px;\n  --navbar-height: clamp(70px, 10vw, 120px);\n}\n\n    .blogs-list-section {\n      padding: var(--space-y) var(--space-x);\n    }\n\n    .blogs-list-container {\n      max-width: var(--max-content-width);\n      margin: 0 auto;\n    }\n\n    .blogs-page-title {\n      margin: 0 0 12px;\n      text-transform: uppercase;\n      letter-spacing: 0.02em;\n    }\n\n    .blogs-page-subtitle {\n      margin: 0 0 28px;\n      max-width: 780px;\n      color: #a5a5a5;\n      line-height: 1.6;\n      font-size: 16px;\n    }\n\n    .blogs-grid {\n      display: grid;\n      grid-template-columns: repeat(2, minmax(0, 1fr));\n      gap: 36px;\n    }\n\n    .blogs-grid .blog-card {\n      height: 100%;\n      display: flex;\n      flex-direction: column;\n    }\n      .blog-card {  \n        max-width: 90%;\n    }\n    \n\n    .blogs-grid .blog-content {\n      flex: 1;\n      display: flex;\n      flex-direction: column;\n    }\n\n    .blogs-grid .blog-excerpt {\n      flex: 1;\n    }\n\n    @media (max-width: 960px) {\n      .blogs-grid {\n        grid-template-columns: 1fr;\n      }\n\n    }\n  </style>\n</head>\n<body>",
