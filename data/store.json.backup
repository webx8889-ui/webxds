      "sections": [
        {
          "id": "blogs-section-60d0122c",
          "label": "Blogs page header",
          "enabled": true,
          "html": "<header>\n    <section class=\"service-hero-section\" aria-label=\"Blogs page header\">\n      <nav class=\"home-navbar\" aria-label=\"Main navigation\">\n        <div class=\"home-nav-container\">\n          <div class=\"home-logo\">\n            <a href=\"/\" class=\"logo-link\" aria-label=\"Webx Design Studio - Go to homepage\">\n              <img src=\"/assets/images/logos/webx-logo.svg\" alt=\"Webx Design Studio\" width=\"140\" height=\"40\" />\n            </a>\n          </div>\n          <a href=\"/pages/main/contact-page.html\" class=\"home-contact-btn\">\n            <span>CONTACT US</span>\n            <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" aria-hidden=\"true\">\n              <path d=\"M3 13L13 3M13 3H5M13 3V11\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n            </svg>\n          </a>\n        </div>\n      </nav>\n    </section>\n  </header>"
        },
        {
          "id": "blogs-section-585ccd46",
          "label": "All blog posts",
          "enabled": true,
          "html": "<section class=\"blogs-list-section\" aria-label=\"All blog posts\">\n      <div class=\"blogs-list-container\">\n        <div class=\"section-header\">\n          <p class=\"section-label\">All Articles</p>\n          <h1 class=\"section-title blogs-page-title\">Insights on UX, UI, and Growth</h1>\n        </div>\n        <p class=\"blogs-page-subtitle\">\n          Explore all blogs from Webx Design Studio. These posts break down practical strategies for digital product design, conversion-focused experiences, and modern UI systems.\n        </p>\n\n        <div class=\"blogs-grid\">\n          <article class=\"blog-card\">\n            <div class=\"blog-image\">\n              <img src=\"/assets/images/blogs/blog-img-1.png\" alt=\"AI-Driven Personalization in UI/UX Design 2026 - featured image\" width=\"400\" height=\"240\" loading=\"lazy\" />\n            </div>\n            <div class=\"blog-content\">\n              <h2 class=\"blog-card-title\">AI-Driven Personalization: The UX/UI Design Trend Your Business Cannot Ignore in 2026</h2>\n              <div class=\"blog-meta\">\n                <div class=\"blog-tags\">\n                  <span class=\"blog-tag\">ai powered user interfaces</span>\n                  <span class=\"blog-tag\">does ux affect seo</span>\n                  <span class=\"blog-tag\">2026 ux ui design trends</span>\n                </div>\n                <span class=\"blog-date\"><time datetime=\"2025-04-16\">Date: 16 Apr 25</time></span>\n              </div>\n              <p class=\"blog-excerpt\">In 2026, UX/UI design has shifted from one-layout-for-all toward interfaces that adapt to user behavior and intent.</p>\n              <a href=\"/pages/blogs/blog.html\" class=\"blog-read-more\" aria-label=\"Read AI-Driven Personalization blog\">\n                <span>READ MORE</span>\n                <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" aria-hidden=\"true\">\n                  <path d=\"M3 13L13 3M13 3H5M13 3V11\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n                </svg>\n              </a>\n            </div>\n          </article>\n\n          <article class=\"blog-card\">\n            <div class=\"blog-image\">\n              <img src=\"/assets/images/blogs/blog-img-2.png\" alt=\"Apple Design Study UX Lessons 2026 - featured image\" width=\"400\" height=\"240\" loading=\"lazy\" />\n            </div>\n            <div class=\"blog-content\">\n              <h2 class=\"blog-card-title\">Apple Design Study: 10 UX Lessons You Can Apply to Your Products in 2026</h2>\n              <div class=\"blog-meta\">\n                <div class=\"blog-tags\">\n                  <span class=\"blog-tag\">apple design study</span>\n                  <span class=\"blog-tag\">apple ux case study</span>\n                  <span class=\"blog-tag\">ios design principles</span>\n                </div>\n                <span class=\"blog-date\"><time datetime=\"2025-04-16\">Date: 16 Apr 25</time></span>\n              </div>\n              <p class=\"blog-excerpt\">A practical breakdown of product clarity, hierarchy, motion, and design consistency inspired by Apple interfaces.</p>\n              <a href=\"/pages/blogs/blog-apple.html\" class=\"blog-read-more\" aria-label=\"Read Apple Design Study blog\">\n                <span>READ MORE</span>\n                <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" aria-hidden=\"true\">\n                  <path d=\"M3 13L13 3M13 3H5M13 3V11\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n                </svg>\n              </a>\n            </div>\n          </article>\n\n          <article class=\"blog-card\">\n            <div class=\"blog-image\">\n              <img src=\"/assets/images/blogs/blog-img-3.png\" alt=\"High-converting landing page UX and CRO guide - featured image\" width=\"400\" height=\"240\" loading=\"lazy\" />\n            </div>\n            <div class=\"blog-content\">\n              <h2 class=\"blog-card-title\">How to Design a High-Converting Landing Page in 2026: UX and CRO Complete Guide</h2>\n              <div class=\"blog-meta\">\n                <div class=\"blog-tags\">\n                  <span class=\"blog-tag\">high converting landing page</span>\n                  <span class=\"blog-tag\">landing page ux design</span>\n                  <span class=\"blog-tag\">conversion rate optimization</span>\n                </div>\n                <span class=\"blog-date\"><time datetime=\"2026-02-18\">Date: 18 Feb 26</time></span>\n              </div>\n              <p class=\"blog-excerpt\">A complete guide to CTA hierarchy, trust signals, mobile UX, and practical conversion optimization for landing pages.</p>\n              <a href=\"/pages/blogs/blog-3.html\" class=\"blog-read-more\" aria-label=\"Read high-converting landing page blog\">\n                <span>READ MORE</span>\n                <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" aria-hidden=\"true\">\n                  <path d=\"M3 13L13 3M13 3H5M13 3V11\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n                </svg>\n              </a>\n            </div>\n          </article>\n\n          <article class=\"blog-card\">\n            <div class=\"blog-image\">\n              <img src=\"/assets/images/blogs/blog-img-4.png\" alt=\"Website redesign checklist 2026 - featured image\" width=\"400\" height=\"240\" loading=\"lazy\" />\n            </div>\n            <div class=\"blog-content\">\n              <h2 class=\"blog-card-title\">10 Signs It Is Time to Redesign Your Website in 2026: Full Redesign Checklist</h2>\n              <div class=\"blog-meta\">\n                <div class=\"blog-tags\">\n                  <span class=\"blog-tag\">website redesign 2026</span>\n                  <span class=\"blog-tag\">when to redesign website</span>\n                  <span class=\"blog-tag\">website redesign checklist</span>\n                </div>\n                <span class=\"blog-date\"><time datetime=\"2026-02-18\">Date: 18 Feb 26</time></span>\n              </div>\n              <p class=\"blog-excerpt\">Learn the warning signals that your current website is slowing growth, and use this redesign checklist to plan the next version.</p>\n              <a href=\"/pages/blogs/blog-4.html\" class=\"blog-read-more\" aria-label=\"Read website redesign checklist blog\">\n                <span>READ MORE</span>\n                <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\" aria-hidden=\"true\">\n                  <path d=\"M3 13L13 3M13 3H5M13 3V11\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n                </svg>\n              </a>\n            </div>\n          </article>\n        </div>\n      </div>\n    </section>"
        },
        {
          "id": "blogs-section-2cbe69f1",
          "label": "Site footer",
          "enabled": true,
          "html": "<footer class=\"footer-section\" aria-label=\"Site footer\">\n    <div class=\"footer-container\">\n      <div class=\"footer-top\">\n        <div class=\"footer-logo\">\n          <img src=\"/assets/images/logos/webx-logo.svg\" alt=\"Webx Design Studio\" class=\"footer-logo-img\" width=\"140\" height=\"40\" loading=\"lazy\" />\n        </div>\n        <div class=\"footer-social\">\n          <a href=\"https://www.linkedin.com/in/piyushgohil8889/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"social-icon\" aria-label=\"Webx Design Studio on LinkedIn\">\n            <img src=\"/assets/images/icons/linkedin-icon.png\" alt=\"LinkedIn\" class=\"social-icon-img\" width=\"24\" height=\"24\" loading=\"lazy\" />\n          </a>\n          <a href=\"https://dribbble.com/desinger8889\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"social-icon\" aria-label=\"Webx Design Studio on Dribbble\">\n            <img src=\"/assets/images/icons/dribbble-icon.png\" alt=\"Dribbble\" class=\"social-icon-img\" width=\"24\" height=\"24\" loading=\"lazy\" />\n          </a>\n          <a href=\"https://www.behance.net/Piyushgohil8889\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"social-icon\" aria-label=\"Webx Design Studio on Behance\">\n            <img src=\"/assets/images/icons/behance-icon.png\" alt=\"Behance\" class=\"social-icon-img\" width=\"24\" height=\"24\" loading=\"lazy\" />\n          </a>\n        </div>\n      </div>\n\n      <div class=\"footer-section-block\">\n        <h3 class=\"footer-heading\">\n          Services\n          <button class=\"footer-toggle\" aria-label=\"Toggle Services menu\" aria-expanded=\"false\">\n            <span class=\"accordion-arrow-circle\">\n              <svg class=\"arrow-svg\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http:/www.w3.org/2000/svg\" aria-hidden=\"true\">\n                <path d=\"M5 12H19M19 12L12 5M19 12L12 19\" stroke=\"black\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n              </svg>\n            </span>\n          </button>\n        </h3>\n        <div class=\"footer-links\">\n          <a href=\"/pages/main/services.html\">UI/UX Design</a>\n          <a href=\"/pages/main/services.html\">Web Design</a>\n          <a href=\"/pages/main/services.html\">App Design</a>\n          <a href=\"/pages/main/services.html\">Marketing Emailer</a>\n          <a href=\"/pages/main/services.html\">Social Media</a>\n          <a href=\"/pages/main/services.html\">Logo Design</a>\n          <a href=\"/pages/main/services.html\">Graphics Design</a>\n          <a href=\"/pages/main/services.html\">Tool Design</a>\n          <a href=\"/pages/main/services.html\">Document Design</a>\n          <a href=\"/pages/main/services.html\">ETC Design</a>\n        </div>\n      </div>\n\n      <div class=\"footer-section-block\">\n        <h3 class=\"footer-heading\">\n          Company\n          <button class=\"footer-toggle\" aria-label=\"Toggle Company menu\" aria-expanded=\"false\">\n            <span class=\"accordion-arrow-circle\">\n              <svg class=\"arrow-svg\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http:/www.w3.org/2000/svg\" aria-hidden=\"true\">\n                <path d=\"M5 12H19M19 12L12 5M19 12L12 19\" stroke=\"black\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" />\n              </svg>\n            </span>\n          </button>\n        </h3>\n        <div class=\"footer-links\">\n          <a href=\"/pages/main/about.html\">About Us</a>\n          <a href=\"/pages/blogs/blogs.html\">Blog</a>\n          <a href=\"/pages/main/contact-page.html\">Contact</a>\n          <a href=\"/pages/legal/privacy-policy.html\">Privacy Policy</a>\n          <a href=\"/pages/legal/term-condition.html\">Terms of Service</a>\n        </div>\n      </div>\n\n      <div class=\"footer-bottom\">\n        <p class=\"footer-copyright\">&copy; 2026 Webx Design Studio. All rights reserved</p>\n      </div>\n    </div>\n    <div class=\"footer-bg-text\" aria-hidden=\"true\">\n      <img src=\"/assets/images/logos/webx-footer-logo-large.svg\" alt=\"\" class=\"footer-bg-image\" loading=\"lazy\" />\n    </div>\n  </footer>"
        },
