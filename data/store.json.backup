      ],
      "sections": [
        {
          "id": "services-section-2772c745",
          "label": "Services page hero",
          "enabled": true,
          "html": "<header>\r\n        <section class=\"service-hero-section\" aria-label=\"Services page hero\">\r\n            <nav class=\"home-navbar\" aria-label=\"Main navigation\">\r\n                <div class=\"home-nav-container\">\r\n                    <div class=\"home-logo\"> <a href=\"/\" class=\"logo-link\"\r\n                            aria-label=\"Webx Design Studio - Go to homepage\"> <img\r\n                                src=\"/assets/images/logos/webx-logo.svg\" alt=\"Webx Design Studio\" width=\"140\"\r\n                                height=\"40\" /> </a> </div> <a href=\"/pages/main/contact-page.html\"\r\n                        class=\"home-contact-btn\"> <span>CONTACT US</span> <svg width=\"16\" height=\"16\"\r\n                            viewBox=\"0 0 16 16\" fill=\"none\" aria-hidden=\"true\">\r\n                            <path d=\"M3 13L13 3M13 3H5M13 3V11\" stroke=\"currentColor\" stroke-width=\"2\"\r\n                                stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                        </svg> </a>\r\n                </div>\r\n            </nav>\r\n        </section>\r\n    </header>"
        },
        {
          "id": "services-section-a9867d39",
          "label": "Services introduction",
          "enabled": true,
          "html": "<section class=\"services-section\" aria-label=\"Services introduction\">\r\n            <div class=\"services-container\">\r\n                <h1 class=\"services-page-title\">We build digital products that move people.</h1>\r\n                <p class=\"services-description\"> At Webx Design Studio, we are more than a design agency. We are a team\r\n                    of designers, strategists, and developers who use human insight and modern tools like AI to solve\r\n                    real business problems. We dive deep into your unique goals to create digital experiences that are\r\n                    simple, scalable, and transformative. </p>\r\n                <div class=\"services-image-wrapper\"> <img src=\"/assets/images/banners/services-banner.png\"\r\n                        alt=\"Webx Design Studio UI/UX design and web development services overview\"\r\n                        class=\"services-image\" width=\"1200\" height=\"600\" loading=\"eager\" /> </div>\r\n            </div>\r\n        </section>"
        },
        {
          "id": "services-section-cc462ae3",
          "label": "Core services list",
          "enabled": true,
          "html": "<section class=\"services-accordion-section\" aria-label=\"Core services list\">\r\n            <div class=\"services-accordion-container\">\r\n                <div class=\"sliding-text-wrapper\" aria-hidden=\"true\">\r\n                    <div class=\"sliding-text\"> <span class=\"text-outlined\">Our Services</span> <span class=\"text-separator\">&bull;</span> <span class=\"text-filled\">What we do</span> <span class=\"text-separator\">&bull;</span> <span class=\"text-outlined\">Our Services</span> <span class=\"text-separator\">&bull;</span> <span class=\"text-filled\">What we do</span> <span class=\"text-separator\">&bull;</span> <span class=\"text-outlined\">Our Services</span> <span class=\"text-separator\">&bull;</span> <span class=\"text-filled\">What we do</span> <span class=\"text-separator\">&bull;</span> <span class=\"text-outlined\">Our Services</span> <span class=\"text-separator\">&bull;</span> <span class=\"text-filled\">What we do</span> <span class=\"text-separator\">&bull;</span> </div>\r\n                </div>\r\n                <div class=\"section-header\">\r\n                    <p class=\"section-label\">Core Services</p>\r\n                    <h2 class=\"section-title\">Designing for Impact, Delivering Results</h2>\r\n                </div>\r\n                <div class=\"accordion-item active\"> <button class=\"accordion-header\" aria-expanded=\"true\"\r\n                        aria-controls=\"accordion-content-1\"> <span class=\"accordion-number\">01</span>\r\n                        <h3 class=\"accordion-title\">Website Design</h3> <span class=\"accordion-arrow-circle\"\r\n                            aria-hidden=\"true\"> <svg class=\"arrow-svg\" viewBox=\"0 0 24 24\" fill=\"none\"\r\n                                xmlns=\"http:/www.w3.org/2000/svg\">\r\n                                <path d=\"M5 12H19M19 12L12 5M19 12L12 19\" stroke=\"black\" stroke-width=\"2.5\"\r\n                                    stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                            </svg> </span>\r\n                    </button>\r\n                    <div class=\"accordion-content\" id=\"accordion-content-1\" role=\"region\">\r\n                        <div class=\"accordion-content-inner\">\r\n                            <p class=\"accordion-text\">Developing high-performance platforms that serve as your brand's\r\n                                central digital headquarters. These websites are engineered for speed, technical\r\n                                precision, and high conversion, ensuring a seamless and professional experience across\r\n                                all devices.</p> <a href=\"/pages/system/service-form.html\" class=\"accordion-cta-button\">\r\n                                <span>GET ESTIMATE</span> <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\"\r\n                                    aria-hidden=\"true\">\r\n                                    <path d=\"M3 13L13 3M13 3H5M13 3V11\" stroke=\"currentColor\" stroke-width=\"2\"\r\n                                        stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                                </svg> </a>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n                <div class=\"accordion-item\"> <button class=\"accordion-header\" aria-expanded=\"false\"\r\n                        aria-controls=\"accordion-content-2\"> <span class=\"accordion-number\">02</span>\r\n                        <h3 class=\"accordion-title\">App Design</h3> <span class=\"accordion-arrow-circle\"\r\n                            aria-hidden=\"true\"> <svg class=\"arrow-svg\" viewBox=\"0 0 24 24\" fill=\"none\"\r\n                                xmlns=\"http:/www.w3.org/2000/svg\">\r\n                                <path d=\"M5 12H19M19 12L12 5M19 12L12 19\" stroke=\"black\" stroke-width=\"2.5\"\r\n                                    stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                            </svg> </span>\r\n                    </button>\r\n                    <div class=\"accordion-content\" id=\"accordion-content-2\" role=\"region\">\r\n                        <div class=\"accordion-content-inner\">\r\n                            <p class=\"accordion-text\">Architecting intuitive mobile and web applications that simplify\r\n                                complex interactions through frictionless navigation. By focusing on user-first logic\r\n                                and clean aesthetics, these digital products ensure high usability and long-term user\r\n                                retention.</p> <a href=\"/pages/system/service-form.html\" class=\"accordion-cta-button\">\r\n                                <span>GET ESTIMATE</span> <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\"\r\n                                    aria-hidden=\"true\">\r\n                                    <path d=\"M3 13L13 3M13 3H5M13 3V11\" stroke=\"currentColor\" stroke-width=\"2\"\r\n                                        stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                                </svg> </a>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n                <div class=\"accordion-item\"> <button class=\"accordion-header\" aria-expanded=\"false\"\r\n                        aria-controls=\"accordion-content-3\"> <span class=\"accordion-number\">03</span>\r\n                        <h3 class=\"accordion-title\">Graphics Design</h3> <span class=\"accordion-arrow-circle\"\r\n                            aria-hidden=\"true\"> <svg class=\"arrow-svg\" viewBox=\"0 0 24 24\" fill=\"none\"\r\n                                xmlns=\"http:/www.w3.org/2000/svg\">\r\n                                <path d=\"M5 12H19M19 12L12 5M19 12L12 19\" stroke=\"black\" stroke-width=\"2.5\"\r\n                                    stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                            </svg> </span>\r\n                    </button>\r\n                    <div class=\"accordion-content\" id=\"accordion-content-3\" role=\"region\">\r\n                        <div class=\"accordion-content-inner\">\r\n                            <p class=\"accordion-text\">Creating bold visual identity systems that translate core business\r\n                                values into unforgettable brand assets. From initial logo concepts to comprehensive\r\n                                brand guidelines, these frameworks ensure a consistent and authoritative presence across\r\n                                every touchpoint.</p> <a href=\"/pages/system/service-form.html\"\r\n                                class=\"accordion-cta-button\"> <span>GET ESTIMATE</span> <svg width=\"16\" height=\"16\"\r\n                                    viewBox=\"0 0 16 16\" fill=\"none\" aria-hidden=\"true\">\r\n                                    <path d=\"M3 13L13 3M13 3H5M13 3V11\" stroke=\"currentColor\" stroke-width=\"2\"\r\n                                        stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                                </svg> </a>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n                <div class=\"accordion-item\"> <button class=\"accordion-header\" aria-expanded=\"false\"\r\n                        aria-controls=\"accordion-content-4\"> <span class=\"accordion-number\">04</span>\r\n                        <h3 class=\"accordion-title\">Document Design</h3> <span class=\"accordion-arrow-circle\"\r\n                            aria-hidden=\"true\"> <svg class=\"arrow-svg\" viewBox=\"0 0 24 24\" fill=\"none\"\r\n                                xmlns=\"http:/www.w3.org/2000/svg\">\r\n                                <path d=\"M5 12H19M19 12L12 5M19 12L12 19\" stroke=\"black\" stroke-width=\"2.5\"\r\n                                    stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                            </svg> </span>\r\n                    </button>\r\n                    <div class=\"accordion-content\" id=\"accordion-content-4\" role=\"region\">\r\n                        <div class=\"accordion-content-inner\">\r\n                            <p class=\"accordion-text\">Engineering impactful pitch decks and branded reports that\r\n                                transform dense data into clear, persuasive narratives. These designs prioritize visual\r\n                                hierarchy, providing your team with the professional tools needed to influence\r\n                                high-level business decisions.</p> <a href=\"/pages/system/service-form.html\"\r\n                                class=\"accordion-cta-button\"> <span>GET ESTIMATE</span> <svg width=\"16\" height=\"16\"\r\n                                    viewBox=\"0 0 16 16\" fill=\"none\" aria-hidden=\"true\">\r\n                                    <path d=\"M3 13L13 3M13 3H5M13 3V11\" stroke=\"currentColor\" stroke-width=\"2\"\r\n                                        stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                                </svg> </a>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n                <div class=\"accordion-item\"> <button class=\"accordion-header\" aria-expanded=\"false\"\r\n                        aria-controls=\"accordion-content-5\"> <span class=\"accordion-number\">05</span>\r\n                        <h3 class=\"accordion-title\">Social Media Design</h3> <span class=\"accordion-arrow-circle\"\r\n                            aria-hidden=\"true\"> <svg class=\"arrow-svg\" viewBox=\"0 0 24 24\" fill=\"none\"\r\n                                xmlns=\"http:/www.w3.org/2000/svg\">\r\n                                <path d=\"M5 12H19M19 12L12 5M19 12L12 19\" stroke=\"black\" stroke-width=\"2.5\"\r\n                                    stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                            </svg> </span>\r\n                    </button>\r\n                    <div class=\"accordion-content\" id=\"accordion-content-5\" role=\"region\">\r\n                        <div class=\"accordion-content-inner\">\r\n                            <p class=\"accordion-text\">Producing high-engagement content tailored to foster community\r\n                                growth and strengthen brand visibility. These strategic visuals are designed to capture\r\n                                attention instantly in crowded feeds, effectively amplifying your brand's voice and\r\n                                messaging.</p> <a href=\"/pages/system/service-form.html\" class=\"accordion-cta-button\">\r\n                                <span>GET ESTIMATE</span> <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\"\r\n                                    aria-hidden=\"true\">\r\n                                    <path d=\"M3 13L13 3M13 3H5M13 3V11\" stroke=\"currentColor\" stroke-width=\"2\"\r\n                                        stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                                </svg> </a>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n                <div class=\"accordion-item\"> <button class=\"accordion-header\" aria-expanded=\"false\"\r\n                        aria-controls=\"accordion-content-6\"> <span class=\"accordion-number\">06</span>\r\n                        <h3 class=\"accordion-title\">Marketing Mailer</h3> <span class=\"accordion-arrow-circle\"\r\n                            aria-hidden=\"true\"> <svg class=\"arrow-svg\" viewBox=\"0 0 24 24\" fill=\"none\"\r\n                                xmlns=\"http:/www.w3.org/2000/svg\">\r\n                                <path d=\"M5 12H19M19 12L12 5M19 12L12 19\" stroke=\"black\" stroke-width=\"2.5\"\r\n                                    stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                            </svg> </span>\r\n                    </button>\r\n                    <div class=\"accordion-content\" id=\"accordion-content-6\" role=\"region\">\r\n                        <div class=\"accordion-content-inner\">\r\n                            <p class=\"accordion-text\">Structuring conversion-focused email experiences built to cut\r\n                                through inbox noise and inspire direct user action. By balancing clean aesthetics with\r\n                                clear calls-to-action, these mailers help brands maintain effective and professional\r\n                                communication with their audience.</p> <a href=\"/pages/system/service-form.html\"\r\n                                class=\"accordion-cta-button\"> <span>GET ESTIMATE</span> <svg width=\"16\" height=\"16\"\r\n                                    viewBox=\"0 0 16 16\" fill=\"none\" aria-hidden=\"true\">\r\n                                    <path d=\"M3 13L13 3M13 3H5M13 3V11\" stroke=\"currentColor\" stroke-width=\"2\"\r\n                                        stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                                </svg> </a>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n                <div class=\"accordion-item\"> <button class=\"accordion-header\" aria-expanded=\"false\"\r\n                        aria-controls=\"accordion-content-7\"> <span class=\"accordion-number\">07</span>\r\n                        <h3 class=\"accordion-title\">Customize Tools</h3> <span class=\"accordion-arrow-circle\"\r\n                            aria-hidden=\"true\"> <svg class=\"arrow-svg\" viewBox=\"0 0 24 24\" fill=\"none\"\r\n                                xmlns=\"http:/www.w3.org/2000/svg\">\r\n                                <path d=\"M5 12H19M19 12L12 5M19 12L12 19\" stroke=\"black\" stroke-width=\"2.5\"\r\n                                    stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                            </svg> </span>\r\n                    </button>\r\n                    <div class=\"accordion-content\" id=\"accordion-content-7\" role=\"region\">\r\n                        <div class=\"accordion-content-inner\">\r\n                            <p class=\"accordion-text\">Building specialized dashboards and SaaS platforms designed for\r\n                                operational efficiency and internal scale. This approach turns complex data sets into\r\n                                intuitive, manageable tools that empower teams to work with greater speed and clarity.\r\n                            </p> <a href=\"/pages/system/service-form.html\" class=\"accordion-cta-button\"> <span>GET\r\n                                    ESTIMATE</span> <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\"\r\n                                    aria-hidden=\"true\">\r\n                                    <path d=\"M3 13L13 3M13 3H5M13 3V11\" stroke=\"currentColor\" stroke-width=\"2\"\r\n                                        stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                                </svg> </a>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </section>"
        },
        {
          "id": "services-section-12d82eea",
          "label": "Our clients",
          "enabled": true,
          "html": "<section class=\"clients-section\" aria-label=\"Our clients\">\r\n            <div class=\"clients-container\">\r\n                <div class=\"section-header\">\r\n                    <p class=\"section-label\">Clients</p>\r\n                    <h2 class=\"section-title\">Brands That Trust Our Craft</h2>\r\n                </div>\r\n                <div class=\"clients-slider-wrapper animate-logos\" aria-label=\"Client logo carousel\">\r\n          <div class=\"clients-slider\">\r\n            <div class=\"client-logo\"><img src=\"/assets/images/clients/bajaj-logo.png\" alt=\"Bajaj - client of Webx Design Studio\" width=\"120\" height=\"60\" loading=\"lazy\" /></div>\r\n            <div class=\"client-logo\"><img src=\"/assets/images/logos/ab-logo.png\" alt=\"Arogya Bharat - client of Webx Design Studio\" width=\"120\" height=\"60\" loading=\"lazy\" /></div>\r\n            <div class=\"client-logo\"><img src=\"/assets/images/clients/manglam-logo.png\" alt=\"Manglam - client of Webx Design Studio\" width=\"120\" height=\"60\" loading=\"lazy\" /></div>\r\n            <div class=\"client-logo\"><img src=\"/assets/images/clients/de-logo.png\" alt=\"Dharmesh Enterprise - client of Webx Design Studio\" width=\"120\" height=\"60\" loading=\"lazy\" /></div>\r\n            <div class=\"client-logo\"><img src=\"/assets/images/clients/morphico-logo.png\" alt=\"Morphico - client of Webx Design Studio\" width=\"120\" height=\"60\" loading=\"lazy\" /></div>\r\n            <div class=\"client-logo\"><img src=\"/assets/images/clients/mecon-logo.png\" alt=\"Mecon - client of Webx Design Studio\" width=\"120\" height=\"60\" loading=\"lazy\" /></div>\r\n            <div class=\"client-logo\"><img src=\"/assets/images/clients/tictax-logo.png\" alt=\"TicTax - client of Webx Design Studio\" width=\"120\" height=\"60\" loading=\"lazy\" /></div>\r\n            <div class=\"client-logo\"><img src=\"/assets/images/clients/gurukrupa-logo.png\" alt=\"Gurukrupa - client of Webx Design Studio\" width=\"120\" height=\"60\" loading=\"lazy\" /></div>\r\n            <!-- Duplicates for infinite scroll (aria-hidden to avoid screen reader repetition) -->\r\n            <div class=\"client-logo\" aria-hidden=\"true\"><img src=\"/assets/images/clients/bajaj-logo.png\" alt=\"\" width=\"120\" height=\"60\" loading=\"lazy\" /></div>\r\n            <div class=\"client-logo\" aria-hidden=\"true\"><img src=\"/assets/images/logos/ab-logo.png\" alt=\"\" width=\"120\" height=\"60\" loading=\"lazy\" /></div>\r\n            <div class=\"client-logo\" aria-hidden=\"true\"><img src=\"/assets/images/clients/tictax-logo.png\" alt=\"\" width=\"120\" height=\"60\" loading=\"lazy\" /></div>\r\n            <div class=\"client-logo\" aria-hidden=\"true\"><img src=\"/assets/images/clients/morphico-logo.png\" alt=\"\" width=\"120\" height=\"60\" loading=\"lazy\" /></div>\r\n            <div class=\"client-logo\" aria-hidden=\"true\"><img src=\"/assets/images/clients/mecon-logo.png\" alt=\"\" width=\"120\" height=\"60\" loading=\"lazy\" /></div>\r\n            <div class=\"client-logo\" aria-hidden=\"true\"><img src=\"/assets/images/clients/manglam-logo.png\" alt=\"\" width=\"120\" height=\"60\" loading=\"lazy\" /></div>\r\n            <div class=\"client-logo\" aria-hidden=\"true\"><img src=\"/assets/images/clients/gurukrupa-logo.png\" alt=\"\" width=\"120\" height=\"60\" loading=\"lazy\" /></div>\r\n            <div class=\"client-logo\" aria-hidden=\"true\"><img src=\"/assets/images/clients/de-logo.png\" alt=\"\" width=\"120\" height=\"60\" loading=\"lazy\" /></div>\r\n          </div>\r\n        </div>\r\n            </div>\r\n        </section>"
        },
        {
          "id": "services-section-3c9383d0",
          "label": "Frequently asked questions",
          "enabled": true,
          "html": "<section class=\"faq-section\" aria-label=\"Frequently asked questions\">\r\n            <div class=\"faq-container\">\r\n                <div class=\"section-header\">\r\n                    <p class=\"section-label\">Frequently Asked Questions</p>\r\n                    <h2 class=\"section-title\">Find answers to common questions about our services</h2>\r\n                </div>\r\n                <div class=\"faq-accordion\">\r\n                    <div class=\"faq-item active\"> <button class=\"faq-question\" aria-expanded=\"true\"\r\n                            aria-controls=\"faq-answer-1\"> <span>How much does a website or app design cost?</span> <span\r\n                                class=\"faq-icon\" aria-hidden=\"true\">x</span> </button>\r\n                        <div class=\"faq-answer\" id=\"faq-answer-1\" role=\"region\">\r\n                            <p>Costs vary based on complexity and features. A professional website typically ranges from\r\n                                Rs. 25,000 to Rs. 50,000, while custom e-commerce or SaaS solutions range from Rs.\r\n                                1,00,000 to Rs. 5,00,000+. We provide detailed quotes after understanding your specific\r\n                                needs.</p>\r\n                        </div>\r\n                    </div>\r\n                    <div class=\"faq-item\"> <button class=\"faq-question\" aria-expanded=\"false\"\r\n                            aria-controls=\"faq-answer-2\"> <span>How do you use AI in your design process?</span> <span\r\n                                class=\"faq-icon\" aria-hidden=\"true\">+</span> </button>\r\n                        <div class=\"faq-answer\" id=\"faq-answer-2\" role=\"region\">\r\n                            <p>We use emerging AI tools to push digital experiences forward and improve efficiency. This\r\n                                allows us to focus more on human insight and strategic thinking to craft meaningful\r\n                                solutions.</p>\r\n                        </div>\r\n                    </div>\r\n                    <div class=\"faq-item\"> <button class=\"faq-question\" aria-expanded=\"false\"\r\n                            aria-controls=\"faq-answer-3\"> <span>Can you help with branding from scratch?</span> <span\r\n                                class=\"faq-icon\" aria-hidden=\"true\">+</span> </button>\r\n                        <div class=\"faq-answer\" id=\"faq-answer-3\" role=\"region\">\r\n                            <p>Yes. From early ideas to refined design systems, we build with clarity and intention. We\r\n                                create full identity systems, logos, and visuals that define your brand.</p>\r\n                        </div>\r\n                    </div>\r\n                    <div class=\"faq-item\"> <button class=\"faq-question\" aria-expanded=\"false\"\r\n                            aria-controls=\"faq-answer-4\"> <span>How do you ensure the design fits our audience?</span>\r\n                            <span class=\"faq-icon\" aria-hidden=\"true\">+</span> </button>\r\n                        <div class=\"faq-answer\" id=\"faq-answer-4\" role=\"region\">\r\n                            <p>Every project starts with understanding people first. We delve deep into your unique\r\n                                needs and target audience to craft intuitive solutions.</p>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </section>"
        },
        {
          "id": "services-section-10cb28f9",
          "label": "Site footer",
          "enabled": true,
          "html": "<footer class=\"footer-section\" aria-label=\"Site footer\">\r\n        <div class=\"footer-container\">\r\n            <div class=\"footer-top\">\r\n                <div class=\"footer-logo\"> <img src=\"/assets/images/logos/webx-logo.svg\" alt=\"Webx Design Studio\"\r\n                        class=\"footer-logo-img\" width=\"140\" height=\"40\" loading=\"lazy\" /> </div>\r\n                <div class=\"footer-social\"> <a href=\"https://www.linkedin.com/in/piyushgohil8889/\" target=\"_blank\"\r\n                        rel=\"noopener noreferrer\" class=\"social-icon\" aria-label=\"Webx Design Studio on LinkedIn\"> <img\r\n                            src=\"/assets/images/icons/linkedin-icon.png\" alt=\"LinkedIn\" class=\"social-icon-img\"\r\n                            width=\"24\" height=\"24\" loading=\"lazy\" /> </a> <a href=\"https://dribbble.com/desinger8889\"\r\n                        target=\"_blank\" rel=\"noopener noreferrer\" class=\"social-icon\"\r\n                        aria-label=\"Webx Design Studio on Dribbble\"> <img src=\"/assets/images/icons/dribbble-icon.png\"\r\n                            alt=\"Dribbble\" class=\"social-icon-img\" width=\"24\" height=\"24\" loading=\"lazy\" /> </a> <a\r\n                        href=\"https://www.behance.net/Piyushgohil8889\" target=\"_blank\" rel=\"noopener noreferrer\"\r\n                        class=\"social-icon\" aria-label=\"Webx Design Studio on Behance\"> <img\r\n                            src=\"/assets/images/icons/behance-icon.png\" alt=\"Behance\" class=\"social-icon-img\" width=\"24\"\r\n                            height=\"24\" loading=\"lazy\" /> </a> </div>\r\n            </div>\r\n            <div class=\"footer-section-block\">\r\n                <h3 class=\"footer-heading\"> Services <button class=\"footer-toggle\" aria-label=\"Toggle Services menu\"\r\n                        aria-expanded=\"false\"> <span class=\"accordion-arrow-circle\"> <svg class=\"arrow-svg\"\r\n                                viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http:/www.w3.org/2000/svg\" aria-hidden=\"true\">\r\n                                <path d=\"M5 12H19M19 12L12 5M19 12L12 19\" stroke=\"black\" stroke-width=\"2.5\"\r\n                                    stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                            </svg> </span> </button> </h3>\r\n                <div class=\"footer-links\"> <a href=\"/pages/main/services.html\">UI/UX Design</a> <a\r\n                        href=\"/pages/main/services.html\">Web Design</a> <a href=\"/pages/main/services.html\">App\r\n                        Design</a> <a href=\"/pages/main/services.html\">Marketing Emailer</a> <a\r\n                        href=\"/pages/main/services.html\">Social Media</a> <a href=\"/pages/main/services.html\">Logo\r\n                        Design</a> <a href=\"/pages/main/services.html\">Graphics Design</a> <a\r\n                        href=\"/pages/main/services.html\">Tool Design</a> <a href=\"/pages/main/services.html\">Document\r\n                        Design</a> <a href=\"/pages/main/services.html\">ETC Design</a> </div>\r\n            </div>\r\n            <div class=\"footer-section-block\">\r\n                <h3 class=\"footer-heading\"> Company <button class=\"footer-toggle\" aria-label=\"Toggle Company menu\"\r\n                        aria-expanded=\"false\"> <span class=\"accordion-arrow-circle\"> <svg class=\"arrow-svg\"\r\n                                viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http:/www.w3.org/2000/svg\" aria-hidden=\"true\">\r\n                                <path d=\"M5 12H19M19 12L12 5M19 12L12 19\" stroke=\"black\" stroke-width=\"2.5\"\r\n                                    stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                            </svg> </span> </button> </h3>\r\n                <div class=\"footer-links\"> <a href=\"/pages/main/about.html\">About Us</a> <a\r\n                        href=\"/pages/blogs/blogs.html\">Blog</a> <a href=\"/pages/main/contact-page.html\">Contact</a> <a\r\n                        href=\"/pages/legal/privacy-policy.html\">Privacy Policy</a> <a\r\n                        href=\"/pages/legal/term-condition.html\">Terms of Service</a> </div>\r\n            </div>\r\n            <div class=\"footer-bottom\">\r\n                <p class=\"footer-copyright\">&copy; 2026 Webx Design Studio. All rights reserved</p>\r\n            </div>\r\n        </div>\r\n        <div class=\"footer-bg-text\" aria-hidden=\"true\"> <img src=\"/assets/images/logos/webx-footer-logo-large.svg\"\r\n                alt=\"\" class=\"footer-bg-image\" loading=\"lazy\" /> </div>\r\n    </footer>"
        },
        {
          "id": "services-section-36240195",
          "label": "Bottom navigation",
          "enabled": true,
          "html": "<nav class=\"bottom-navbar\" aria-label=\"Bottom navigation\">\r\n        <div class=\"bottom-nav-logo\"> <a href=\"/\" class=\"logo-link\"\r\n                aria-label=\"Webx Design Studio - Go to homepage\"> <img src=\"/assets/images/logos/webx-logo.svg\"\r\n                    alt=\"Webx Design Studio\" class=\"logo-full\" width=\"100\" height=\"30\" loading=\"lazy\" /> <img\r\n                    src=\"/assets/images/icons/webx-icon.svg\" alt=\"Webx\" class=\"logo-icon\" width=\"32\" height=\"32\"\r\n                    loading=\"lazy\" /> </a> </div>\r\n        <div class=\"bottom-nav-container\"> <a href=\"/\" class=\"nav-item\"> <img\r\n                    src=\"/assets/images/others/home.png\" alt=\"\" class=\"nav-icon\" aria-hidden=\"true\" width=\"24\"\r\n                    height=\"24\" loading=\"lazy\" /> <span class=\"nav-label\">Home</span> </a> <a\r\n                href=\"/pages/main/work.html\" class=\"nav-item\"> <img src=\"/assets/images/others/work.png\" alt=\"\"\r\n                    class=\"nav-icon\" aria-hidden=\"true\" width=\"24\" height=\"24\" loading=\"lazy\" /> <span\r\n                    class=\"nav-label\">Work</span> </a> <a href=\"/pages/main/services.html\" class=\"nav-item active\"\r\n                aria-current=\"page\"> <img src=\"/assets/images/others/services.png\" alt=\"\" class=\"nav-icon\"\r\n                    aria-hidden=\"true\" width=\"24\" height=\"24\" loading=\"lazy\" /> <span class=\"nav-label\">Services</span>\r\n            </a> <a href=\"/pages/main/about.html\" class=\"nav-item\"> <img src=\"/assets/images/others/about.png\" alt=\"\"\r\n                    class=\"nav-icon\" aria-hidden=\"true\" width=\"24\" height=\"24\" loading=\"lazy\" /> <span\r\n                    class=\"nav-label\">About</span> </a> <a href=\"/pages/main/contact-page.html\" class=\"nav-item\"> <img\r\n                    src=\"/assets/images/others/contact.png\" alt=\"\" class=\"nav-icon\" aria-hidden=\"true\" width=\"24\"\r\n                    height=\"24\" loading=\"lazy\" /> <span class=\"nav-label\">Contact</span> </a> <button\r\n                class=\"nav-item more-toggle\" type=\"button\" aria-label=\"Open full navigation menu\" aria-expanded=\"false\"\r\n                aria-controls=\"moreMenu\"> <svg class=\"more-icon\" viewBox=\"0 0 24 24\" aria-hidden=\"true\">\r\n                    <line x1=\"5\" y1=\"8\" x2=\"19\" y2=\"8\" />\r\n                    <line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\" />\r\n                    <line x1=\"5\" y1=\"16\" x2=\"19\" y2=\"16\" />\r\n                </svg> <span class=\"nav-label\">More</span> </button> </div>\r\n    </nav>"
        }
      ],
