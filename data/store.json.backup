        {
          "id": "contact-section-846fefa7",
          "label": "Contact information and office locations",
          "enabled": true,
          "html": "<section class=\"contact-offices-section\" id=\"contact\" aria-label=\"Contact information and office locations\">\r\n            <div class=\"contact-offices-container\">\r\n                <div class=\"contact-header\">\r\n                    <h1 class=\"contact-main-title\">Ready to build something meaningful?</h1>\r\n                    <p class=\"contact-subtitle\">Let's take your vision and turn it into a high-performing digital\r\n                        reality.</p>\r\n                </div>\r\n                <div class=\"offices-label-wrapper\"> <span class=\"offices-label\">Our Office</span> </div>\r\n                <div class=\"offices-section\">\r\n                    <h2 class=\"offices-title\">Reach Out to Our Offices</h2>\r\n                    <div class=\"office-block\">\r\n                        <h3 class=\"office-heading\">Head Office</h3>\r\n                        <address class=\"office-address\"> Webx Design Studio,<br /> C/o Viral Studio, Navanagar Society,\r\n                            Radar Road, Gokulnagar, Jamnagar, Gujarat - 361004 </address>\r\n                    </div>\r\n                    <div class=\"office-block\">\r\n                        <h3 class=\"office-heading\">Branch Office</h3>\r\n                        <address class=\"office-address\"> Webx Design Studio,<br /> Umakant Pandit Udhyog Nagar,\r\n                            Chandreshnagar,<br /> Rajkot, Gujarat - 360004 </address>\r\n                    </div>\r\n                    <div class=\"contact-info-wrapper\">\r\n                        <div class=\"contact-info-block\">\r\n                            <h3 class=\"contact-info-heading\">Reach out to us</h3>\r\n                            <div class=\"contact-links\"> <a href=\"tel:+918000541833\" class=\"contact-link\"\r\n                                    aria-label=\"Call Webx Design Studio at +91 80005 41833\"> <svg\r\n                                        class=\"contact-arrow-icon\" viewBox=\"0 0 24 24\" fill=\"none\"\r\n                                        xmlns=\"http:/www.w3.org/2000/svg\" aria-hidden=\"true\">\r\n                                        <path d=\"M7 17L17 7M17 7H7M17 7V17\" stroke=\"currentColor\" stroke-width=\"2\"\r\n                                            stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                                    </svg> +91 80005 41833 </a> <a href=\"mailto:piyush.gohil@webxds.com\"\r\n                                    class=\"contact-link\"\r\n                                    aria-label=\"Email Webx Design Studio at piyush.gohil@webxds.com\"> <svg\r\n                                        class=\"contact-arrow-icon\" viewBox=\"0 0 24 24\" fill=\"none\"\r\n                                        xmlns=\"http:/www.w3.org/2000/svg\" aria-hidden=\"true\">\r\n                                        <path d=\"M7 17L17 7M17 7H7M17 7V17\" stroke=\"currentColor\" stroke-width=\"2\"\r\n                                            stroke-linecap=\"round\" stroke-linejoin=\"round\" />\r\n                                    </svg> piyush.gohil@webxds.com </a> </div>\r\n                        </div> \r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </section>"
        },
